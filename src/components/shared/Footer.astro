---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner container">
    <a href="/" class="footer-glyph-link" aria-label="SG57 Labs home">
      <img src="/sg57/glyph-192.png" alt="SG57" class="footer-glyph" width="48" height="48" loading="lazy" />
    </a>
    <span class="copyright">&copy; {year} SG57 Labs</span>
    <a href="mailto:support@sg57.dev">Support</a>
    <span class="separator">|</span>
    <a href="https://sg57.dev">sg57.dev</a>
  </div>
</footer>

<style>
  .footer {
    margin-top: auto;
    background: var(--sg57-glass-bg);
    backdrop-filter: blur(var(--sg57-glass-blur));
    -webkit-backdrop-filter: blur(var(--sg57-glass-blur));
    border-top: 1px solid var(--sg57-glass-border);
    padding: 1.5rem 0;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .footer-glyph-link {
    display: inline-flex;
    transition: transform 0.2s ease;
    border-radius: var(--sg57-radius-sm);
  }

  .footer-glyph-link:hover {
    transform: translateY(-1px);
  }

  .footer-glyph-link:active {
    transform: scale(0.95);
  }

  .footer-glyph-link:focus-visible {
    box-shadow: var(--sg57-focus-ring);
  }

  .footer-glyph {
    width: 48px;
    height: 48px;
    object-fit: contain;
    opacity: 0.5;
    transition: opacity 0.2s ease;
  }

  .footer-glyph-link:hover .footer-glyph {
    opacity: 0.8;
  }

  .copyright {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: 1.125rem;
    color: var(--sg57-text-muted);
  }

  .separator {
    color: var(--sg57-text-muted);
    font-size: 1.125rem;
  }

  .footer a {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: 1.125rem;
    color: var(--sg57-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 0.25rem;
  }

  .footer a:hover {
    color: var(--sg57-accent);
  }

  .footer a:active {
    opacity: 0.75;
  }

  .footer a:focus-visible {
    box-shadow: var(--sg57-focus-ring);
    border-radius: var(--sg57-radius-sm);
  }
</style>
