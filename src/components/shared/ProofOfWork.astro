---
import BeforeAfterSlider from '../services/BeforeAfterSlider.astro';
---

<section class="proof-section" aria-labelledby="proof-heading">
  <div class="proof-container container">

    <!-- Section label -->
    <h2 class="proof-eyebrow" id="proof-heading">PROOF OF WORK</h2>

    <!-- Client card header -->
    <div class="proof-card">
      <div class="proof-header">
        <div class="proof-meta">
          <span class="proof-tag">Client</span>
          <h3 class="proof-client">Staples &amp; Statements</h3>
          <p class="proof-type">Wardrobe Stylist &mdash; Personal Brand</p>
        </div>
        <div class="proof-scope">
          <span class="proof-scope-label">Full Brand + Website + SEO + Marketing</span>
          <a
            href="https://staplesandstatements.com"
            class="proof-site-link"
            target="_blank"
            rel="noopener noreferrer"
          >
            staplesandstatements.com →
          </a>
        </div>
      </div>

      <!-- Narrative -->
      <div class="proof-narrative">
        <p>
          Danielle had built something real — a styling business growing on talent and word of mouth.
          But when someone asked for her website, she cringed. A decade of expertise, represented by nothing.
        </p>
        <p>
          We delivered the full white-glove treatment: brand strategy, visual identity, a custom website
          optimized for SEO and mobile, professional email, and branded social media templates — everything
          she needed to look as established online as she already was in person.
        </p>
      </div>

      <!-- Before / After slider -->
      <div class="proof-slider-wrap">
        <div class="proof-slider-label">
          <span class="psl-glyph" aria-hidden="true">◆</span>
          TRANSFORMATION
        </div>
        <BeforeAfterSlider
          beforeSrc="/services/ss-before.webp"
          afterSrc="/services/ss-after.webp"
          beforeAlt="Staples & Statements before redesign"
          afterAlt="Staples & Statements after redesign by SG57 Labs"
        />
      </div>

      <!-- Deliverables — always-visible cards showing what was built and WHY it matters -->
      <div class="proof-deliverables">
        <h4 class="proof-dl-label">What We Delivered — End to End</h4>
        <div class="proof-dl-grid">
          <div class="proof-dl-card">
            <div class="dl-card-glyph" aria-hidden="true">◈</div>
            <div class="dl-card-body">
              <span class="dl-card-title">Brand Strategy &amp; Positioning</span>
              <span class="dl-card-desc">Defines who you are, who you serve, and why clients choose you over the competition.</span>
            </div>
          </div>
          <div class="proof-dl-card">
            <div class="dl-card-glyph" aria-hidden="true">◆</div>
            <div class="dl-card-body">
              <span class="dl-card-title">Visual Identity System</span>
              <span class="dl-card-desc">Logo, colors, fonts, and photography direction that make your brand look as premium as your service.</span>
            </div>
          </div>
          <div class="proof-dl-card">
            <div class="dl-card-glyph" aria-hidden="true">⟐</div>
            <div class="dl-card-body">
              <span class="dl-card-title">Custom-Built Website</span>
              <span class="dl-card-desc">Mobile-friendly, SEO-optimized, with calendar booking, LTK shopping integration, and service pages that convert visitors into booked clients.</span>
            </div>
          </div>
          <div class="proof-dl-card">
            <div class="dl-card-glyph" aria-hidden="true">▣</div>
            <div class="dl-card-body">
              <span class="dl-card-title">Search Engine Optimization</span>
              <span class="dl-card-desc">Show up when people Google services like yours. First page rankings mean first choice.</span>
            </div>
          </div>
          <div class="proof-dl-card">
            <div class="dl-card-glyph" aria-hidden="true">⊕</div>
            <div class="dl-card-body">
              <span class="dl-card-title">Professional Email Setup</span>
              <span class="dl-card-desc">you@yourbusiness.com instead of Gmail — instantly more credible with every client interaction.</span>
            </div>
          </div>
          <div class="proof-dl-card">
            <div class="dl-card-glyph" aria-hidden="true">⌬</div>
            <div class="dl-card-body">
              <span class="dl-card-title">Social Media Templates</span>
              <span class="dl-card-desc">Branded, ready-to-post designs so your Instagram and LinkedIn always look polished and on-brand.</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Testimonial -->
      <div class="proof-testimonial-section">
        <span class="testimonial-quote" aria-hidden="true">&ldquo;</span>
        <blockquote class="proof-quote">
          <p class="proof-quote-text">
            SG57 Labs did an outstanding job taking the thoughts and ideas I had floating
            around in my head and bringing them to life on screen. I was dumbfounded when they
            first walked me through my site &mdash; the attention to detail and the overall vision
            they created perfectly matched what I wanted my business to look and feel like.
            There were organized rounds of revisions where I could make tweaks and changes along
            the way so that when we launched, it was a seamless effort. I can&rsquo;t recommend
            SG57 Labs enough &mdash; hands-down a phenomenal experience.
          </p>
          <footer class="proof-attribution">
            <img
              src="/team/danielle.jpg"
              alt="Danielle, Founder of Staples & Statements"
              class="attr-avatar"
              width="48"
              height="48"
              loading="lazy"
            />
            <div class="attr-info">
              <span class="attr-name">Danielle</span>
              <span class="attr-sep">//</span>
              <span class="attr-role">Founder, Staples &amp; Statements</span>
            </div>
          </footer>
        </blockquote>
      </div>

    </div><!-- /proof-card -->

    <!-- Page gallery -->
    <div class="proof-gallery">
      <a class="gallery-item" href="https://staplesandstatements.com" target="_blank" rel="noopener noreferrer">
        <img src="/work/ss-landing.webp" alt="Landing page" width="1440" height="900" loading="lazy" />
        <span class="gallery-label">Landing</span>
      </a>
      <a class="gallery-item" href="https://staplesandstatements.com/archetypes" target="_blank" rel="noopener noreferrer">
        <img src="/work/ss-archetypes.webp" alt="Style archetype quiz" width="1440" height="900" loading="lazy" />
        <span class="gallery-label">Archetypes</span>
      </a>
      <a class="gallery-item" href="https://staplesandstatements.com/shop" target="_blank" rel="noopener noreferrer">
        <img src="/work/ss-shop.webp" alt="LTK shop integration" width="1440" height="900" loading="lazy" />
        <span class="gallery-label">Shop</span>
      </a>
      <a class="gallery-item" href="https://staplesandstatements.com/services" target="_blank" rel="noopener noreferrer">
        <img src="/work/ss-services.webp" alt="Services page" width="1440" height="900" loading="lazy" />
        <span class="gallery-label">Services</span>
      </a>
    </div>

  </div>
</section>

<style>
  .proof-section {
    padding: 3rem 1.5rem 2.5rem;
  }

  .proof-container {
    max-width: 1120px;
  }

  .proof-eyebrow {
    display: block;
    font-family: var(--sg57-font-mono);
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--sg57-services-accent);
    margin-bottom: 1.25rem;
  }

  /* ── Card ── */
  .proof-card {
    background: var(--sg57-glass-bg);
    backdrop-filter: blur(var(--sg57-glass-blur));
    -webkit-backdrop-filter: blur(var(--sg57-glass-blur));
    border: 1px solid rgba(196, 137, 106, 0.2);
    box-shadow: 0 4px 24px rgba(196, 137, 106, 0.06), var(--sg57-glass-shadow);
    border-radius: var(--sg57-radius-lg);
    overflow: hidden;
  }

  /* ── Header ── */
  .proof-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
    padding: 2rem 2.5rem;
    border-bottom: 1px solid var(--sg57-glass-border);
  }

  .proof-tag {
    display: block;
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 1.125rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--sg57-services-accent);
    margin-bottom: 0.4rem;
  }

  .proof-client {
    font-family: var(--sg57-font-display);
    font-weight: 700;
    font-size: clamp(1.3rem, 3vw, 1.8rem);
    color: var(--sg57-text);
    letter-spacing: 0.02em;
    margin-bottom: 0.25rem;
    line-height: 1.2;
  }

  .proof-type {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: 1.125rem;
    color: var(--sg57-text-dim);
  }

  .proof-scope {
    flex-shrink: 0;
    text-align: right;
  }

  .proof-scope-label {
    display: block;
    font-family: var(--sg57-font-mono);
    font-size: 1.125rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sg57-text-dim);
    margin-bottom: 0.35rem;
  }

  .proof-site-link {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--sg57-services-accent);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: color 0.2s ease;
  }

  .proof-site-link:hover { color: var(--sg57-services-accent-hover); }

  .proof-site-link:active { opacity: 0.75; }

  .proof-site-link:focus-visible {
    box-shadow: var(--sg57-focus-ring);
    border-radius: var(--sg57-radius-sm);
  }

  /* ── Narrative ── */
  .proof-narrative {
    padding: 1.75rem 2.5rem;
    border-bottom: 1px solid var(--sg57-glass-border);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .proof-narrative p {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: 1.125rem;
    color: var(--sg57-text-dim);
    line-height: 1.75;
  }

  /* ── Slider ── */
  .proof-slider-wrap {
    border-bottom: 1px solid var(--sg57-glass-border);
  }

  .proof-slider-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 2.5rem;
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 1.125rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--sg57-services-accent);
    border-bottom: 1px solid var(--sg57-glass-border);
  }

  .psl-glyph {
    font-size: 1.125rem;
    animation: pulse-glow 4s ease-in-out infinite;
  }

  /* ── Deliverables ── */
  .proof-deliverables {
    padding: 1.75rem 2.5rem;
    border-bottom: 1px solid var(--sg57-glass-border);
  }

  .proof-dl-label {
    font-family: var(--sg57-font-display);
    font-weight: 500;
    font-size: 1.125rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sg57-text-dim);
    margin-bottom: 1rem;
  }

  .proof-dl-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  .proof-dl-card {
    display: flex;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--sg57-elevated);
    border: 1px solid var(--sg57-border-subtle);
    border-radius: var(--sg57-radius-md);
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .proof-dl-card:hover {
    border-color: var(--sg57-services-accent);
    box-shadow: 0 0 16px rgba(196, 137, 106, 0.1);
  }

  .dl-card-glyph {
    flex-shrink: 0;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--sg57-services-accent);
    opacity: 0.7;
    padding-top: 0.1rem;
  }

  .dl-card-body {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .dl-card-title {
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--sg57-text);
    letter-spacing: 0.02em;
    line-height: 1.3;
  }

  .dl-card-desc {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: 1.125rem;
    color: var(--sg57-text-dim);
    line-height: 1.5;
  }

  /* ── Testimonial ── */
  .proof-testimonial-section {
    position: relative;
    padding: 3rem 2.5rem 2rem;
  }

  .testimonial-quote {
    position: absolute;
    top: 0.6rem;
    left: 1.5rem;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 4rem;
    line-height: 1;
    color: var(--sg57-services-accent);
    opacity: 0.3;
    pointer-events: none;
  }

  .proof-quote {
    margin: 0;
    border: none;
    padding: 0;
  }

  .proof-quote-text {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: 1.125rem;
    color: var(--sg57-text-dim);
    line-height: 1.8;
    font-style: italic;
  }

  .proof-attribution {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1.25rem;
  }

  .attr-avatar {
    width: 48px;
    height: 48px;
    border-radius: var(--sg57-radius-full);
    object-fit: cover;
    border: 2px solid rgba(196, 137, 106, 0.4);
    flex-shrink: 0;
  }

  .attr-info {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-family: var(--sg57-font-mono);
    font-size: 1.125rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .attr-name {
    color: var(--sg57-text);
    font-weight: 600;
  }

  .attr-sep {
    color: var(--sg57-services-accent);
    opacity: 0.6;
  }

  .attr-role {
    color: var(--sg57-text-muted);
    font-weight: 400;
  }

  /* ── Gallery ── */
  .proof-gallery {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .gallery-item {
    position: relative;
    display: block;
    border-radius: var(--sg57-radius-md);
    overflow: hidden;
    border: 1px solid var(--sg57-border-glass);
    text-decoration: none;
    cursor: pointer;
    transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s var(--sg57-ease-snap);
  }

  .gallery-item:hover {
    border-color: rgba(196, 137, 106, 0.4);
    box-shadow: 0 8px 32px rgba(196, 137, 106, 0.18);
    transform: scale(1.06);
    z-index: 2;
  }

  .gallery-item:active {
    transform: scale(1.02);
  }

  .gallery-item:focus-visible {
    box-shadow: var(--sg57-focus-ring), 0 8px 32px rgba(196, 137, 106, 0.18);
    border-color: rgba(196, 137, 106, 0.4);
    outline: none;
  }

  .gallery-item img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    object-position: top center;
  }

  .gallery-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.35rem 0.6rem;
    font-family: var(--sg57-font-mono);
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--sg57-text-dim);
    background: var(--sg57-glass-bg-dense);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .proof-header {
      flex-direction: column;
      gap: 1rem;
    }

    .proof-scope {
      text-align: left;
    }

    .proof-dl-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .proof-gallery {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .proof-header,
    .proof-narrative,
    .proof-deliverables,
    .proof-testimonial-section {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }

    .proof-slider-label {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }

    .proof-dl-grid {
      grid-template-columns: 1fr;
    }

    .proof-gallery {
      grid-template-columns: 1fr;
    }
  }
</style>
