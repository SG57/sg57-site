---
const pathname = Astro.url.pathname;
function isActive(href: string): boolean {
  // Normalize trailing slashes for comparison
  const norm = (p: string) => p.replace(/\/+$/, '') || '/';
  return norm(pathname) === norm(href) || (href !== '/' && norm(pathname).startsWith(norm(href)));
}
---

<nav class="nav">
  <div class="nav-inner container">
    <a href="/" class="nav-logo" aria-label="SG57 Labs home">
      <img src="/sg57/glyph-32.png" alt="" class="nav-glyph" width="32" height="32" />
      <span class="logo-text">SG57</span>
      <span class="logo-sub">LABS</span>
    </a>

    <!-- Desktop links -->
    <div class="nav-links">
      <a href="/clide" class:list={[{ 'is-active': isActive('/clide') }]} aria-current={isActive('/clide') ? 'page' : undefined}>Clide</a>
      <a href="/siftr" class:list={[{ 'is-active': isActive('/siftr') }]} aria-current={isActive('/siftr') ? 'page' : undefined}>Siftr</a>
      <a href="/text-easy" class:list={[{ 'is-active': isActive('/text-easy') }]} aria-current={isActive('/text-easy') ? 'page' : undefined}>Text Easy</a>
      <a href="/services" class:list={[{ 'is-active': isActive('/services') }]} aria-current={isActive('/services') ? 'page' : undefined}>Services</a>
    </div>

    <!-- Mobile hamburger -->
    <button
      class="hamburger"
      id="hamburger"
      type="button"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="ham-bar"></span>
      <span class="ham-bar"></span>
      <span class="ham-bar"></span>
    </button>
  </div>

  <!-- Mobile menu panel -->
  <div class="mobile-menu" id="mobile-menu" role="region" aria-label="Mobile navigation">
    <a href="/clide" class:list={[{ 'is-active': isActive('/clide') }]} aria-current={isActive('/clide') ? 'page' : undefined}>Clide</a>
    <a href="/siftr" class:list={[{ 'is-active': isActive('/siftr') }]} aria-current={isActive('/siftr') ? 'page' : undefined}>Siftr</a>
    <a href="/text-easy" class:list={[{ 'is-active': isActive('/text-easy') }]} aria-current={isActive('/text-easy') ? 'page' : undefined}>Text Easy</a>
    <a href="/services" class:list={[{ 'is-active': isActive('/services') }]} aria-current={isActive('/services') ? 'page' : undefined}>Services</a>
  </div>
</nav>

<script>
  document.addEventListener('astro:page-load', () => {
    try {
    const hamburger = document.getElementById('hamburger');
    const menu = document.getElementById('mobile-menu');
    if (!hamburger || !menu) return;

    let open = false;

    // Collect all focusable elements inside the mobile menu
    function getMenuFocusables() {
      return [...menu.querySelectorAll('a, button')];
    }

    function openMenu() {
      open = true;
      hamburger.classList.add('is-open');
      hamburger.setAttribute('aria-expanded', 'true');
      menu.classList.add('is-open');
      // Move focus to first menu link
      const focusables = getMenuFocusables();
      if (focusables.length) {
        // Delay to let the CSS transition start so the element is visible
        requestAnimationFrame(() => focusables[0].focus());
      }
    }

    function closeMenu(returnFocus) {
      if (!open) return;
      open = false;
      hamburger.classList.remove('is-open');
      hamburger.setAttribute('aria-expanded', 'false');
      menu.classList.remove('is-open');
      if (returnFocus) hamburger.focus();
    }

    function toggle() {
      if (open) closeMenu(true);
      else openMenu();
    }

    hamburger.addEventListener('click', toggle);

    // Close on link click
    menu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => closeMenu(false)));

    // Close on Escape + focus trap within mobile menu
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && open) {
        e.preventDefault();
        closeMenu(true);
        return;
      }

      // Focus trap: keep Tab cycling within hamburger + menu items when open
      if (e.key === 'Tab' && open) {
        const focusables = [hamburger, ...getMenuFocusables()];
        const first = focusables[0];
        const last = focusables[focusables.length - 1];

        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });

    } catch (_) { /* Nav init failed — links remain functional without JS */ }
  });
</script>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--sg57-glass-bg);
    backdrop-filter: blur(var(--sg57-glass-blur));
    -webkit-backdrop-filter: blur(var(--sg57-glass-blur));
    border-bottom: 1px solid var(--sg57-glass-border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 3.5rem;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--sg57-text);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .nav-logo:hover {
    color: var(--sg57-accent);
  }

  .nav-glyph {
    width: 32px;
    height: 32px;
    object-fit: contain;
    flex-shrink: 0;
    opacity: 0.9;
    transition: opacity 0.2s ease, filter 0.2s ease;
  }

  .nav-logo:hover .nav-glyph {
    opacity: 1;
    filter: drop-shadow(0 0 8px var(--sg57-accent-glow));
  }

  .logo-text {
    font-family: var(--sg57-font-display);
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: 0.15em;
    transform: translateY(1px);
  }

  .logo-sub {
    font-family: var(--sg57-font-display);
    font-weight: 300;
    font-size: 1.125rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--sg57-text-dim);
    margin-left: 0.75rem;
    transform: translateY(1px);
  }

  /* -- Desktop links -- */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }

  .nav-links a {
    font-family: var(--sg57-font-display);
    font-weight: 500;
    font-size: 1.125rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sg57-text-dim);
    text-decoration: none;
    transition: color 0.2s ease;
    transform: translateY(1px);
  }

  .nav-links a:hover {
    color: var(--sg57-accent);
  }

  .nav-links a.is-active {
    color: var(--sg57-accent);
    position: relative;
  }

  .nav-links a.is-active::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--sg57-accent);
    border-radius: 1px;
    opacity: 0.7;
  }

  .nav-links a:active {
    opacity: 0.75;
  }

  .nav-links a:focus-visible {
    box-shadow: var(--sg57-focus-ring);
    border-radius: var(--sg57-radius-sm);
  }

  /* Group separator before Services */
  .nav-links a:last-child {
    position: relative;
  }

  .nav-links a:last-child::before {
    content: '';
    position: absolute;
    left: calc(-1.75rem / 2);
    top: 50%;
    transform: translateY(-50%);
    width: 1px;
    height: 1rem;
    background: rgba(255, 255, 255, 0.14);
    border-radius: 1px;
  }

  /* -- Hamburger (hidden on desktop) -- */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }

  .ham-bar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--sg57-text-dim);
    border-radius: 1px;
    transition: transform 0.3s var(--sg57-ease-snap), opacity 0.2s ease;
    transform-origin: center;
  }

  .hamburger:focus-visible {
    box-shadow: var(--sg57-focus-ring);
    border-radius: var(--sg57-radius-sm);
  }

  .hamburger.is-open .ham-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .hamburger.is-open .ham-bar:nth-child(2) {
    opacity: 0;
  }
  .hamburger.is-open .ham-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* -- Mobile menu panel (hidden on desktop) -- */
  .mobile-menu {
    display: none;
    flex-direction: column;
    gap: 0;
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-height 0.35s var(--sg57-ease-snap), opacity 0.25s ease;
    border-top: 1px solid var(--sg57-glass-border);
  }

  .mobile-menu.is-open {
    max-height: 340px;
    opacity: 1;
  }

  .mobile-menu a {
    font-family: var(--sg57-font-display);
    font-weight: 500;
    font-size: 1.125rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sg57-text-dim);
    text-decoration: none;
    padding: 0.85rem 1.5rem;
    border-bottom: 1px solid var(--sg57-border-subtle);
    transition: color 0.2s ease, background 0.2s ease;
    min-height: 44px;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .mobile-menu a.is-active {
    color: var(--sg57-accent);
    border-left: 2px solid var(--sg57-accent);
  }

  .mobile-menu a:hover {
    color: var(--sg57-accent);
    background: var(--sg57-accent-glow);
  }

  .mobile-menu a:active {
    opacity: 0.75;
  }

  .mobile-menu a:focus-visible {
    box-shadow: inset var(--sg57-focus-ring);
    outline: none;
  }

  /* -- Responsive -- */
  @media (max-width: 640px) {
    .logo-sub {
      display: none;
    }

    .nav-links {
      display: none;
    }

    .hamburger {
      display: flex;
    }

    .mobile-menu {
      display: flex;
    }
  }
</style>
