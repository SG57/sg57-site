---
---

<nav class="nav">
  <div class="nav-inner container">
    <a href="/" class="nav-logo" aria-label="SG57 Labs home">
      <span class="bracket">[</span>
      <span class="logo-text">SG57</span>
      <span class="bracket">]</span>
      <span class="logo-sub">LABS</span>
    </a>
    <div class="nav-links">
      <a href="/clide">Clide</a>
      <a href="/siftr">Siftr</a>
      <a href="/services">Services</a>
      <button
        class="theme-toggle"
        id="theme-toggle"
        aria-label="Toggle light/dark theme"
        title="Toggle theme"
      >
        <span class="theme-icon theme-icon--dark" aria-hidden="true">☀</span>
        <span class="theme-icon theme-icon--light" aria-hidden="true">☾</span>
      </button>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--sg57-glass-bg);
    backdrop-filter: blur(var(--sg57-glass-blur));
    -webkit-backdrop-filter: blur(var(--sg57-glass-blur));
    border-bottom: 1px solid var(--sg57-glass-border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 3.5rem;
  }

  .nav-logo {
    display: flex;
    align-items: baseline;
    gap: 0.15rem;
    color: var(--sg57-text);
    text-decoration: none;
  }

  .nav-logo:hover {
    color: var(--sg57-text);
  }

  .bracket {
    font-family: var(--sg57-font-display);
    font-weight: 300;
    font-size: 1.25rem;
    opacity: 0.6;
  }

  .logo-text {
    font-family: var(--sg57-font-display);
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: 0.15em;
  }

  .logo-sub {
    font-family: var(--sg57-font-display);
    font-weight: 300;
    font-size: 0.7rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--sg57-text-dim);
    margin-left: 0.75rem;
  }

  .nav-links {
    display: flex;
    gap: 1.75rem;
  }

  .nav-links a {
    font-family: var(--sg57-font-display);
    font-weight: 500;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sg57-text-dim);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .nav-links a:hover {
    color: var(--sg57-accent);
  }

  /* Theme toggle */
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    min-width: 44px;
    min-height: 44px;
    background: transparent;
    border: 1px solid var(--sg57-border-subtle);
    border-radius: var(--sg57-radius-sm);
    cursor: pointer;
    transition: border-color 0.2s ease, background 0.2s ease;
    margin-left: 0.5rem;
    padding: 0;
  }

  .theme-toggle:hover {
    border-color: var(--sg57-accent-muted);
    background: var(--sg57-accent-glow);
  }

  .theme-icon {
    font-size: 1rem;
    line-height: 1;
  }

  /* Dark mode: show sun icon (to switch to light) */
  .theme-icon--light { display: none; }
  .theme-icon--dark  { display: inline; }

  :global([data-theme='light']) .theme-icon--dark  { display: none; }
  :global([data-theme='light']) .theme-icon--light { display: inline; }

  @media (max-width: 640px) {
    .logo-sub {
      display: none;
    }

    .nav-links {
      gap: 1rem;
    }

    .nav-links a {
      font-size: 0.8rem;
    }
  }
</style>
