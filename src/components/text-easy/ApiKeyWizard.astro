---
// API Key Setup Wizard — 5 guided steps + celebration finale
// Self-contained Astro component, vanilla JS state machine.
// Steps reconstructed from actual aistudio.google.com screenshots.
---

<div class="akw-wrapper" id="akw">

  <!-- ── SCREENSHOT PANEL (frosted-glass sidebar, desktop / bottom strip, mobile) ── -->
  <div class="akw-shots-panel" id="akw-screenshots"></div>

  <!-- ── WIZARD BODY ── -->
  <div class="akw-body" id="akw-body">

    <!-- Header row -->
    <div class="akw-header">
      <div class="akw-badge">
        <span class="akw-badge-glyph">◆</span>
        SETUP GUIDE
      </div>
      <div class="akw-counter" aria-live="polite">
        <span id="akw-current">01</span>
        <span class="akw-counter-sep">/</span>
        <span>05</span>
      </div>
    </div>

    <!-- Progress track -->
    <div
      class="akw-track"
      role="progressbar"
      aria-valuemin="1"
      aria-valuemax="5"
      aria-valuenow="1"
      aria-label="Setup progress"
    >
      <div class="akw-fill" id="akw-fill"></div>
    </div>

    <!-- Slide: content area (screenshots live in the external panel) -->
    <div class="akw-slide" id="akw-slide" aria-live="polite" aria-atomic="true">
      <div class="akw-slide-content">
        <div class="akw-step-top">
          <div class="akw-step-icon" id="akw-step-icon" aria-hidden="true"></div>
          <div class="akw-step-meta">
            <div class="akw-step-number" id="akw-step-number" aria-hidden="true"></div>
            <h2 class="akw-heading" id="akw-heading" tabindex="-1"></h2>
          </div>
        </div>
        <div class="akw-instructions" id="akw-instructions"></div>
        <div class="akw-action" id="akw-action"></div>
      </div>
    </div>

    <!-- Navigation -->
    <div class="akw-nav">
      <button class="akw-btn akw-btn-back" id="akw-back" disabled title="No previous step">
        <span aria-hidden="true">&larr;</span> Back
      </button>
      <button class="akw-btn akw-btn-next" id="akw-next" title="Continue to next step">
        I've done this <span aria-hidden="true">&rarr;</span>
      </button>
    </div>

  </div><!-- /akw-body -->

  <!-- ── CONNECTING PHASE ── -->
  <div class="akw-connecting hidden" id="akw-connecting" aria-live="assertive" aria-label="Completing setup">
    <div class="akw-conn-glyph" aria-hidden="true">◈</div>
    <p class="akw-conn-text">Almost there&hellip;</p>
    <div class="akw-conn-track">
      <div class="akw-conn-bar" id="akw-conn-bar"></div>
    </div>
  </div>

  <!-- ── DONE PHASE ── -->
  <div class="akw-done hidden" id="akw-done" aria-live="polite">
    <div class="akw-done-inner">
      <div class="akw-done-icon" data-stagger="0" aria-hidden="true">
        <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="24" cy="24" r="20" opacity="0.3"/>
          <path d="M15 25l6 6 12-12" stroke-width="2.5"/>
        </svg>
      </div>
      <div class="akw-done-signal" data-stagger="1">YOU'RE ALL SET</div>
      <h2  class="akw-done-headline" data-stagger="2">Text Easy is connected to Google&rsquo;s AI</h2>
      <p   class="akw-done-desc" data-stagger="3">
        Switch back to Text Easy and tap <strong>Guide</strong> in the
        bottom nav &mdash; it&rsquo;ll walk you through everything else.
      </p>
      <button class="akw-retake" id="akw-retake" data-stagger="4">
        Start over <span aria-hidden="true">&rarr;</span>
      </button>
    </div>
  </div>

</div><!-- /akw-wrapper -->

<script>
  // ── SVG ICONS (inline, no external deps) ────────────────────────────────────

  const ICONS = {
    globe: '<svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="20" cy="20" r="16"/><ellipse cx="20" cy="20" rx="8" ry="16"/><line x1="4" y1="20" x2="36" y2="20"/><path d="M6.5 12h27M6.5 28h27"/></svg>',
    plus: '<svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="20" cy="20" r="16" opacity="0.3"/><line x1="20" y1="12" x2="20" y2="28"/><line x1="12" y1="20" x2="28" y2="20"/></svg>',
    gear: '<svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="20" cy="20" r="5"/><path d="M20 4v4M20 32v4M36 20h-4M8 20H4M31.3 8.7l-2.8 2.8M11.5 28.5l-2.8 2.8M31.3 31.3l-2.8-2.8M11.5 11.5L8.7 8.7"/></svg>',
    copy: '<svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="12" y="12" width="20" height="22" rx="3"/><path d="M8 28V10a3 3 0 013-3h14"/></svg>',
    phone: '<svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="11" y="4" width="18" height="32" rx="4"/><line x1="17" y1="32" x2="23" y2="32"/><circle cx="20" cy="8" r="1" fill="currentColor" stroke="none"/></svg>',
  };

  // ── DATA ────────────────────────────────────────────────────────────────────

  const STEPS = [
    {
      number: '01',
      heading: 'Open Google AI Studio & Accept Terms',
      icon: 'globe',
      instructions: [
        'Tap the green button to open Google AI Studio:',
        { type: 'action', label: 'Open Google AI Studio', url: 'https://aistudio.google.com/apikey', hint: 'Opens in a new tab \u2014 come back here when you\u2019re done.' },
        'A <strong>Terms of Service</strong> screen will appear.',
        'Check the <strong>&ldquo;I acknowledge&rdquo;</strong> checkbox.',
        'Tap <strong>&ldquo;Continue&rdquo;</strong>.',
      ],
      screenshots: ['/text-easy/setup/step-1-terms.png'],
      screenshotAlts: ['Google AI Studio Terms of Service screen with agreement checkbox'],
      action: null,
      nextLabel: 'I accepted the terms \u2192',
    },
    {
      number: '02',
      heading: 'Tap "Create API Key"',
      icon: 'plus',
      instructions: [
        'You\u2019ll see the <strong>API Keys</strong> page.',
        'Tap the <strong>&ldquo;Create API key&rdquo;</strong> button in the top right corner.',
      ],
      screenshots: ['/text-easy/setup/step-2-api-keys.png'],
      screenshotAlts: ['API Keys page showing the Create API key button'],
      action: null,
      nextLabel: 'I tapped Create API key \u2192',
    },
    {
      number: '03',
      heading: 'Name Your Key & Create a Project',
      icon: 'gear',
      instructions: [
        'A <strong>&ldquo;Create a new key&rdquo;</strong> dialog will appear.',
        'The default key name is fine \u2014 you don\u2019t need to change it.',
        'If it asks you to create a project, give it any name (like <strong>&ldquo;Gemini Project&rdquo;</strong>) and tap <strong>&ldquo;Create project&rdquo;</strong>.',
        'Then tap <strong>&ldquo;Create key&rdquo;</strong>.',
      ],
      screenshots: [
        '/text-easy/setup/step-3a-name-key.png',
        '/text-easy/setup/step-3b-create-project.png',
      ],
      screenshotAlts: [
        'Create a new key dialog with name field and project dropdown',
        'Create a new project dialog with name field',
      ],
      action: null,
      nextLabel: 'I created my key \u2192',
    },
    {
      number: '04',
      heading: 'Copy Your Key',
      icon: 'copy',
      instructions: [
        'Your new API key will appear \u2014 it starts with <code class="akw-code">AIza...</code>',
        'Tap the <strong>&ldquo;Copy key&rdquo;</strong> button at the bottom of the dialog.',
        'Your key is now on your clipboard \u2014 ready to paste.',
      ],
      screenshots: ['/text-easy/setup/step-4-copy-key.png'],
      screenshotAlts: ['API key details dialog showing the key and Copy key button'],
      action: null,
      nextLabel: 'I\u2019ve copied it \u2192',
    },
    {
      number: '05',
      heading: 'Paste It in Text Easy',
      icon: 'phone',
      instructions: [
        'Switch back to <strong>Text Easy</strong> on your phone.',
        'Tap <strong>&ldquo;API Key&rdquo;</strong> in Settings.',
        'Tap the <strong>&ldquo;Change&rdquo;</strong> link next to the API key field.',
        'Long-press the text field and tap <strong>&ldquo;Paste&rdquo;</strong>.',
        'Tap <strong>&ldquo;Save&rdquo;</strong>.',
      ],
      screenshots: [
        '/text-easy/setup/step-5a-app-empty.png',
      ],
      screenshotAlts: [
        'Text Easy API Key settings page',
      ],
      action: null,
      nextLabel: 'Done! \u2192',
    },
  ];

  const TOTAL = STEPS.length;

  // ── INIT ────────────────────────────────────────────────────────────────────

  document.addEventListener('astro:page-load', () => {
  try {
  const akw = document.getElementById('akw');
  if (!akw) return;

  let current   = 0;
  let animating = false;

  const body         = document.getElementById('akw-body');
  const slide        = document.getElementById('akw-slide');
  const stepIconEl   = document.getElementById('akw-step-icon');
  const stepNumEl    = document.getElementById('akw-step-number');
  const headingEl    = document.getElementById('akw-heading');
  const instrEl      = document.getElementById('akw-instructions');
  const screenshotEl = document.getElementById('akw-screenshots');
  const actionEl     = document.getElementById('akw-action');
  const fill         = document.getElementById('akw-fill');
  const currentEl    = document.getElementById('akw-current');
  const backBtn      = document.getElementById('akw-back');
  const nextBtn      = document.getElementById('akw-next');
  const connPhase    = document.getElementById('akw-connecting');
  const connBar      = document.getElementById('akw-conn-bar');
  const doneEl       = document.getElementById('akw-done');
  const retakeBtn    = document.getElementById('akw-retake');
  const trackEl      = akw.querySelector('.akw-track');

  if (!body || !slide || !stepIconEl || !stepNumEl || !headingEl || !instrEl ||
      !screenshotEl || !actionEl || !fill || !currentEl || !backBtn || !nextBtn ||
      !connPhase || !connBar || !doneEl || !retakeBtn) return;

  function wait(ms) {
    return new Promise(r => setTimeout(r, ms));
  }

  function scrollToWizard() {
    akw.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function renderStep(idx) {
    const step = STEPS[idx];

    // Icon
    stepIconEl.innerHTML = ICONS[step.icon] || '';

    // Number + heading
    stepNumEl.textContent = step.number;
    headingEl.textContent = step.heading;

    // Instructions (supports strings and inline {type:'action'} objects)
    instrEl.innerHTML = '';
    const ul = document.createElement('ul');
    ul.className = 'akw-list';
    step.instructions.forEach(item => {
      if (typeof item === 'object' && item.type === 'action') {
        // Inline action button — rendered as a centered block within the list
        const wrapper = document.createElement('li');
        wrapper.className = 'akw-inline-action';
        const a = document.createElement('a');
        a.className = 'akw-action-btn';
        a.href = item.url;
        a.target = '_blank';
        a.rel = 'noopener noreferrer';
        a.innerHTML = item.label + ' <span class="akw-link-arrow" aria-hidden="true">&nearr;</span>';
        wrapper.appendChild(a);
        if (item.hint) {
          const hint = document.createElement('span');
          hint.className = 'akw-inline-hint';
          hint.textContent = item.hint;
          wrapper.appendChild(hint);
        }
        ul.appendChild(wrapper);
      } else {
        const li = document.createElement('li');
        li.innerHTML = item;
        ul.appendChild(li);
      }
    });
    instrEl.appendChild(ul);

    // Screenshots — populate left column
    screenshotEl.innerHTML = '';
    if (step.screenshots && step.screenshots.length > 0) {
      step.screenshots.forEach((src, i) => {
        const figure = document.createElement('figure');
        figure.className = 'akw-img-frame';
        const img = document.createElement('img');
        img.src = src;
        img.alt = step.screenshotAlts[i] || '';
        img.loading = 'lazy';
        img.decoding = 'async';
        figure.appendChild(img);
        screenshotEl.appendChild(figure);
      });
    }

    // Action area (clear — inline actions are now embedded in instructions)
    actionEl.innerHTML = '';

    // Counter + progress
    currentEl.textContent = step.number;
    const pct = ((idx + 1) / TOTAL) * 100;
    fill.style.width = pct + '%';
    if (trackEl) {
      trackEl.setAttribute('aria-valuenow', String(idx + 1));
    }

    // Next button label
    nextBtn.innerHTML = step.nextLabel;
  }

  function updateNav() {
    backBtn.disabled = current === 0 || animating;
    nextBtn.disabled = animating;
    backBtn.title = current === 0 ? 'No previous step' : 'Go back';
  }

  async function goToStep(target, direction) {
    if (animating || target === current || target < 0 || target >= TOTAL) return;
    animating = true;
    updateNav();

    const exitClass = direction === 'forward' ? 'exiting-left' : 'exiting-right';
    slide.classList.add(exitClass);
    await wait(280);

    current = target;
    renderStep(current);
    slide.classList.remove(exitClass);
    const enterClass = direction === 'forward' ? 'entering-right' : 'entering-left';
    slide.classList.add(enterClass);

    void slide.offsetWidth;
    slide.classList.remove(enterClass);

    // Scroll both content and shots panel to top on step change
    slide.scrollTop = 0;
    screenshotEl.scrollTop = 0;
    scrollToWizard();

    await wait(320);
    animating = false;
    updateNav();
    headingEl.focus();
  }

  async function showDone() {
    animating = true;
    nextBtn.disabled = true;
    backBtn.disabled = true;

    scrollToWizard();

    body.classList.add('phase-out');
    await wait(350);
    body.classList.add('hidden');
    body.classList.remove('phase-out');

    connPhase.classList.remove('hidden');
    connPhase.classList.add('phase-in');
    connBar.style.transition = 'none';
    connBar.style.width = '0%';
    void connBar.offsetWidth;
    connBar.style.transition = 'width 0.9s cubic-bezier(0.4, 0, 0.2, 1)';
    connBar.style.width = '100%';
    await wait(1100);

    connPhase.classList.add('phase-out');
    await wait(300);
    connPhase.classList.add('hidden');
    connPhase.classList.remove('phase-in', 'phase-out');

    doneEl.classList.remove('hidden');
    doneEl.classList.add('phase-in');
    const staggerEls = doneEl.querySelectorAll('[data-stagger]');
    staggerEls.forEach(el => {
      el.style.opacity   = '0';
      el.style.transform = 'translateY(14px)';
    });
    await wait(80);

    for (const el of staggerEls) {
      el.style.transition = 'opacity 0.45s ease, transform 0.45s cubic-bezier(0.22, 1, 0.36, 1)';
      el.style.opacity    = '1';
      el.style.transform  = 'translateY(0)';
      await wait(140);
    }

    animating = false;
  }

  function resetWizard() {
    current = 0;
    animating = false;

    doneEl.classList.add('hidden');
    doneEl.classList.remove('phase-in');
    doneEl.querySelectorAll('[data-stagger]').forEach(el => {
      el.style.opacity    = '';
      el.style.transform  = '';
      el.style.transition = '';
    });

    renderStep(0);
    body.classList.remove('hidden');
    updateNav();
    scrollToWizard();
    requestAnimationFrame(() => headingEl.focus());
  }

  backBtn.addEventListener('click', () => {
    if (current > 0) goToStep(current - 1, 'back');
  });

  nextBtn.addEventListener('click', () => {
    if (current < TOTAL - 1) {
      goToStep(current + 1, 'forward');
    } else {
      showDone();
    }
  });

  retakeBtn.addEventListener('click', resetWizard);

  document.addEventListener('keydown', e => {
    if (!akw.contains(e.target)) return;
    if (e.key === 'Enter' && !animating) {
      e.preventDefault();
      if (doneEl.classList.contains('hidden') === false) return;
      if (current < TOTAL - 1) {
        goToStep(current + 1, 'forward');
      } else {
        showDone();
      }
    }
  });

  renderStep(0);
  updateNav();

  } catch (_) { /* Wizard init failed — page remains functional */ }
  });
</script>

<style>
  /* ── WRAPPER (flex row on desktop, column on mobile) ── */
  .akw-wrapper {
    display: flex;
    background: var(--sg57-glass-bg);
    backdrop-filter: blur(var(--sg57-glass-blur));
    -webkit-backdrop-filter: blur(var(--sg57-glass-blur));
    border: 1px solid var(--sg57-glass-border);
    box-shadow: var(--sg57-glass-shadow);
    border-radius: var(--sg57-radius-md);
    overflow: hidden;
    width: 100%;
    max-width: 1040px;
    max-height: 80vh;
    margin: 0 auto;
  }

  /* ── SCREENSHOT PANEL (bolted-on frosted-glass sidebar) ── */
  .akw-shots-panel {
    flex: 0 0 38%;
    max-width: 380px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1.25rem 1rem;
    overflow-y: auto;
    overflow-x: hidden;
    -webkit-overflow-scrolling: touch;
    background: rgba(0, 0, 0, 0.2);
    border-right: 1px solid var(--sg57-border);
    /* Subtle scrollbar */
    scrollbar-width: thin;
    scrollbar-color: transparent transparent;
  }

  .akw-shots-panel:hover {
    scrollbar-color: var(--sg57-scrollbar-thumb) transparent;
  }

  .akw-shots-panel::-webkit-scrollbar { width: 4px; background: transparent; }
  .akw-shots-panel::-webkit-scrollbar-track { background: transparent; }
  .akw-shots-panel::-webkit-scrollbar-thumb { background: transparent; border-radius: 4px; }
  .akw-shots-panel:hover::-webkit-scrollbar-thumb { background: var(--sg57-scrollbar-thumb); }

  .akw-shots-panel:empty {
    display: none;
  }

  .akw-shots-panel :global(.akw-img-frame) {
    margin: 0;
    border-radius: var(--sg57-radius-md);
    overflow: hidden;
    border: none;
    box-shadow:
      0 2px 8px rgba(0, 0, 0, 0.4),
      0 8px 24px rgba(0, 0, 0, 0.3);
    background: var(--sg57-void);
    flex-shrink: 0;
  }

  .akw-shots-panel :global(.akw-img-frame img) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--sg57-radius-md);
  }

  /* ── HEADER ── */
  .akw-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 2rem 0;
    flex-shrink: 0;
  }

  .akw-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 1.125rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sg57-accent);
  }

  .akw-badge-glyph {
    font-size: 1.125rem;
    animation: pulse-glow 4s ease-in-out infinite;
  }

  .akw-counter {
    font-family: var(--sg57-font-mono);
    font-size: 1.125rem;
    color: var(--sg57-text-dim);
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  #akw-current {
    color: var(--sg57-accent);
    font-weight: 600;
  }

  .akw-counter-sep {
    opacity: 0.4;
  }

  /* ── PROGRESS TRACK ── */
  .akw-track {
    margin: 1.25rem 2rem 0;
    height: 2px;
    background: var(--sg57-border);
    border-radius: 2px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .akw-fill {
    height: 100%;
    width: 20%;
    background: var(--sg57-accent);
    border-radius: 2px;
    transition: width 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    box-shadow: 0 0 8px var(--sg57-accent-glow);
  }

  /* ── BODY — flex child of wrapper, fills remaining width ── */
  .akw-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
    min-height: 0;
  }

  /* ── SLIDE (scrollable content area) ── */
  .akw-slide {
    display: flex;
    flex-direction: column;
    padding: 1rem 2rem 0;
    flex: 1 1 0%;
    min-height: 0;
    overflow-y: auto;
    overflow-x: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.28s ease;
  }

  .akw-slide::-webkit-scrollbar { display: none; }

  .akw-slide.exiting-left  { transform: translateX(-40px); opacity: 0; }
  .akw-slide.exiting-right { transform: translateX(40px);  opacity: 0; }
  .akw-slide.entering-right { transform: translateX(40px); opacity: 0; transition: none; }
  .akw-slide.entering-left  { transform: translateX(-40px); opacity: 0; transition: none; }

  /* ── STEP TOP (icon + number + heading) ── */
  .akw-step-top {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .akw-step-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    color: var(--sg57-accent);
    opacity: 0.7;
  }

  .akw-step-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .akw-step-meta {
    flex: 1;
    min-width: 0;
  }

  .akw-step-number {
    font-family: var(--sg57-font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--sg57-accent);
    opacity: 0.5;
    letter-spacing: 0.1em;
    margin-bottom: 0.15rem;
  }

  .akw-heading {
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: clamp(1.2rem, 2.5vw, 1.35rem);
    color: var(--sg57-text-bright);
    line-height: 1.3;
    letter-spacing: 0.02em;
    outline: none;
  }

  /* ── INSTRUCTIONS ── */
  .akw-instructions :global(.akw-list) {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .akw-instructions :global(.akw-list li) {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: 1.125rem;
    color: var(--sg57-text);
    line-height: 1.65;
    padding-left: 1.25rem;
    position: relative;
  }

  .akw-instructions :global(.akw-list li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--sg57-accent-muted);
    opacity: 0.6;
  }

