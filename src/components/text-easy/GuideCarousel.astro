---
/**
 * GuideCarousel — Swipeable screenshot showcase in phone frames.
 * CSS scroll-snap for native touch swipe; JS for arrow/keyboard/dot nav.
 */

interface Slide {
  src: string;
  alt: string;
  title: string;
  desc: string;
}

const slides: Slide[] = [
  {
    src: '/text-easy/screenshots/guide-intents.webp',
    alt: 'Intent picker showing 3 inferred intents from an incoming message',
    title: 'Pick Your Intent',
    desc: 'AI reads the message and infers 3 likely response intents. You recognize — you don\'t compose.',
  },
  {
    src: '/text-easy/screenshots/guide-replies.webp',
    alt: 'Reply picker showing 3 generated reply options',
    title: 'Choose a Reply',
    desc: '3 reply options written in your voice. Tap one to copy, paste it back. Done.',
  },
  {
    src: '/text-easy/screenshots/guide-refinements.webp',
    alt: 'Refinement panel with tone and style controls',
    title: 'Refine Your Reply',
    desc: 'Adjust tone, length, and style with one tap. Create your own custom refinements.',
  },
  {
    src: '/text-easy/screenshots/guide-compose.webp',
    alt: 'Compose mode for writing messages from scratch',
    title: 'Compose from Scratch',
    desc: 'No incoming message? Write anything — birthday wishes, emails, awkward asks.',
  },
  {
    src: '/text-easy/screenshots/guide-qs-panel.webp',
    alt: 'Quick Settings panel with Text Easy tile',
    title: 'Quick Settings Tile',
    desc: 'Trigger from anywhere with one swipe and one tap. Works in every app.',
  },
];
---

<div class="guide-carousel" role="region" aria-label="App screenshots" aria-roledescription="carousel">
  <!-- Side arrows -->
  <button class="carousel-side-arrow carousel-side-arrow--left carousel-prev-side" aria-label="Previous screenshot">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M15 18l-6-6 6-6"/>
    </svg>
  </button>
  <button class="carousel-side-arrow carousel-side-arrow--right carousel-next-side" aria-label="Next screenshot">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M9 18l6-6-6-6"/>
    </svg>
  </button>

  <div class="carousel-track" tabindex="0">
    {slides.map((slide, i) => (
      <div class="carousel-slide" role="group" aria-roledescription="slide" aria-label={`${i + 1} of ${slides.length}: ${slide.title}`}>
        <div class="phone-frame">
          <img
            src={slide.src}
            alt={slide.alt}
            width="1080"
            height="2160"
            loading={i === 0 ? 'eager' : 'lazy'}
            decoding="async"
          />
        </div>
        <h3 class="slide-title">{slide.title}</h3>
        <p class="slide-desc">{slide.desc}</p>
      </div>
    ))}
  </div>

  <div class="carousel-controls">
    <button class="carousel-btn carousel-prev" aria-label="Previous screenshot" disabled>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M15 18l-6-6 6-6"/>
      </svg>
    </button>

    <div class="carousel-dots" role="tablist" aria-label="Screenshot navigation">
      {slides.map((slide, i) => (
        <button
          class={`carousel-dot${i === 0 ? ' active' : ''}`}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          aria-label={slide.title}
          data-index={i}
        />
      ))}
    </div>

    <button class="carousel-btn carousel-next" aria-label="Next screenshot">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 18l6-6-6-6"/>
      </svg>
    </button>
  </div>
</div>

<style>
  .guide-carousel {
    width: 100%;
    max-width: 100%;
    overflow: hidden;
    position: relative;
  }

  /* ── Scroll-snap track ── */
  .carousel-track {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    /* Mobile: center a single slide with generous padding */
    padding: 0 calc(50% - 130px);
    outline: none;
    cursor: grab;
  }

  .carousel-track.is-dragging {
    scroll-behavior: auto;
    scroll-snap-type: none;
    cursor: grabbing;
    user-select: none;
  }
  .carousel-track::-webkit-scrollbar { display: none; }

  @media (prefers-reduced-motion: reduce) {
    .carousel-track { scroll-behavior: auto; }
  }

  /* ── Slide ── */
  .carousel-slide {
    /* Mobile: single slide fills most of the viewport */
    flex: 0 0 260px;
    scroll-snap-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  /* ── Phone frame ── */
  .phone-frame {
    width: 100%;
    aspect-ratio: 9 / 18;
    border-radius: 1.5rem;
    border: 1px solid var(--sg57-border);
    background: var(--sg57-surface);
    overflow: hidden;
    box-shadow:
      0 0 20px rgba(0, 255, 136, 0.06),
      0 8px 32px rgba(0, 0, 0, 0.4);
    transition: box-shadow var(--sg57-duration-200, 200ms) ease;
  }

  .phone-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .slide-title {
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: var(--sg57-font-xl);
    color: var(--sg57-text-bright);
    margin: 1rem 0 0.25rem;
    letter-spacing: 0.04em;
  }

  .slide-desc {
    font-family: var(--sg57-font-display);
    font-size: var(--sg57-font-sm);
    color: var(--sg57-text-muted);
    line-height: 1.5;
    max-width: 280px;
  }

  /* ── Controls ── */
  .carousel-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .carousel-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--sg57-border);
    background: var(--sg57-surface);
    color: var(--sg57-text);
    cursor: pointer;
    transition: all var(--sg57-duration-150, 150ms) ease;
  }
  .carousel-btn:hover:not(:disabled) {
    border-color: var(--sg57-accent);
    color: var(--sg57-accent);
    box-shadow: 0 0 12px var(--sg57-accent-glow);
  }
  .carousel-btn:disabled {
    opacity: 0.25;
    cursor: default;
  }
  .carousel-btn svg {
    width: 18px;
    height: 18px;
  }

  /* ── Dots ── */
  .carousel-dots {
    display: flex;
    gap: 0.5rem;
  }

  .carousel-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: var(--sg57-raised);
    cursor: pointer;
    padding: 0;
    transition: all var(--sg57-duration-150, 150ms) ease;
  }
  .carousel-dot.active {
    background: var(--sg57-accent);
    box-shadow: 0 0 8px var(--sg57-accent-glow);
    transform: scale(1.3);
  }
  .carousel-dot:hover:not(.active) {
    background: var(--sg57-text-dim);
  }

  /* ── Responsive ── */
  @media (min-width: 640px) {
    .carousel-slide { flex: 0 0 320px; }
    .carousel-track { padding: 0 calc(50% - 180px); gap: 2rem; }
    .slide-desc { max-width: 320px; }
  }

  @media (min-width: 1024px) {
    .carousel-slide { flex: 0 0 340px; }
    .carousel-track { padding: 0 calc(50% - 190px); gap: 2.5rem; }
    .phone-frame {
      border-radius: 2rem;
    }
  }

  /* ── Side arrows — hover-reveal ── */
  .carousel-side-arrow {
    position: absolute;
    top: 40%;
    transform: translateY(-50%);
    z-index: 3;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--sg57-border);
    background: rgba(var(--sg57-surface-rgb, 18, 18, 18), 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: var(--sg57-text-muted);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    opacity: 0;
    transition: opacity 0.25s ease, color var(--sg57-duration-150, 150ms) ease,
                border-color var(--sg57-duration-150, 150ms) ease,
                box-shadow var(--sg57-duration-150, 150ms) ease,
                transform var(--sg57-duration-150, 150ms) ease;
  }

  .guide-carousel:hover .carousel-side-arrow {
    opacity: 1;
  }

  .carousel-side-arrow--left { left: 0.5rem; }
  .carousel-side-arrow--right { right: 0.5rem; }

  .carousel-side-arrow svg {
    width: 18px;
    height: 18px;
  }

  .carousel-side-arrow:hover {
    border-color: var(--sg57-accent);
    color: var(--sg57-accent);
    box-shadow: 0 0 12px var(--sg57-accent-glow);
    transform: translateY(-50%) scale(1.08);
  }

  .carousel-side-arrow:active {
    transform: translateY(-50%) scale(0.95);
  }

  /* Hide side arrows on mobile/portrait */
  @media (max-width: 639px), (hover: none) and (orientation: portrait) {
    .carousel-side-arrow { display: none; }
  }
</style>

<script>
  function initCarousel() {
    const carousel = document.querySelector('.guide-carousel');
    if (!carousel) return;

    const track = carousel.querySelector('.carousel-track') as HTMLElement;
    const slides = carousel.querySelectorAll('.carousel-slide');
    const dots = carousel.querySelectorAll('.carousel-dot');
    const prevBtn = carousel.querySelector('.carousel-prev') as HTMLButtonElement;
    const nextBtn = carousel.querySelector('.carousel-next') as HTMLButtonElement;
    const prevSide = carousel.querySelector('.carousel-prev-side') as HTMLButtonElement;
    const nextSide = carousel.querySelector('.carousel-next-side') as HTMLButtonElement;

    let current = 0;
    const total = slides.length;

    function scrollToSlide(index: number) {
      const target = slides[index] as HTMLElement;
      const trackRect = track.getBoundingClientRect();
      const slideRect = target.getBoundingClientRect();
      const offset = slideRect.left - trackRect.left + track.scrollLeft
        - (trackRect.width / 2) + (slideRect.width / 2);
      track.scrollTo({ left: offset });
    }

    function updateState(index: number) {
      current = index;
      prevBtn.disabled = current === 0;
      nextBtn.disabled = current === total - 1;
      dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === current);
        dot.setAttribute('aria-selected', i === current ? 'true' : 'false');
      });
    }

    // Detect active slide from scroll position
    function onScroll() {
      const trackRect = track.getBoundingClientRect();
      const center = trackRect.left + trackRect.width / 2;
      let closest = 0;
      let minDist = Infinity;
      slides.forEach((slide, i) => {
        const rect = slide.getBoundingClientRect();
        const dist = Math.abs(rect.left + rect.width / 2 - center);
        if (dist < minDist) { minDist = dist; closest = i; }
      });
      if (closest !== current) updateState(closest);
    }

    let scrollTimer: ReturnType<typeof setTimeout>;
    track.addEventListener('scroll', () => {
      clearTimeout(scrollTimer);
      scrollTimer = setTimeout(onScroll, 60);
    }, { passive: true });

    prevBtn.addEventListener('click', () => {
      if (current > 0) { scrollToSlide(current - 1); updateState(current - 1); }
    });
    nextBtn.addEventListener('click', () => {
      if (current < total - 1) { scrollToSlide(current + 1); updateState(current + 1); }
    });
    prevSide?.addEventListener('click', () => {
      if (current > 0) { scrollToSlide(current - 1); updateState(current - 1); }
    });
    nextSide?.addEventListener('click', () => {
      if (current < total - 1) { scrollToSlide(current + 1); updateState(current + 1); }
    });

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => { scrollToSlide(i); updateState(i); });
    });

    // On wider screens (3 slides visible), start focused on slide 2 (index 1)
    // so the user sees slides 1-2-3 on load. On mobile, start at slide 0.
    const isDesktop = window.matchMedia('(min-width: 640px)').matches;
    const initialSlide = isDesktop ? 1 : 0;

    // Use requestAnimationFrame to ensure layout is complete before scrolling
    requestAnimationFrame(() => {
      // Disable smooth scroll for the initial positioning
      track.style.scrollBehavior = 'auto';
      scrollToSlide(initialSlide);
      updateState(initialSlide);
      // Re-enable smooth scroll after a tick
      requestAnimationFrame(() => {
        track.style.scrollBehavior = '';
      });
    });

    // Keyboard nav when track is focused
    track.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'ArrowLeft' && current > 0) {
        e.preventDefault(); scrollToSlide(current - 1); updateState(current - 1);
      } else if (e.key === 'ArrowRight' && current < total - 1) {
        e.preventDefault(); scrollToSlide(current + 1); updateState(current + 1);
      }
    });

    // Click-to-drag support
    let isDragging = false;
    let startX = 0;
    let scrollStart = 0;

    track.addEventListener('mousedown', (e: MouseEvent) => {
      isDragging = true;
      startX = e.pageX;
      scrollStart = track.scrollLeft;
      track.classList.add('is-dragging');
    });

    window.addEventListener('mousemove', (e: MouseEvent) => {
      if (!isDragging) return;
      track.scrollLeft = scrollStart - (e.pageX - startX);
    });

    window.addEventListener('mouseup', () => {
      if (!isDragging) return;
      isDragging = false;
      track.classList.remove('is-dragging');
      requestAnimationFrame(() => {
        track.style.scrollSnapType = 'x mandatory';
      });
    });

    track.querySelectorAll('img').forEach(img => {
      img.addEventListener('dragstart', (e) => e.preventDefault());
    });
  }

  // Run on load and on Astro view transitions
  initCarousel();
  document.addEventListener('astro:after-swap', initCarousel);
</script>
