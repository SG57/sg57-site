---
import Base from '../layouts/Base.astro';
---

<Base>

  <!-- ══ HERO ══ -->
  <section class="hero">
    <div class="hero-inner container">

      <!-- Left: brand statement -->
      <div class="hero-text">
        <span class="hero-eyebrow">SG57 LABS · SOFTWARE STUDIO</span>
        <h1 class="hero-headline">
          <span class="hl-dim">SOFTWARE</span>
          <span class="hl-bold">REFINERY.</span>
        </h1>
        <p class="hero-sub">
          Desktop apps. Production web builds. Full-stack contracting.<br>
          Precision-engineered from architecture to deploy.
        </p>
        <div class="hero-ctas">
          <a href="#products" class="btn btn-primary">See Products →</a>
          <a href="mailto:consult@sg57.dev" class="btn btn-ghost">Hire Us →</a>
        </div>
      </div>

      <!-- Right: terminal window (Clide screenshot placeholder) -->
      <div class="hero-visual" aria-hidden="true">
        <div class="terminal-window">
          <div class="terminal-bar">
            <span class="t-dots">
              <span class="t-dot t-dot--red"></span>
              <span class="t-dot t-dot--yellow"></span>
              <span class="t-dot t-dot--green"></span>
            </span>
            <span class="t-title">clide — fleet control</span>
          </div>
          <div class="terminal-body">
            <div class="t-line"><span class="t-prompt">$</span> <span class="t-cmd">agent init --all</span></div>
            <div class="t-line t-ok"><span class="t-icon">✓</span> 8 agents connected</div>
            <div class="t-line t-gap"></div>
            <div class="t-line"><span class="t-prompt">$</span> <span class="t-cmd">fleet status</span></div>
            <div class="t-line t-meta">  CLAUDE-01 <span class="t-active">● writing tests</span></div>
            <div class="t-line t-meta">  CLAUDE-02 <span class="t-active">● refactoring auth</span></div>
            <div class="t-line t-meta">  CLAUDE-03 <span class="t-idle">⏸ idle</span></div>
            <div class="t-line t-meta">  CLAUDE-04 <span class="t-active">● analyzing logs</span></div>
            <div class="t-line t-meta">  CLAUDE-05 <span class="t-active">● code review</span></div>
            <div class="t-line t-gap"></div>
            <div class="t-line"><span class="t-prompt">$</span> <span class="t-cursor">█</span></div>
            <div class="t-todo">// screenshot placeholder — real Clide UI incoming</div>
          </div>
        </div>
      </div>

    </div>

    <!-- Scroll hint -->
    <div class="hero-scroll-hint" aria-hidden="true">
      <span class="scroll-label">scroll</span>
      <span class="scroll-arrow">↓</span>
    </div>
  </section>

  <!-- ══ PRODUCTS ══ -->
  <section class="products" id="products">
    <div class="container">
      <span class="section-eyebrow">Products</span>
      <div class="product-grid">

        <a href="/clide" class="product-card product-card--clide">
          <div class="product-card-bg" style="background-image: url('/clide/clide-hero.jpg');"></div>
          <div class="product-card-scrim product-card-scrim--clide"></div>
          <div class="product-card-content">
            <div class="product-meta">
              <img src="/brand/clide-icon.svg" alt="" class="product-icon" width="28" height="28" />
              <span class="product-label">CLIDE <span class="product-sep">//</span> AI TERMINAL COMMAND CENTER</span>
            </div>
            <p class="product-tagline">Mission Control for your AI terminal sessions.</p>
            <span class="product-cta">Learn More →</span>
          </div>
        </a>

        <a href="/siftr" class="product-card product-card--siftr">
          <div class="product-card-bg" style="background-image: url('/siftr/siftr-hero.jpg');"></div>
          <div class="product-card-scrim product-card-scrim--siftr"></div>
          <div class="product-card-content">
            <div class="product-meta">
              <img src="/brand/siftr-icon.svg" alt="" class="product-icon" width="28" height="28" />
              <span class="product-label">SIFTR <span class="product-sep">//</span> LOG ANALYSIS SYSTEM</span>
            </div>
            <p class="product-tagline">200MB log files. 3 seconds. Zero crashes.</p>
            <span class="product-cta">Learn More →</span>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- ══ SERVICES ══ -->
  <section class="services-section">
    <div class="container">
      <div class="services-card">
        <div class="services-left">
          <span class="section-eyebrow" style="color: #C4896A;">Services</span>
          <h2 class="services-heading">
            Brand DNA <span class="services-sep">//</span> Full-Stack Contracting
          </h2>
          <p class="services-desc">
            Production websites. Complete brand identity systems. Mobile apps.
            Whatever you need shipped — scoped, estimated, delivered.
          </p>
          <a href="/services" class="services-cta">See What We Build →</a>
        </div>
        <ul class="services-capabilities" aria-label="Service capabilities">
          <li>Brand Constitution &amp; Bible</li>
          <li>Design Token Systems</li>
          <li>Production Web Builds</li>
          <li>Mobile App Development</li>
          <li>Full-Stack Contracting</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ══ PROOF STRIP ══ -->
  <div class="proof-strip" aria-label="Credentials">
    <div class="container">
      <div class="proof-items">
        <span>20+ years shipping software</span>
        <span class="proof-dot" aria-hidden="true">·</span>
        <span>2 desktop apps in market</span>
        <span class="proof-dot" aria-hidden="true">·</span>
        <span>Full-stack architect for hire</span>
      </div>
    </div>
  </div>

  <!-- ══ WORK ══ -->
  <section class="work-section">
    <div class="container">
      <span class="section-eyebrow" style="color: #C4896A;">Work</span>
      <div class="work-card">
        <div class="work-info">
          <span class="work-type">Brand System + Web Build</span>
          <h3 class="work-name">Staples &amp; Statements</h3>
          <p class="work-desc">
            Wix to production — complete brand system, custom domain,
            Calendly booking, LTK shop integration, archetype quiz, and style guide.
            Zero templates. Zero page builders.
          </p>
          <a
            href="https://staplesandstatements.com"
            class="work-link"
            target="_blank"
            rel="noopener noreferrer"
          >
            staplesandstatements.com →
          </a>
        </div>
        <div class="work-preview">
          <div class="work-frame">
            <div class="work-frame-bar">
              <span class="work-frame-dots">
                <span></span><span></span><span></span>
              </span>
              <span class="work-frame-url">staplesandstatements.com</span>
            </div>
            <div class="work-frame-body">
              <span class="work-frame-todo">// preview image coming soon</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ ABOUT ══ -->
  <section class="about container">
    <div class="about-panel">
      <h2 class="about-heading">About</h2>
      <p class="about-text">
        SG57 Labs is a software refinery &mdash; we build focused, high-performance tools
        that do one thing exceptionally well. No bloat, no compromises.
        Every detail refined until only what matters remains.
      </p>
    </div>
  </section>

</Base>

<style>
  /* ════════════════════════════════════════════════════
     HERO
     ════════════════════════════════════════════════════ */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 55fr 45fr;
    gap: 3rem;
    align-items: center;
    padding: 7rem 1.5rem 5rem;
  }

  /* ── Left: text ── */
  .hero-eyebrow {
    display: block;
    font-family: var(--sg57-font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: var(--sg57-accent);
    text-transform: uppercase;
    margin-bottom: 1.25rem;
    opacity: 0;
    animation: slide-up 0.8s 0.1s var(--sg57-ease-snap) forwards;
  }

  .hero-headline {
    display: flex;
    flex-direction: column;
    line-height: 0.95;
    margin-bottom: 1.75rem;
    opacity: 0;
    animation: slide-up 0.9s 0.2s var(--sg57-ease-snap) forwards;
  }

  .hl-dim {
    font-family: var(--sg57-font-display);
    font-weight: 300;
    font-size: clamp(2.8rem, 7vw, 6rem);
    color: var(--sg57-text-dim);
    letter-spacing: 0.04em;
  }

  .hl-bold {
    font-family: var(--sg57-font-display);
    font-weight: 700;
    font-size: clamp(3rem, 7.5vw, 6.5rem);
    color: #ffffff;
    letter-spacing: 0.02em;
    text-shadow: 0 0 60px rgba(152, 142, 213, 0.15);
  }

  .hero-sub {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: clamp(0.9rem, 1.5vw, 1.05rem);
    color: var(--sg57-text-dim);
    line-height: 1.7;
    max-width: 460px;
    margin-bottom: 2rem;
    opacity: 0;
    animation: slide-up 0.9s 0.35s var(--sg57-ease-snap) forwards;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    opacity: 0;
    animation: slide-up 0.9s 0.5s var(--sg57-ease-snap) forwards;
  }

  .btn {
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.06em;
    padding: 0.65rem 1.4rem;
    min-height: 44px;
    border-radius: var(--sg57-radius-md);
    text-decoration: none;
    transition: all 0.2s var(--sg57-ease-out);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
  }

  .btn-primary {
    background: var(--sg57-glass-bg);
    backdrop-filter: blur(var(--sg57-glass-blur));
    -webkit-backdrop-filter: blur(var(--sg57-glass-blur));
    border: 1px solid var(--sg57-accent);
    color: var(--sg57-accent);
  }

  .btn-primary:hover {
    background: rgba(152, 142, 213, 0.12);
    box-shadow: 0 0 20px var(--sg57-accent-glow);
    color: var(--sg57-accent-hover);
    transform: translateY(-1px);
  }

  .btn:active {
    transform: scale(0.97);
  }

  .btn-ghost {
    background: transparent;
    border: 1px solid var(--sg57-glass-border);
    color: var(--sg57-text-dim);
  }

  .btn-ghost:hover {
    border-color: var(--sg57-text-dim);
    color: var(--sg57-text);
    transform: translateY(-1px);
  }

  /* ── Right: terminal mockup ── */
  .hero-visual {
    opacity: 0;
    animation: slide-up 1s 0.4s var(--sg57-ease-snap) forwards;
  }

  .terminal-window {
    background: var(--sg57-glass-bg-dense);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--sg57-border-glass);
    border-radius: var(--sg57-radius-lg);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.6), 0 0 0 1px rgba(255,255,255,0.04);
    overflow: hidden;
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 1rem;
    background: var(--sg57-overlay-subtle);
    border-bottom: 1px solid var(--sg57-border-glass);
  }

  .t-dots { display: flex; gap: 0.35rem; }
  .t-dot {
    width: 10px; height: 10px; border-radius: 50%;
  }
  .t-dot--red    { background: #ff5f57; }
  .t-dot--yellow { background: #febc2e; }
  .t-dot--green  { background: #28c840; }

  .t-title {
    font-family: var(--sg57-font-mono);
    font-size: 0.7rem;
    color: var(--sg57-text-muted);
    letter-spacing: 0.05em;
    margin-left: 0.25rem;
  }

  .terminal-body {
    padding: 1.25rem 1.25rem 1rem;
    font-family: var(--sg57-font-mono);
    font-size: 0.78rem;
    line-height: 1.6;
  }

  .t-line     { color: var(--sg57-text); margin: 0.1rem 0; }
  .t-gap      { height: 0.6rem; }
  .t-ok       { color: var(--sg57-success); }
  .t-meta     { color: var(--sg57-text-dim); padding-left: 0.5rem; }
  .t-prompt   { color: var(--sg57-accent); margin-right: 0.4rem; }
  .t-cmd      { color: var(--sg57-text); }
  .t-active   { color: #5BC0BE; }
  .t-idle     { color: var(--sg57-text-muted); }

  .t-cursor {
    color: var(--sg57-accent);
    animation: cursor-blink 1.1s step-start infinite;
  }

  @keyframes cursor-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  .t-todo {
    margin-top: 1rem;
    padding: 0.6rem 0.75rem;
    border: 1px dashed var(--sg57-accent-glow);
    border-radius: 4px;
    font-family: var(--sg57-font-mono);
    font-size: 0.68rem;
    color: var(--sg57-text-muted);
    letter-spacing: 0.03em;
  }

  /* ── Scroll hint ── */
  .hero-scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    opacity: 0;
    animation: fade-in 1s 1.2s ease forwards;
  }

  .scroll-label {
    font-family: var(--sg57-font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    color: var(--sg57-text-muted);
    text-transform: uppercase;
  }

  .scroll-arrow {
    color: var(--sg57-text-muted);
    font-size: 0.75rem;
    animation: scroll-bounce 2s ease-in-out infinite;
  }

  @keyframes scroll-bounce {
    0%, 100% { transform: translateY(0);   opacity: 0.4; }
    50%       { transform: translateY(4px); opacity: 0.9; }
  }

  /* ════════════════════════════════════════════════════
     SHARED SECTION LABEL
     ════════════════════════════════════════════════════ */
  .section-eyebrow {
    display: block;
    font-family: var(--sg57-font-mono);
    font-size: 0.68rem;
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--sg57-accent);
    margin-bottom: 1.25rem;
  }

  /* ════════════════════════════════════════════════════
     PRODUCTS — cinematic media cards
     ════════════════════════════════════════════════════ */
  .products {
    padding: 3rem 1.5rem 2.5rem;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .product-card {
    position: relative;
    display: block;
    height: 280px;
    border-radius: var(--sg57-radius-lg);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--sg57-border-glass);
    transition: transform 0.25s var(--sg57-ease-out), box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .product-card:hover {
    transform: translateY(-3px);
  }

  .product-card--clide:hover {
    box-shadow: 0 8px 40px rgba(91, 192, 190, 0.2);
    border-color: rgba(91, 192, 190, 0.35);
  }

  .product-card--siftr:hover {
    box-shadow: 0 8px 40px rgba(212, 161, 90, 0.2);
    border-color: rgba(212, 161, 90, 0.35);
  }

  /* Banner image layer */
  .product-card-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transition: transform 0.4s var(--sg57-ease-out);
  }

  .product-card:hover .product-card-bg {
    transform: scale(1.03);
  }

  /* Gradient scrim — content lives over this */
  .product-card-scrim {
    position: absolute;
    inset: 0;
  }

  .product-card-scrim--clide {
    background: linear-gradient(
      to top,
      rgba(6, 12, 16, 0.92) 0%,
      rgba(6, 12, 16, 0.55) 45%,
      rgba(6, 12, 16, 0.15) 100%
    );
  }

  .product-card-scrim--siftr {
    background: linear-gradient(
      to top,
      rgba(8, 6, 4, 0.92) 0%,
      rgba(8, 6, 4, 0.55) 45%,
      rgba(8, 6, 4, 0.15) 100%
    );
  }

  /* Content pinned to bottom */
  .product-card-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .product-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.15rem;
  }

  .product-icon {
    flex-shrink: 0;
    opacity: 0.9;
  }

  .product-label {
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    color: var(--sg57-text);
  }

  .product-card--clide .product-sep { color: #5BC0BE; }
  .product-card--siftr .product-sep { color: #D4A15A; }

  .product-tagline {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: 0.88rem;
    color: var(--sg57-text-dim);
    line-height: 1.4;
  }

  .product-cta {
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    margin-top: 0.25rem;
    transition: color 0.2s ease;
  }

  .product-card--clide .product-cta { color: #5BC0BE; }
  .product-card--siftr .product-cta { color: #D4A15A; }

  .product-card--clide:hover .product-cta { color: #6DD4D2; }
  .product-card--siftr:hover .product-cta { color: #DEB374; }

  /* ════════════════════════════════════════════════════
     SERVICES
     ════════════════════════════════════════════════════ */
  .services-section {
    padding: 1.5rem 1.5rem 2.5rem;
  }

  .services-card {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2.5rem;
    align-items: center;
    background: var(--sg57-glass-bg);
    backdrop-filter: blur(var(--sg57-glass-blur));
    -webkit-backdrop-filter: blur(var(--sg57-glass-blur));
    border: 1px solid rgba(196, 137, 106, 0.2);
    box-shadow: 0 0 40px rgba(196, 137, 106, 0.06), var(--sg57-glass-shadow);
    border-radius: var(--sg57-radius-lg);
    padding: 2rem 2.5rem;
  }

  .services-heading {
    font-family: var(--sg57-font-display);
    font-weight: 700;
    font-size: clamp(1.1rem, 2.5vw, 1.6rem);
    color: var(--sg57-text);
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }

  .services-sep { color: #C4896A; margin: 0 0.15em; }

  .services-desc {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: 0.9rem;
    color: var(--sg57-text-dim);
    line-height: 1.65;
    max-width: 500px;
    margin-bottom: 1.25rem;
  }

  .services-cta {
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    color: #C4896A;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .services-cta:hover { color: #D49A7A; }

  .services-capabilities {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-left: 1px solid rgba(196, 137, 106, 0.18);
    padding-left: 2rem;
    flex-shrink: 0;
  }

  .services-capabilities li {
    font-family: var(--sg57-font-mono);
    font-size: 0.72rem;
    color: var(--sg57-text-dim);
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  .services-capabilities li::before {
    content: '→ ';
    color: rgba(196, 137, 106, 0.5);
  }

  /* ════════════════════════════════════════════════════
     PROOF STRIP
     ════════════════════════════════════════════════════ */
  .proof-strip {
    padding: 1.25rem 0;
    border-top: 1px solid var(--sg57-border-glass);
    border-bottom: 1px solid var(--sg57-border-glass);
    background: var(--sg57-overlay-subtle);
  }

  .proof-items {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    font-family: var(--sg57-font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: var(--sg57-text-dim);
    text-transform: uppercase;
  }

  .proof-dot {
    color: var(--sg57-accent);
    opacity: 0.5;
  }

  /* ════════════════════════════════════════════════════
     WORK
     ════════════════════════════════════════════════════ */
  .work-section {
    padding: 3rem 1.5rem 2.5rem;
  }

  /* override container on this section */
  .work-section > .container {
    max-width: 1120px;
  }

  .work-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: center;
    background: var(--sg57-glass-bg);
    backdrop-filter: blur(var(--sg57-glass-blur));
    -webkit-backdrop-filter: blur(var(--sg57-glass-blur));
    border: 1px solid var(--sg57-glass-border);
    box-shadow: var(--sg57-glass-shadow);
    border-radius: var(--sg57-radius-lg);
    padding: 2.5rem;
  }

  .work-type {
    display: block;
    font-family: var(--sg57-font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #C4896A;
    margin-bottom: 0.75rem;
  }

  .work-name {
    font-family: var(--sg57-font-display);
    font-weight: 700;
    font-size: clamp(1.4rem, 3vw, 2rem);
    color: var(--sg57-text);
    letter-spacing: 0.04em;
    margin-bottom: 1rem;
    line-height: 1.1;
  }

  .work-desc {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: 0.9rem;
    color: var(--sg57-text-dim);
    line-height: 1.7;
