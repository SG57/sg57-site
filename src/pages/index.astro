---
import Base from '../layouts/Base.astro';
---

<Base>

  <!-- ══ Hero (full viewport) ══ -->
  <section class="hero">
    <div class="hero-content container">
      <div class="hero-logo">
        <span class="bracket">[</span>
        <span class="logo-text">SG57</span>
        <span class="bracket">]</span>
      </div>
      <p class="hero-labs">LABS</p>
      <div class="hero-divider" aria-hidden="true">
        <span class="divider-line"></span>
        <span class="divider-dot">◆</span>
        <span class="divider-line"></span>
      </div>
      <p class="hero-subtitle">Software Refinery</p>
    </div>
  </section>

  <!-- ══ Products ══ -->
  <section class="products container">
    <div class="product-grid">
      <a href="/clide" class="product-card product-card--clide stagger-item" style="--stagger-index: 0; animation: slide-up 0.5s var(--sg57-ease-snap) both;">
        <div class="product-icon">
          <img src="/brand/clide-icon.svg" alt="" width="48" height="48" />
        </div>
        <h2 class="product-name">CLIDE <span class="product-sep">//</span> AI TERMINAL COMMAND CENTER</h2>
        <p class="product-tagline">Mission Control for your AI terminal sessions.</p>
        <p class="product-desc">Manage dozens of CLI AI agents from one cockpit.</p>
        <span class="product-cta">Learn More &rarr;</span>
      </a>
      <a href="/siftr" class="product-card product-card--siftr stagger-item" style="--stagger-index: 1; animation: slide-up 0.5s var(--sg57-ease-snap) both;">
        <div class="product-icon">
          <img src="/brand/siftr-icon.svg" alt="" width="48" height="48" />
        </div>
        <h2 class="product-name">SIFTR <span class="product-sep">//</span> LOG ANALYSIS SYSTEM</h2>
        <p class="product-tagline">200MB log files. 3 seconds. Zero crashes.</p>
        <p class="product-desc">High-performance log viewer for .NET/IIS environments.</p>
        <span class="product-cta">Learn More &rarr;</span>
      </a>
    </div>
  </section>

  <!-- ══ About ══ -->
  <section class="about container">
    <div class="about-panel">
      <h2 class="about-heading">About</h2>
      <p class="about-text">
        SG57 Labs is a software refinery &mdash; we build focused,
        high-performance tools that do one thing exceptionally well.
        No bloat, no compromises. Every detail refined until only
        what matters remains.
      </p>
    </div>
  </section>

</Base>

<style>
  /* ════════════════════════════════════════════════════
     HERO
     ════════════════════════════════════════════════════ */
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
  }

  .hero-content {
    text-align: center;
    padding: 6rem 1.5rem;
  }

  .hero-logo {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.3rem;
    margin-bottom: 0.25rem;
    animation: hero-in 1.2s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .bracket {
    font-family: var(--sg57-font-display);
    font-weight: 200;
    font-size: clamp(2.5rem, 6vw, 5rem);
    color: var(--sg57-accent);
    animation: bracket-pulse 4.5s ease-in-out infinite;
  }

  .logo-text {
    font-family: var(--sg57-font-display);
    font-weight: 700;
    font-size: clamp(3rem, 8vw, 6.5rem);
    color: #ffffff;
    letter-spacing: 0.2em;
    text-shadow:
      0 0 40px rgba(255, 255, 255, 0.12),
      0 0 80px rgba(152, 142, 213, 0.10);
  }

  .hero-labs {
    font-family: var(--sg57-font-display);
    font-weight: 300;
    font-size: clamp(0.75rem, 1.4vw, 1rem);
    letter-spacing: 0.55em;
    color: var(--sg57-text-dim);
    text-transform: uppercase;
    margin-bottom: 1.25rem;
    opacity: 0;
    animation: hero-in 1.2s 0.18s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .hero-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
    opacity: 0;
    animation: hero-in 0.9s 0.35s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .divider-line {
    display: block;
    width: 52px;
    height: 1px;
  }
  .divider-line:first-child {
    background: linear-gradient(to right, transparent, var(--sg57-accent-muted));
  }
  .divider-line:last-child {
    background: linear-gradient(to left, transparent, var(--sg57-accent-muted));
  }
  .divider-dot {
    font-size: 0.4rem;
    color: var(--sg57-accent-muted);
    line-height: 1;
  }

  .hero-subtitle {
    font-family: var(--sg57-font-display);
    font-weight: 300;
    font-size: clamp(1rem, 2vw, 1.4rem);
    color: var(--sg57-text-dim);
    letter-spacing: 0.1em;
    opacity: 0;
    animation: hero-in 1.2s 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @keyframes hero-in {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0);    }
  }

  @keyframes bracket-pulse {
    0%, 100% { opacity: 0.65; text-shadow: 0 0 10px rgba(152, 142, 213, 0.25); }
    50%       { opacity: 1.00; text-shadow: 0 0 30px rgba(152, 142, 213, 0.70); }
  }

  /* ════════════════════════════════════════════════════
     PRODUCTS — frosted glass cards
     ════════════════════════════════════════════════════ */
  .products {
    padding: 4rem 1.5rem 5rem;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .product-card {
    display: flex;
    flex-direction: column;
    background: var(--frost-bg);
    backdrop-filter: blur(var(--frost-blur));
    -webkit-backdrop-filter: blur(var(--frost-blur));
    border: 1px solid var(--frost-border);
    box-shadow: var(--frost-shadow);
    border-radius: 8px;
    padding: 2rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.2s var(--sg57-ease-out);
  }

  .product-card:hover {
    border-color: var(--sg57-accent-muted);
    box-shadow:
      0 0 32px var(--sg57-accent-glow),
      inset 0 0 32px var(--sg57-accent-glow),
      var(--frost-shadow);
    transform: translateY(-2px);
  }

  .product-card--clide {
    --sg57-accent:       #5BC0BE;
    --sg57-accent-hover: #6DD4D2;
    --sg57-accent-muted: #4A9E9C;
    --sg57-accent-glow:  rgba(91, 192, 190, 0.12);
  }
  .product-card--siftr {
    --sg57-accent:       #D4A15A;
    --sg57-accent-hover: #DEB374;
    --sg57-accent-muted: #B8894A;
    --sg57-accent-glow:  rgba(212, 161, 90, 0.12);
  }

  .product-icon      { margin-bottom: 1.25rem; width: 48px; height: 48px; }
  .product-name      { font-family: var(--sg57-font-display); font-weight: 600; font-size: 1rem; letter-spacing: 0.1em; color: #ffffff; margin-bottom: 0.75rem; }
  .product-sep       { color: var(--sg57-accent); margin: 0 0.15em; }
  .product-tagline   { font-family: var(--sg57-font-display); font-weight: 500; font-size: 0.95rem; color: var(--sg57-text); margin-bottom: 0.35rem; }
  .product-desc      { font-family: var(--sg57-font-display); font-weight: 400; font-size: 0.9rem; color: var(--sg57-text-dim); line-height: 1.5; flex: 1; margin-bottom: 1.25rem; }
  .product-cta       { font-family: var(--sg57-font-display); font-weight: 600; font-size: 0.85rem; color: var(--sg57-accent); letter-spacing: 0.05em; transition: color 0.2s ease; }
  .product-card:hover .product-cta { color: var(--sg57-accent-hover); }

  /* ════════════════════════════════════════════════════
     ABOUT — frosted glass panel
     ════════════════════════════════════════════════════ */
  .about {
    padding: 0 1.5rem 6rem;
    max-width: 720px;
  }

  .about-panel {
    background: var(--frost-bg);
    backdrop-filter: blur(var(--frost-blur));
    -webkit-backdrop-filter: blur(var(--frost-blur));
    border: 1px solid var(--frost-border);
    box-shadow: var(--frost-shadow);
    border-radius: 8px;
    padding: 2rem 2.5rem;
  }

  .about-heading {
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 1.1rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sg57-accent);
    margin-bottom: 1rem;
  }

  .about-text {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: 1rem;
    color: var(--sg57-text-dim);
    line-height: 1.7;
  }

  /* ── Responsive ── */
  @media (max-width: 720px) {
    .product-grid { grid-template-columns: 1fr; }
    .hero         { min-height: 80vh; }
  }
</style>
