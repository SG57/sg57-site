---
import Base from '../../layouts/Base.astro';
import ApiKeyWizard from '../../components/text-easy/ApiKeyWizard.astro';
---

<Base
  title="Set Up Your Free AI Key — Text Easy | SG57 Labs"
  description="One-time setup guide to get your free Gemini API key for Text Easy. Takes about 2 minutes. Your key stays on your device."
  accentColor="#00FF88"
  accentHover="#33FFaa"
  accentMuted="#00CC6E"
  accentGlow="rgba(0, 255, 136, 0.15)"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'Set Up Your Free Gemini API Key for Text Easy',
    description: 'A step-by-step guide to getting your free AI key from Google and connecting it to the Text Easy app.',
    totalTime: 'PT2M',
    tool: { '@type': 'HowToTool', name: 'Google account (Gmail, YouTube, etc.)' },
    step: [
      {
        '@type': 'HowToStep',
        position: 1,
        name: 'Sign in to Google AI Studio',
        text: 'Go to aistudio.google.com/apikey and sign in with your Google account.',
        url: 'https://aistudio.google.com/apikey',
      },
      {
        '@type': 'HowToStep',
        position: 2,
        name: 'Create your API key',
        text: 'Click the blue "Create API key" button. If asked, create a new project with any name. Google will generate a key starting with "AIza...".',
      },
      {
        '@type': 'HowToStep',
        position: 3,
        name: 'Copy the key',
        text: 'Tap or click the copy icon (two overlapping squares) next to the key.',
      },
      {
        '@type': 'HowToStep',
        position: 4,
        name: 'Paste it in Text Easy',
        text: 'Open Text Easy, go to Settings, tap "API Key", long-press the text field and paste, then tap Save.',
      },
      {
        '@type': 'HowToStep',
        position: 5,
        name: 'Done',
        text: 'Text Easy is now connected to Google\'s AI. Try it by copying any text message and tapping the Text Easy Quick Settings tile.',
      },
    ],
  }}
>

  <!-- ══════════════════════════════════════════════════════════════════════════
       §1 HERO — compact, informational, not cinematic
       ══════════════════════════════════════════════════════════════════════════ -->
  <section class="setup-hero">
    <div class="container bloom">
      <span class="hero-eyebrow">TEXT EASY SETUP</span>
      <h1 class="hero-headline">Set Up Your Free AI Key</h1>
      <div class="hero-badges">
        <span class="hero-badge">One-time setup</span>
        <span class="hero-badge-sep" aria-hidden="true">&middot;</span>
        <span class="hero-badge">About 2 minutes</span>
        <span class="hero-badge-sep" aria-hidden="true">&middot;</span>
        <span class="hero-badge">Your key stays on your device</span>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════════════════
       §2 CONTEXT — warm explanation of what this is and why
       ══════════════════════════════════════════════════════════════════════════ -->
  <section class="context container">
    <div class="duotone-card">
      <div class="duotone-left">
        <div class="duotone-icon" aria-hidden="true">
          <svg viewBox="0 0 56 56" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M28 8v6M28 42v6M8 28h6M42 28h6" opacity="0.3"/>
            <path d="M16 16l4 4M36 36l4 4M36 16l-4 4M16 36l4-4" opacity="0.2"/>
            <rect x="18" y="18" width="20" height="20" rx="4" stroke-width="1.5"/>
            <path d="M28 24v8M24 28h8" stroke-width="2"/>
          </svg>
        </div>
        <h2 class="duotone-heading">Why you need this</h2>
      </div>
      <div class="duotone-right">
        <p class="duotone-body">
          Text Easy uses Google&rsquo;s Gemini AI to read messages and write replies in your voice.
          To do this, it needs a free <strong>API key</strong> &mdash; think of it like a library card
          that lets the app borrow from Google&rsquo;s AI.
        </p>
        <p class="duotone-body">
          You get one for free, it takes about 2 minutes, and you never have to do it again.
        </p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════════════════
       §3 INTERACTIVE WIZARD — guided step-by-step setup
       ══════════════════════════════════════════════════════════════════════════ -->
  <section class="wizard-section container" aria-label="Setup wizard">
    <ApiKeyWizard />
  </section>

  <!-- ══════════════════════════════════════════════════════════════════════════
       §4 FAQ — animated accordion with icons
       ══════════════════════════════════════════════════════════════════════════ -->
  <section class="faq container" aria-labelledby="faq-heading">
    <h2 class="section-label" id="faq-heading">Common Questions</h2>

    <div class="faq-grid" id="faq-grid">

      <div class="faq-card" data-faq data-open="true">
        <button class="faq-question" aria-expanded="true">
          <span class="faq-icon" aria-hidden="true">
            <svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="14" cy="14" r="11"/>
              <path d="M10 14h8"/>
              <path d="M14 7v3M14 18v3" opacity="0.3"/>
            </svg>
          </span>
          <span class="faq-label">Is this really free?</span>
          <span class="faq-toggle" aria-hidden="true">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="4" y1="10" x2="16" y2="10"/><line class="faq-toggle-vert" x1="10" y1="4" x2="10" y2="16"/></svg>
          </span>
        </button>
        <div class="faq-panel">
          <div class="faq-answer">
            Yes. Google&rsquo;s free tier gives you <strong>1,500 requests per day</strong>.
            Even heavy texters rarely use 50 in a day. You&rsquo;d need to generate replies
            non-stop for hours to come close. There&rsquo;s no credit card required and no surprise charges.
          </div>
        </div>
      </div>

      <div class="faq-card" data-faq>
        <button class="faq-question" aria-expanded="false">
          <span class="faq-icon" aria-hidden="true">
            <svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="7" y="12" width="14" height="11" rx="2"/>
              <path d="M10 12V9a4 4 0 018 0v3"/>
              <circle cx="14" cy="18" r="1.5" fill="currentColor" stroke="none"/>
            </svg>
          </span>
          <span class="faq-label">Is my key safe?</span>
          <span class="faq-toggle" aria-hidden="true">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="4" y1="10" x2="16" y2="10"/><line class="faq-toggle-vert" x1="10" y1="4" x2="10" y2="16"/></svg>
          </span>
        </button>
        <div class="faq-panel">
          <div class="faq-answer">
            Your API key is stored <strong>only on your device</strong> using Android&rsquo;s encrypted storage
            (the same system that protects your passwords and fingerprints). SG57 Labs never sees,
            collects, or transmits your key. It goes directly from your phone to Google &mdash; we&rsquo;re
            not in the middle.
          </div>
        </div>
      </div>

      <div class="faq-card" data-faq>
        <button class="faq-question" aria-expanded="false">
          <span class="faq-icon" aria-hidden="true">
            <svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 14a10 10 0 0118-6"/>
              <path d="M24 14a10 10 0 01-18 6"/>
              <polyline points="22 4 22 8 18 8"/>
              <polyline points="6 24 6 20 10 20"/>
            </svg>
          </span>
          <span class="faq-label">What if I lose my key?</span>
          <span class="faq-toggle" aria-hidden="true">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="4" y1="10" x2="16" y2="10"/><line class="faq-toggle-vert" x1="10" y1="4" x2="10" y2="16"/></svg>
          </span>
        </button>
        <div class="faq-panel">
          <div class="faq-answer">
            No problem. Go back to
            <a href="https://aistudio.google.com/apikey" target="_blank" rel="noopener noreferrer">aistudio.google.com/apikey</a>
            and create a new one. You can have multiple keys, and old ones keep working
            until you delete them.
          </div>
        </div>
      </div>

      <div class="faq-card" data-faq>
        <button class="faq-question" aria-expanded="false">
          <span class="faq-icon" aria-hidden="true">
            <svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="6" width="10" height="16" rx="2"/>
              <rect x="15" y="6" width="10" height="16" rx="2"/>
              <line x1="6" y1="19" x2="10" y2="19" opacity="0.5"/>
              <line x1="18" y1="19" x2="22" y2="19" opacity="0.5"/>
            </svg>
          </span>
          <span class="faq-label">Can I use this key on multiple devices?</span>
          <span class="faq-toggle" aria-hidden="true">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="4" y1="10" x2="16" y2="10"/><line class="faq-toggle-vert" x1="10" y1="4" x2="10" y2="16"/></svg>
          </span>
        </button>
        <div class="faq-panel">
          <div class="faq-answer">
            Yes. Copy the same key into Text Easy on any Android device you own.
            They all share the same free 1,500 daily requests, which is still
            far more than you&rsquo;ll ever need.
          </div>
        </div>
      </div>

      <div class="faq-card" data-faq>
        <button class="faq-question" aria-expanded="false">
          <span class="faq-icon" aria-hidden="true">
            <svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="5" opacity="0.3"/>
              <path d="M14 18v2a3 3 0 003 3h0"/>
              <circle cx="11" cy="11" r="2"/>
              <path d="M15 15l6 6"/>
              <path d="M8 4l1 2M4 8l2 1" opacity="0.3"/>
            </svg>
          </span>
          <span class="faq-label">What exactly is an &ldquo;API key&rdquo;?</span>
          <span class="faq-toggle" aria-hidden="true">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="4" y1="10" x2="16" y2="10"/><line class="faq-toggle-vert" x1="10" y1="4" x2="10" y2="16"/></svg>
          </span>
        </button>
        <div class="faq-panel">
          <div class="faq-answer">
            It&rsquo;s a password that tells Google &ldquo;this app has permission to
            use my AI.&rdquo; That&rsquo;s it. You create it once, paste it into Text Easy,
            and never think about it again. It&rsquo;s tied to your own Google account so
            that you control it &mdash; you can delete it or create a new one anytime.
          </div>
        </div>
      </div>

      <div class="faq-card" data-faq>
        <button class="faq-question" aria-expanded="false">
          <span class="faq-icon" aria-hidden="true">
            <svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10 4l-2 8h12l-2-8"/>
              <circle cx="14" cy="18" r="6"/>
              <path d="M12 18l2 2 4-4"/>
            </svg>
          </span>
          <span class="faq-label">I pasted the key but Text Easy isn&rsquo;t working</span>
          <span class="faq-toggle" aria-hidden="true">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="4" y1="10" x2="16" y2="10"/><line class="faq-toggle-vert" x1="10" y1="4" x2="10" y2="16"/></svg>
          </span>
        </button>
        <div class="faq-panel">
          <div class="faq-answer">
            Make sure you copied the <strong>entire key</strong> &mdash; it&rsquo;s a long
            string that starts with <code>AIza</code>. If you accidentally copied only part
            of it, go back to
            <a href="https://aistudio.google.com/apikey" target="_blank" rel="noopener noreferrer">aistudio.google.com/apikey</a>,
            copy it again, and paste it into Settings. If it still doesn&rsquo;t work,
            try creating a brand new key. And if you&rsquo;re still stuck,
            email us at <a href="mailto:support@sg57.dev">support@sg57.dev</a> &mdash;
            we&rsquo;re happy to help.
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- FAQ accordion script — animated expand/collapse -->
  <script>
    document.addEventListener('astro:page-load', () => {
      const grid = document.getElementById('faq-grid');
      if (!grid) return;

      const cards = grid.querySelectorAll('[data-faq]');

      // Initialize: set panel heights for open items
      cards.forEach(card => {
        const panel = card.querySelector('.faq-panel');
        const answer = panel.querySelector('.faq-answer');
        if (!panel || !answer) return;

        if (card.dataset.open === 'true') {
          panel.style.maxHeight = answer.scrollHeight + 'px';
          panel.style.opacity = '1';
        } else {
          panel.style.maxHeight = '0';
          panel.style.opacity = '0';
        }
      });

      grid.addEventListener('click', e => {
        const btn = e.target.closest('.faq-question');
        if (!btn) return;

        const card = btn.closest('[data-faq]');
        const panel = card.querySelector('.faq-panel');
        const answer = panel.querySelector('.faq-answer');
        if (!panel || !answer) return;

        const isOpen = btn.getAttribute('aria-expanded') === 'true';

        if (isOpen) {
          // Collapse
          panel.style.maxHeight = answer.scrollHeight + 'px';
          void panel.offsetWidth; // force reflow
          panel.style.maxHeight = '0';
          panel.style.opacity = '0';
          btn.setAttribute('aria-expanded', 'false');
          card.removeAttribute('data-open');
        } else {
          // Expand
          panel.style.maxHeight = answer.scrollHeight + 'px';
          panel.style.opacity = '1';
          btn.setAttribute('aria-expanded', 'true');
          card.dataset.open = 'true';
        }
      });
    });
  </script>

  <!-- ══════════════════════════════════════════════════════════════════════════
       §5 FOOTER CTA
       ══════════════════════════════════════════════════════════════════════════ -->
  <section class="setup-footer">
    <div class="container">
      <div class="footer-cta-card bloom">
        <p class="footer-help">
          Need help? Email us at
          <a href="mailto:support@sg57.dev" class="footer-email">support@sg57.dev</a>
        </p>
        <a href="/text-easy" class="footer-back">
          <span class="back-arrow" aria-hidden="true">&larr;</span>
          Back to Text Easy
        </a>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ============================================
     Text Easy Setup Guide — Scoped Styles
     ============================================ */

  /* Product accent override — neon green, scoped to all page sections */
  .setup-hero,
  .context,
  .wizard-section,
  .faq,
  .setup-footer {
    --sg57-accent: var(--sg57-text-easy-accent);
    --sg57-accent-hover: var(--sg57-text-easy-accent-hover);
    --sg57-accent-muted: #00CC6E;
    --sg57-accent-glow: rgba(0, 255, 136, 0.15);
  }

  /* ── Hero ─────────────────────────────────────────────── */
  .setup-hero {
    padding: 6rem 1.5rem 3rem;
    text-align: center;
  }

  .hero-eyebrow {
    display: block;
    font-family: var(--sg57-font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.22em;
    color: var(--sg57-accent);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .hero-headline {
    font-family: var(--sg57-font-display);
    font-weight: 700;
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    color: var(--sg57-text-bright);
    margin-bottom: 1.25rem;
    line-height: 1.15;
  }

  .hero-badges {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
  }

  .hero-badge {
    font-family: var(--sg57-font-display);
    font-weight: 500;
    font-size: 1rem;
    color: var(--sg57-text-dim);
    letter-spacing: 0.02em;
  }

  .hero-badge-sep {
    color: var(--sg57-accent-muted);
    font-size: 1.25rem;
    line-height: 1;
  }

  /* ── Context section ─────────────────────────────────── */
  .context {
    padding: 0 1.5rem 3rem;
    max-width: 820px;
  }

  /* ── Duotone card — Clide splash-inspired 2-column ─── */
  .duotone-card {
    display: grid;
    grid-template-columns: 1fr 2fr;
    border-radius: var(--sg57-radius-md);
    overflow: hidden;
    border: 1px solid var(--sg57-border);
  }

  /* Left panel — accent-tinted, icon + title */
  .duotone-left {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 2rem 1.5rem;
    background:
      radial-gradient(
        ellipse 120% 80% at 50% 50%,
        color-mix(in srgb, var(--sg57-accent) 11%, var(--sg57-elevated)) 0%,
        color-mix(in srgb, var(--sg57-accent) 4%, var(--sg57-elevated)) 100%
      );
    border-right: 1px solid var(--sg57-accent-muted);
    text-align: center;
    position: relative;
  }

  /* Ambient glow orb behind the icon */
  .duotone-left::before {
    content: '';
    position: absolute;
    width: 120px;
    height: 120px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(
      circle,
      var(--sg57-accent-glow) 0%,
      transparent 70%
    );
    filter: blur(24px);
    pointer-events: none;
    animation: pulse-glow 5s ease-in-out infinite;
  }

  .duotone-icon {
    position: relative;
    width: 56px;
    height: 56px;
    color: var(--sg57-accent);
  }

  .duotone-icon svg {
    width: 100%;
    height: 100%;
    filter: drop-shadow(0 0 12px var(--sg57-accent-glow));
  }

  .duotone-heading {
    position: relative;
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 1.125rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sg57-accent);
  }

  /* Right panel — neutral, body text */
  .duotone-right {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.75rem;
    padding: 2rem;
    background:
      radial-gradient(
        ellipse at 10% 50%,
        color-mix(in srgb, var(--sg57-accent) 4%, var(--sg57-surface)) 0%,
        var(--sg57-surface) 60%
      );
  }

  .duotone-body {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: 1.125rem;
    color: var(--sg57-text);
    line-height: 1.75;
    text-align: left;
  }

  .duotone-body strong {
    color: var(--sg57-text-bright);
    font-weight: 600;
  }

  /* Duotone responsive — stack on mobile */
  @media (max-width: 600px) {
    .duotone-card {
      grid-template-columns: 1fr;
    }

    .duotone-left {
      border-right: none;
      border-bottom: 1px solid var(--sg57-accent-muted);
      padding: 1.5rem;
      flex-direction: row;
      gap: 1rem;
    }

    .duotone-left::before {
      width: 80px;
      height: 80px;
    }

    .duotone-icon {
      width: 40px;
      height: 40px;
    }

    .duotone-right {
      padding: 1.5rem;
    }
  }

  /* ── Wizard section ──────────────────────────────────── */
  .wizard-section {
    padding: 0 1.5rem 4rem;
    max-width: 780px;
  }

  /* ── FAQ section ─────────────────────────────────────── */
  .faq {
    padding: 2rem 1.5rem 4rem;
    max-width: 780px;
  }

  .section-label {
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 1.125rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sg57-accent);
    text-align: center;
    margin-bottom: 2rem;
  }

  .faq-grid {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .faq-card {
    background: var(--sg57-surface);
    border: 1px solid var(--sg57-border);
    border-radius: var(--sg57-radius-md);
    overflow: hidden;
    transition: border-color 0.3s ease;
  }

  .faq-card[data-open] {
    border-color: rgba(0, 255, 136, 0.2);
  }

  .faq-question {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    width: 100%;
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--sg57-text-bright);
    background: transparent;
    border: none;
    padding: 1.25rem 1.5rem;
    cursor: pointer;
    text-align: left;
    transition: color 0.2s ease;
    user-select: none;
    -webkit-user-select: none;
    -webkit-tap-highlight-color: transparent;
  }

  .faq-question:hover {
    color: var(--sg57-accent);
  }

  .faq-question:focus-visible {
    box-shadow: var(--sg57-focus-ring);
    outline: none;
  }

  .faq-icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    color: var(--sg57-accent);
    opacity: 0.6;
    transition: opacity 0.2s ease;
  }

  .faq-card[data-open] .faq-icon {
    opacity: 1;
  }

  .faq-icon svg {
    width: 100%;
    height: 100%;
  }

  .faq-label {
    flex: 1;
    min-width: 0;
  }

  /* Animated +/− toggle */
  .faq-toggle {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    color: var(--sg57-accent-muted);
    transition: color 0.2s ease;
  }

  .faq-card[data-open] .faq-toggle {
    color: var(--sg57-accent);
  }

  .faq-toggle svg {
    width: 100%;
    height: 100%;
  }

  .faq-toggle .faq-toggle-vert {
    transition: transform 0.3s var(--sg57-ease-out), opacity 0.3s ease;
    transform-origin: center;
  }

  .faq-card[data-open] .faq-toggle .faq-toggle-vert {
    transform: scaleY(0);
    opacity: 0;
  }

  /* Animated panel */
  .faq-panel {
    overflow: hidden;
