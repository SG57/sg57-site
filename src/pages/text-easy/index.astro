---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Text Easy — Intent-to-Text AI | SG57 Labs"
  description="AI-generated replies in your own voice. Share any text, pick your intent, choose a reply — done in seconds."
  accentColor="#00FF88"
  accentHover="#33FFaa"
  accentMuted="#00CC6E"
  accentGlow="rgba(0, 255, 136, 0.15)"
>
  <!-- Hero — cinematic banner -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="hero-atmosphere" aria-hidden="true">
      <svg class="hero-stars" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <circle cx="145" cy="180" r="2.2" fill="#e4e0f5" opacity="0.45" class="star star-a" style="--td:-0.0s;--dur:9s"/>
        <circle cx="420" cy="320" r="1.8" fill="#c4bce8" opacity="0.35" class="star star-b" style="--td:-3.1s;--dur:11s"/>
        <circle cx="680" cy="85"  r="2.5" fill="#e4e0f5" opacity="0.45" class="star star-a" style="--td:-1.7s;--dur:8.5s"/>
        <circle cx="950" cy="440" r="2.0" fill="#b8b0e0" opacity="0.35" class="star star-b" style="--td:-5.2s;--dur:10.5s"/>
        <circle cx="1230" cy="210" r="1.8" fill="#e4e0f5" opacity="0.4" class="star star-a" style="--td:-2.4s;--dur:9.5s"/>
        <circle cx="260" cy="620" r="2.2" fill="#c4bce8" opacity="0.35" class="star star-b" style="--td:-7.8s;--dur:12s"/>
        <circle cx="830" cy="730" r="1.8" fill="#e4e0f5" opacity="0.4" class="star star-a" style="--td:-0.9s;--dur:8s"/>
        <circle cx="1100" cy="560" r="2.2" fill="#b8b0e0" opacity="0.35" class="star star-b" style="--td:-4.5s;--dur:11.5s"/>
        <circle cx="70" cy="450" r="1.3" fill="#9098b8" opacity="0.22" class="star star-c" style="--td:-8.1s;--dur:15s"/>
        <circle cx="490" cy="530" r="1.3" fill="#9098b8" opacity="0.22" class="star star-c" style="--td:-11.4s;--dur:14.5s"/>
        <circle cx="730" cy="200" r="1.4" fill="#8090b0" opacity="0.2" class="star star-d" style="--td:-4.2s;--dur:16s"/>
        <circle cx="1020" cy="120" r="1.3" fill="#9098b8" opacity="0.22" class="star star-c" style="--td:-9.8s;--dur:18s"/>
        <circle cx="1280" cy="400" r="1.5" fill="#8090b0" opacity="0.2" class="star star-d" style="--td:-1.5s;--dur:15.5s"/>
      </svg>
    </div>
    <div class="hero-content container bloom">
      <!-- h1 for SEO/a11y — visually minimal -->
      <h1 class="sr-only">Text Easy — Intent-to-Text AI</h1>
      <span class="hero-label">INTENT-TO-TEXT ENGINE</span>
      <p class="hero-tagline">Say what you mean. Easy.</p>
      <p class="hero-subtitle">AI-generated replies in your own voice.</p>
      <div class="hero-actions">
        <div class="platform-buttons">
          <!-- iOS — coming soon -->
          <span class="platform-btn platform-btn--coming" aria-label="iOS version coming soon">
            <svg class="pbtn-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12.152 6.896c-.948 0-2.415-1.078-3.96-1.04-2.04.027-3.91 1.183-4.961 3.014-2.117 3.675-.546 9.103 1.519 12.09 1.013 1.454 2.208 3.09 3.792 3.039 1.52-.065 2.09-.987 3.935-.987 1.831 0 2.35.987 3.96.948 1.637-.026 2.676-1.48 3.676-2.948 1.156-1.688 1.636-3.325 1.662-3.415-.039-.013-3.182-1.221-3.22-4.857-.026-3.04 2.48-4.494 2.597-4.559-1.429-2.09-3.623-2.324-4.39-2.376-2-.156-3.675 1.09-4.61 1.09zM15.53 3.83c.843-1.012 1.4-2.427 1.245-3.83-1.207.052-2.662.805-3.532 1.818-.78.896-1.454 2.338-1.273 3.714 1.338.104 2.715-.688 3.559-1.701"/>
            </svg>
            <span class="pbtn-text">
              <span class="pbtn-sub">Coming to</span>
              <span class="pbtn-main">iOS</span>
            </span>
            <span class="pbtn-badge">Soon</span>
          </span>

          <!-- Android — active (MVP) -->
          <!-- TODO: replace href with live Google Play Store listing URL -->
          <a href="#" class="platform-btn platform-btn--android" target="_blank" rel="noopener noreferrer">
            <svg class="pbtn-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.523 15.341c-.551 0-.999-.449-.999-1s.448-.999.999-.999.999.448.999.999c0 .551-.448 1-.999 1m-11.046 0c-.551 0-.999-.449-.999-1s.448-.999.999-.999.999.448.999.999c0 .551-.449 1-.999 1m11.404-6.02l1.998-3.459a.416.416 0 00-.152-.568.416.416 0 00-.568.152l-2.022 3.503A10.875 10.875 0 0012 7.851a10.875 10.875 0 00-5.137 1.099L4.841 5.447a.416.416 0 00-.568-.152.416.416 0 00-.152.568l1.997 3.459C2.689 11.187.343 14.659 0 18.761h24c-.344-4.102-2.689-7.574-6.119-9.44"/>
            </svg>
            <span class="pbtn-text">
              <span class="pbtn-sub">Download on</span>
              <span class="pbtn-main">Google Play</span>
            </span>
          </a>

          <!-- Desktop — coming soon -->
          <span class="platform-btn platform-btn--coming" aria-label="Desktop version coming soon">
            <svg class="pbtn-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <rect x="2" y="2" width="9" height="9" rx="1.5"/>
              <rect x="13" y="2" width="9" height="9" rx="1.5"/>
              <rect x="2" y="13" width="9" height="9" rx="1.5"/>
              <rect x="13" y="13" width="9" height="9" rx="1.5"/>
            </svg>
            <span class="pbtn-text">
              <span class="pbtn-sub">Coming to</span>
              <span class="pbtn-main">Desktop</span>
            </span>
            <span class="pbtn-badge">Soon</span>
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem Statement -->
  <section class="problem container bloom">
    <p class="problem-text">
      You've got 12 unread messages. You know what you want to say.
      You just don't want to sit there and type it all out.
    </p>
    <p class="problem-text problem-punchline">
      <strong>Text Easy handles the words. You handle the intent.</strong>
    </p>
  </section>

  <!-- How It Works — 3-step flow -->
  <section class="how-it-works container">
    <h2 class="section-heading">How It Works</h2>
    <div class="steps-grid">
      <div class="step-card">
        <div class="step-number">01</div>
        <h3 class="step-heading">Share any text</h3>
        <p class="step-desc">
          Select a message in any app &mdash; SMS, Slack, email, Reddit, anywhere &mdash;
          and share it to Text Easy. No typing required.
        </p>
      </div>

      <div class="step-connector" aria-hidden="true">&rarr;</div>

      <div class="step-card">
        <div class="step-number">02</div>
        <h3 class="step-heading">Pick your intent</h3>
        <p class="step-desc">
          The AI infers 3 likely response intents from the message. You recognize
          the right one &mdash; no prompting, no typing.
        </p>
      </div>

      <div class="step-connector" aria-hidden="true">&rarr;</div>

      <div class="step-card">
        <div class="step-number">03</div>
        <h3 class="step-heading">Choose a reply, send</h3>
        <p class="step-desc">
          Pick from 3 reply options in your voice. Tap to copy, paste back
          into your conversation. Done in under 15 seconds.
        </p>
      </div>
    </div>
  </section>

  <!-- Feature Cards -->
  <section class="features container">
    <h2 class="section-heading">Capabilities</h2>
    <div class="feature-grid">
      <div class="feature-card">
        <div class="feature-icon">&#9670;</div>
        <h3 class="feature-name">Intent Inference</h3>
        <p class="feature-desc">
          AI reads the incoming message and surfaces 3 inferred intents.
          You recognize, you don&rsquo;t compose. It&rsquo;s recognition, not authorship.
        </p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">&#10022;</div>
        <h3 class="feature-name">Refinements</h3>
        <p class="feature-desc">
          Tune the output with one tap: shorter, longer, warmer, more formal.
          Refinements apply to the reply you picked, not to your prompt.
        </p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">&#9675;</div>
        <h3 class="feature-name">Your Voice</h3>
        <p class="feature-desc">
          Personalized to how you speak. The output sounds like you &mdash;
          because the intent was yours, and the voice settings are yours.
        </p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">&#9711;</div>
        <h3 class="feature-name">Compose Mode</h3>
        <p class="feature-desc">
          No incoming message? Type or paste your intent directly. Text Easy
          generates from scratch &mdash; anything from birthday wishes to awkward asks.
        </p>
      </div>
    </div>
  </section>

  <!-- Store Gallery -->
  <section class="media container">
    <h2 class="section-heading">App Preview</h2>
    <!-- TODO: replace with actual Play Store screenshots in a portrait frame grid
         Screenshot strategy (from TEXT-EASY-DNA.md §9):
           1. Intent picker — 3 inferred intents
           2. Reply picker — 3 flavored options
           3. Refinement panel — tone/length controls
           4. Quick Settings tile trigger
           5. Settings / personalization screen -->
    <div class="store-placeholder">
      <span class="placeholder-glyph">[ ]</span>
      <p class="placeholder-label">App screenshots coming soon</p>
    </div>
  </section>

  <!-- Free / BYOAPI callout -->
  <section class="byoapi container">
    <div class="byoapi-card">
      <p class="byoapi-heading">Free to use.</p>
      <p class="byoapi-body">
        Text Easy runs on your own Gemini API key &mdash; available free from Google AI Studio
        at 1,500 requests per day. No subscription. No backend. Your key, your data.
      </p>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="final-cta">
    <div class="container">
      <p class="final-cta-text">Stop staring at a blinking cursor.</p>
      <div class="platform-buttons">
        <!-- iOS — coming soon -->
        <span class="platform-btn platform-btn--coming" aria-label="iOS version coming soon">
          <svg class="pbtn-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12.152 6.896c-.948 0-2.415-1.078-3.96-1.04-2.04.027-3.91 1.183-4.961 3.014-2.117 3.675-.546 9.103 1.519 12.09 1.013 1.454 2.208 3.09 3.792 3.039 1.52-.065 2.09-.987 3.935-.987 1.831 0 2.35.987 3.96.948 1.637-.026 2.676-1.48 3.676-2.948 1.156-1.688 1.636-3.325 1.662-3.415-.039-.013-3.182-1.221-3.22-4.857-.026-3.04 2.48-4.494 2.597-4.559-1.429-2.09-3.623-2.324-4.39-2.376-2-.156-3.675 1.09-4.61 1.09zM15.53 3.83c.843-1.012 1.4-2.427 1.245-3.83-1.207.052-2.662.805-3.532 1.818-.78.896-1.454 2.338-1.273 3.714 1.338.104 2.715-.688 3.559-1.701"/>
          </svg>
          <span class="pbtn-text">
            <span class="pbtn-sub">Coming to</span>
            <span class="pbtn-main">iOS</span>
          </span>
          <span class="pbtn-badge">Soon</span>
        </span>

        <!-- Android — active (MVP) -->
        <!-- TODO: replace href with live Google Play Store listing URL -->
        <a href="#" class="platform-btn platform-btn--android" target="_blank" rel="noopener noreferrer">
          <svg class="pbtn-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.523 15.341c-.551 0-.999-.449-.999-1s.448-.999.999-.999.999.448.999.999c0 .551-.448 1-.999 1m-11.046 0c-.551 0-.999-.449-.999-1s.448-.999.999-.999.999.448.999.999c0 .551-.449 1-.999 1m11.404-6.02l1.998-3.459a.416.416 0 00-.152-.568.416.416 0 00-.568.152l-2.022 3.503A10.875 10.875 0 0012 7.851a10.875 10.875 0 00-5.137 1.099L4.841 5.447a.416.416 0 00-.568-.152.416.416 0 00-.152.568l1.997 3.459C2.689 11.187.343 14.659 0 18.761h24c-.344-4.102-2.689-7.574-6.119-9.44"/>
          </svg>
          <span class="pbtn-text">
            <span class="pbtn-sub">Download on</span>
            <span class="pbtn-main">Google Play</span>
          </span>
        </a>

        <!-- Desktop — coming soon -->
        <span class="platform-btn platform-btn--coming" aria-label="Desktop version coming soon">
          <svg class="pbtn-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <rect x="2" y="2" width="9" height="9" rx="1.5"/>
            <rect x="13" y="2" width="9" height="9" rx="1.5"/>
            <rect x="2" y="13" width="9" height="9" rx="1.5"/>
            <rect x="13" y="13" width="9" height="9" rx="1.5"/>
          </svg>
          <span class="pbtn-text">
            <span class="pbtn-sub">Coming to</span>
            <span class="pbtn-main">Desktop</span>
          </span>
          <span class="pbtn-badge">Soon</span>
        </span>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ============================================
     Text Easy Product Page — Scoped Styles
     ============================================ */

  /* Product accent override — neon green, scoped to all page sections */
  .hero,
  .problem,
  .how-it-works,
  .features,
  .media,
  .byoapi,
  .final-cta {
    --sg57-accent: var(--sg57-text-easy-accent);
    --sg57-accent-hover: var(--sg57-text-easy-accent-hover);
    --sg57-accent-muted: #00CC6E;
    --sg57-accent-glow: rgba(0, 255, 136, 0.15);
  }

  /* --- Hero --- */
  .hero {
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    min-height: 100vh;
    min-height: 100svh;
    overflow-x: clip; /* see clide/index.astro — same fix for bloom crease */
  }

  /* Sway intensity: --sway: 12px = medium (matches Clide/Siftr) */
  .hero-bg {
    position: absolute;
    inset: -3%;
    background-image: url('/text-easy/feature-graphic.webp');
    background-size: cover;
    background-position: center;
    pointer-events: none;
    --sway: 12px;
    animation: hero-sway 28s cubic-bezier(0.45, 0.05, 0.55, 0.95) infinite;
    will-change: transform;
    mask-image: linear-gradient(to bottom, black 68%, transparent 95%);
    -webkit-mask-image: linear-gradient(to bottom, black 68%, transparent 95%);
  }

  @keyframes hero-sway {
    0%   { transform: translate(0, 0)                                          scale(1.002); }
    12%  { transform: translate(var(--sway), calc(var(--sway) * 0.6))          scale(1.005); }
    27%  { transform: translate(calc(var(--sway) * -0.7), var(--sway))         scale(1.001); }
    41%  { transform: translate(calc(var(--sway) * -1), calc(var(--sway) * -0.4)) scale(1.004); }
    58%  { transform: translate(calc(var(--sway) * 0.5), calc(var(--sway) * -0.9)) scale(1.002); }
    73%  { transform: translate(calc(var(--sway) * 0.8), calc(var(--sway) * 0.3))  scale(1.005); }
    87%  { transform: translate(calc(var(--sway) * -0.4), calc(var(--sway) * 0.7)) scale(1.001); }
    100% { transform: translate(0, 0)                                          scale(1.002); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-bg { animation: none; inset: 0; }
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 0 1.5rem calc(4rem + 30px);
    width: 100%;
  }

  /* Strengthen the .bloom::before scrim for this vivid green hero image.
     The global .bloom is calibrated for the subtle violet site wallpaper;
     this override raises the opacity values without changing anything else. */
  .hero-content::before {
    background: radial-gradient(
      ellipse 70% 55% at 50% 50%,
      rgba(0, 0, 0, 0.90) 0%,
      rgba(0, 0, 0, 0.68) 28%,
      rgba(0, 0, 0, 0.35) 52%,
      transparent         70%
    );
  }

  .hero-label {
    display: block;
    font-family: var(--sg57-font-mono);
    font-size: 1.125rem;
    letter-spacing: 0.22em;
    color: var(--sg57-accent);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .hero-tagline {
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: clamp(1.125rem, 2.5vw, 1.6rem);
    color: var(--sg57-text);
    margin-bottom: 0.5rem;
  }

  .hero-subtitle {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: clamp(1.125rem, 1.8vw, 1.25rem);
    color: var(--sg57-text);
    margin-bottom: 2rem;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.8);
  }

  /* --- CTA Button --- */
  .cta-button {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 1.125rem;
    letter-spacing: 0.05em;
    color: var(--sg57-accent);
    background: var(--sg57-glass-bg);
    backdrop-filter: blur(var(--sg57-glass-blur));
    -webkit-backdrop-filter: blur(var(--sg57-glass-blur));
    border: 1px solid var(--sg57-accent-muted);
    border-radius: var(--sg57-radius-md);
    padding: 0.75rem 2rem;
    text-decoration: none;
    transition: color 0.25s ease, background 0.25s ease, border-color 0.25s ease,
                box-shadow 0.3s ease, transform 0.2s var(--sg57-ease-out);
  }

  .cta-button:hover {
    color: var(--sg57-text-on-accent);
    background: var(--sg57-accent);
    border-color: var(--sg57-accent);
    box-shadow: 0 0 28px var(--sg57-accent-glow);
    transform: translateY(-1px);
  }

  .cta-button:active {
    transform: scale(0.97) translateY(0);
  }

  .cta-button:focus-visible {
    box-shadow: var(--sg57-focus-ring), 0 0 28px var(--sg57-accent-glow);
    outline: none;
  }

  /* --- Platform Store Buttons --- */
  .platform-buttons {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    align-items: stretch;
    flex-wrap: wrap;
  }

  .platform-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    min-height: 56px;
    padding: 0.75rem 1.25rem;
    background: var(--sg57-glass-bg);
    backdrop-filter: blur(var(--sg57-glass-blur));
    -webkit-backdrop-filter: blur(var(--sg57-glass-blur));
    border: 1px solid var(--sg57-border);
    border-radius: var(--sg57-radius-md);
    text-decoration: none;
    position: relative;
  }

  .pbtn-icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  .pbtn-text {
    display: flex;
    flex-direction: column;
    text-align: left;
    line-height: 1;
  }

  .pbtn-sub {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.18em;
  }

  .pbtn-main {
    font-family: var(--sg57-font-display);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.03em;
  }

  /* Active: Android */
  .platform-btn--android {
    color: var(--sg57-accent);
    border-color: var(--sg57-accent-muted);
    transition: color 0.25s ease, background 0.25s ease, border-color 0.25s ease,
                box-shadow 0.3s ease, transform 0.2s var(--sg57-ease-out);
  }

  .platform-btn--android:hover {
    color: var(--sg57-text-on-accent);
    background: var(--sg57-accent);
    border-color: var(--sg57-accent);
    box-shadow: 0 0 28px var(--sg57-accent-glow);
    transform: translateY(-1px);
  }

  .platform-btn--android:active {
    transform: scale(0.97) translateY(0);
  }

  .platform-btn--android:focus-visible {
    box-shadow: var(--sg57-focus-ring), 0 0 28px var(--sg57-accent-glow);
    outline: none;
  }

  /* Inactive: coming soon */
  .platform-btn--coming {
    color: var(--sg57-text-muted);
    border-color: rgba(255, 255, 255, 0.07);
    opacity: 0.42;
    cursor: not-allowed;
    user-select: none;
  }

  .pbtn-badge {
    position: absolute;
    top: -8px;
    right: -4px;
    font-family: var(--sg57-font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sg57-text-dim);
    background: var(--sg57-surface);
    border: 1px solid var(--sg57-border);
    border-radius: 999px;
    padding: 0.1em 0.5em;
    line-height: 1.5;
  }

  @media (max-width: 600px) {
    .platform-buttons {
      flex-direction: column;
      align-items: center;
    }

    .platform-btn--android {
      order: -1;
    }

    .platform-btn {
      width: 100%;
      max-width: 260px;
      justify-content: center;
    }
  }

  /* --- Hero atmosphere: starfield above wallpaper --- */
  .hero-atmosphere {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    mask-image: linear-gradient(to bottom, black 70%, transparent 95%);
    -webkit-mask-image: linear-gradient(to bottom, black 70%, transparent 95%);
  }

  .hero-stars {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .star {
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
    animation-fill-mode: both;
  }

  .star-a {
    animation-name: star-drift-a, star-twinkle;
    animation-duration: var(--dur, 10s), 4.5s;
    animation-delay: var(--td, 0s), var(--td, 0s);
  }
  .star-b {
    animation-name: star-drift-b, star-twinkle;
    animation-duration: var(--dur, 10s), 5.8s;
