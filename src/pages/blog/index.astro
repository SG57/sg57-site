---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const totalPosts = posts.length;
const lastUpdated = posts[0]?.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) ?? '—';

const blogListSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'SG57 Labs Mission Log',
  description: 'Engineering notes, product announcements, case studies, and deep dives from SG57 Labs.',
  url: 'https://sg57.dev/blog',
  publisher: { '@type': 'Organization', name: 'SG57 Labs', url: 'https://sg57.dev' },
  blogPost: posts.map((p) => ({
    '@type': 'BlogPosting',
    headline: p.data.title,
    description: p.data.description,
    datePublished: p.data.date.toISOString(),
    url: `https://sg57.dev/blog/${p.id}`,
    author: { '@type': 'Person', name: p.data.author },
    keywords: p.data.tags.join(', '),
  })),
};
---

<Base
  title="Blog — SG57 Labs Mission Log"
  description="Engineering notes, product announcements, client case studies, and deep dives from SG57 Labs. Clide, Siftr, Text Easy, and web services."
  jsonLd={blogListSchema}
>
  <div class="mission-log">

    <!-- Starfield background -->
    <div class="starfield" aria-hidden="true">
      {Array.from({ length: 80 }).map((_, i) => (
        <span class="star" style={`--x:${Math.random()*100}%;--y:${Math.random()*100}%;--s:${(Math.random()*2+0.5).toFixed(1)}px;--d:${(Math.random()*8).toFixed(1)}s;--op:${(Math.random()*0.6+0.2).toFixed(2)}`}></span>
      ))}
    </div>

    <!-- Header: terminal window chrome -->
    <header class="ml-header container">
      <div class="ml-terminal-chrome">
        <div class="ml-chrome-bar">
          <span class="ml-chrome-dots" aria-hidden="true">
            <span class="ml-dot ml-dot--r"></span>
            <span class="ml-dot ml-dot--y"></span>
            <span class="ml-dot ml-dot--g"></span>
          </span>
          <span class="ml-chrome-title">sg57-labs :: mission-log :: transmission-archive</span>
          <span class="ml-chrome-sig" aria-hidden="true">◆ LIVE</span>
        </div>
        <div class="ml-chrome-body">
          <div class="ml-prompt-line">
            <span class="ml-prompt">root@sg57</span><span class="ml-prompt-sep">:</span><span class="ml-prompt-path">~/log</span><span class="ml-prompt-dollar">$</span>
            <span class="ml-prompt-cmd"> ls -la --sort=date</span>
          </div>
          <div class="ml-sys-info">
            <span class="ml-info-row"><span class="ml-info-label">TRANSMISSIONS INDEXED</span><span class="ml-info-val">{totalPosts.toString().padStart(3, '0')}</span></span>
            <span class="ml-info-row"><span class="ml-info-label">LAST TRANSMISSION</span><span class="ml-info-val">{lastUpdated.toUpperCase()}</span></span>
            <span class="ml-info-row"><span class="ml-info-label">SIGNAL STATUS</span><span class="ml-info-val ml-status-ok">● NOMINAL</span></span>
          </div>
          <h1 class="ml-heading">
            <span class="ml-heading-label">// MISSION LOG</span>
            <span class="ml-heading-sub">Engineering notes, case studies &amp; deep dives</span>
          </h1>
        </div>
      </div>
    </header>

    <!-- Post list -->
    <main class="ml-feed container">
      <ul class="ml-list">
        {posts.map((post, idx) => {
          const txNum = (totalPosts - idx).toString().padStart(3, '0');
          const formattedDate = post.data.date.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
          });
          const isRecent = idx === 0;
          return (
            <li class:list={['ml-item', { 'ml-item--latest': isRecent }]}>
              <a href={`/blog/${post.id}`} class="ml-card">
                <div class="ml-card-chrome">
                  <span class="ml-tx-id">TX-{txNum}</span>
                  {isRecent && <span class="ml-badge-new">NEW</span>}
                  <time class="ml-date" datetime={post.data.date.toISOString()}>{formattedDate.toUpperCase()}</time>
                </div>
                <h2 class="ml-card-title">{post.data.title}</h2>
                <p class="ml-card-desc">{post.data.description}</p>
                <div class="ml-card-footer">
                  <div class="ml-tags">
                    {post.data.tags.map((tag) => (
                      <span class="ml-tag">#{tag}</span>
                    ))}
                  </div>
                  <span class="ml-read-more">READ_TRANSMISSION →</span>
                </div>
              </a>
            </li>
          );
        })}
      </ul>

      {posts.length === 0 && (
        <div class="ml-empty">
          <span class="ml-empty-icon">◈</span>
          <p>No transmissions found. Check back soon.</p>
        </div>
      )}
    </main>

  </div>
</Base>

<style>
  /* ── Outer wrapper ── */
  .mission-log {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
  }

  /* ── Starfield ── */
  .starfield {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .star {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: var(--s);
    height: var(--s);
    background: #fff;
    border-radius: 50%;
    opacity: var(--op);
    animation: star-twinkle var(--d, 4s) ease-in-out infinite alternate;
  }

  @keyframes star-twinkle {
    0%   { opacity: var(--op); transform: scale(1); }
    100% { opacity: calc(var(--op) * 0.3); transform: scale(0.6); }
  }

  /* ── Container override ── */
  .mission-log .container {
    position: relative;
    z-index: 1;
    max-width: 800px;
  }

  /* ── Header ── */
  .ml-header {
    padding-top: 3rem;
    padding-bottom: 0;
  }

  .ml-terminal-chrome {
    border: 1px solid rgba(152, 142, 213, 0.3);
    border-radius: var(--sg57-radius-lg);
    overflow: hidden;
    box-shadow: 0 0 40px rgba(152, 142, 213, 0.08), 0 0 80px rgba(152, 142, 213, 0.04);
    background: var(--sg57-glass-bg);
    backdrop-filter: blur(var(--sg57-glass-blur));
    -webkit-backdrop-filter: blur(var(--sg57-glass-blur));
  }

  .ml-chrome-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 1rem;
    background: rgba(26, 28, 40, 0.9);
    border-bottom: 1px solid rgba(152, 142, 213, 0.15);
  }

  .ml-chrome-dots {
    display: flex;
    gap: 6px;
    flex-shrink: 0;
  }

  .ml-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }
  .ml-dot--r { background: #ff5f57; }
  .ml-dot--y { background: #ffbd2e; }
  .ml-dot--g { background: #28c840; }

  .ml-chrome-title {
    font-family: var(--sg57-font-mono, monospace);
    font-size: 0.75rem;
    color: var(--sg57-text-muted);
    letter-spacing: 0.08em;
    flex: 1;
    text-align: center;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .ml-chrome-sig {
    font-family: var(--sg57-font-mono, monospace);
    font-size: 0.7rem;
    color: var(--sg57-success);
    letter-spacing: 0.1em;
    flex-shrink: 0;
    animation: sig-pulse 2s ease-in-out infinite;
  }

  @keyframes sig-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .ml-chrome-body {
    padding: 1.25rem 1.5rem 1.75rem;
  }

  .ml-prompt-line {
    font-family: var(--sg57-font-mono, monospace);
    font-size: 0.875rem;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0;
    flex-wrap: wrap;
  }

  .ml-prompt { color: var(--sg57-success); font-weight: 700; }
  .ml-prompt-sep { color: var(--sg57-text-muted); }
  .ml-prompt-path { color: var(--sg57-accent); }
  .ml-prompt-dollar { color: var(--sg57-text-muted); margin: 0 0.35rem; }
  .ml-prompt-cmd { color: var(--sg57-text); }

  .ml-sys-info {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 2rem;
    margin-bottom: 1.5rem;
    padding: 0.75rem 1rem;
    background: rgba(0, 0, 0, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: var(--sg57-radius-md);
  }

  .ml-info-row {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .ml-info-label {
    font-family: var(--sg57-font-mono, monospace);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    color: var(--sg57-text-muted);
    text-transform: uppercase;
  }

  .ml-info-val {
    font-family: var(--sg57-font-mono, monospace);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--sg57-text);
  }

  .ml-status-ok { color: var(--sg57-success); }

  .ml-heading {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .ml-heading-label {
    font-family: var(--sg57-font-mono, monospace);
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 700;
    color: var(--sg57-accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .ml-heading-sub {
    font-family: var(--sg57-font-display);
    font-size: 1.125rem;
    font-weight: 400;
    color: var(--sg57-text-dim);
    letter-spacing: 0.02em;
  }

  /* ── Feed ── */
  .ml-feed {
    padding-top: 2rem;
    padding-bottom: 5rem;
  }

  .ml-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* ── Post card ── */
  .ml-card {
    display: block;
    padding: 1.25rem 1.5rem;
    border: 1px solid rgba(152, 142, 213, 0.18);
    border-radius: var(--sg57-radius-md);
    background: var(--sg57-glass-bg);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    text-decoration: none;
    transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.2s var(--sg57-ease-snap);
    position: relative;
    overflow: hidden;
  }

  /* scanline effect */
  .ml-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 3px,
      rgba(0, 0, 0, 0.04) 3px,
      rgba(0, 0, 0, 0.04) 4px
    );
    pointer-events: none;
    border-radius: inherit;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .ml-card:hover::before {
    opacity: 1;
  }

  .ml-card:hover {
    border-color: rgba(152, 142, 213, 0.55);
    box-shadow: 0 0 24px rgba(152, 142, 213, 0.12), 0 4px 16px rgba(0, 0, 0, 0.3);
    transform: translateY(-2px);
  }

  .ml-card:active {
    transform: translateY(0);
    opacity: 0.9;
  }

  .ml-card:focus-visible {
    outline: none;
    box-shadow: var(--sg57-focus-ring), 0 0 24px rgba(152, 142, 213, 0.2);
  }

  /* Latest post glows more */
  .ml-item--latest .ml-card {
    border-color: rgba(152, 142, 213, 0.35);
    box-shadow: 0 0 32px rgba(152, 142, 213, 0.1);
  }

  .ml-item--latest .ml-card:hover {
    border-color: rgba(152, 142, 213, 0.7);
    box-shadow: 0 0 48px rgba(152, 142, 213, 0.18);
  }

  /* ── Card parts ── */
  .ml-card-chrome {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .ml-tx-id {
    font-family: var(--sg57-font-mono, monospace);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--sg57-accent);
    background: rgba(152, 142, 213, 0.1);
    border: 1px solid rgba(152, 142, 213, 0.2);
    padding: 0.15rem 0.5rem;
    border-radius: var(--sg57-radius-sm);
  }

  .ml-badge-new {
    font-family: var(--sg57-font-mono, monospace);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--sg57-success);
    background: rgba(76, 175, 110, 0.12);
    border: 1px solid rgba(76, 175, 110, 0.3);
    padding: 0.15rem 0.5rem;
    border-radius: var(--sg57-radius-sm);
    animation: sig-pulse 2s ease-in-out infinite;
  }

  .ml-date {
    font-family: var(--sg57-font-mono, monospace);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--sg57-text-muted);
    margin-left: auto;
  }

  .ml-card-title {
    font-family: var(--sg57-font-display);
    font-size: clamp(1.1rem, 2.5vw, 1.375rem);
    font-weight: 700;
    color: var(--sg57-text);
    letter-spacing: 0.02em;
    line-height: 1.25;
    margin-bottom: 0.5rem;
    transition: color 0.2s ease;
  }

  .ml-card:hover .ml-card-title {
    color: var(--sg57-accent);
  }

  .ml-card-desc {
    font-family: var(--sg57-font-display);
    font-size: 1rem;
    color: var(--sg57-text-dim);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .ml-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .ml-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .ml-tag {
    font-family: var(--sg57-font-mono, monospace);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: var(--sg57-text-muted);
    padding: 0.1rem 0.35rem;
    border: 1px solid var(--sg57-border);
    border-radius: var(--sg57-radius-sm);
    background: var(--sg57-elevated);
  }

  .ml-read-more {
    font-family: var(--sg57-font-mono, monospace);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: var(--sg57-accent);
    opacity: 0;
    transition: opacity 0.2s ease, transform 0.2s ease;
    transform: translateX(-4px);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .ml-card:hover .ml-read-more {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── Empty state ── */
  .ml-empty {
    text-align: center;
    padding: 4rem 2rem;
    border: 1px dashed rgba(152, 142, 213, 0.2);
    border-radius: var(--sg57-radius-lg);
    color: var(--sg57-text-muted);
    font-family: var(--sg57-font-mono, monospace);
    font-size: 1rem;
  }

  .ml-empty-icon {
    display: block;
    font-size: 2rem;
    margin-bottom: 1rem;
    color: var(--sg57-accent);
    opacity: 0.4;
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .ml-sys-info {
      flex-direction: column;
      gap: 0.35rem;
    }

    .ml-card {
      padding: 1rem 1.125rem;
    }

    .ml-date {
      margin-left: 0;
    }

    .ml-read-more {
      display: none;
    }
  }
</style>
