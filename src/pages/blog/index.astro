---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const totalPosts = posts.length;
const lastUpdated = posts[0]?.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) ?? 'N/A';
const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();

const blogListSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'SG57 Labs Mission Log',
  description: 'Engineering notes, product announcements, case studies, and deep dives from SG57 Labs.',
  url: 'https://sg57.dev/blog',
  publisher: { '@type': 'Organization', name: 'SG57 Labs', url: 'https://sg57.dev' },
  blogPost: posts.map((p) => ({
    '@type': 'BlogPosting',
    headline: p.data.title,
    description: p.data.description,
    datePublished: p.data.date.toISOString(),
    url: `https://sg57.dev/blog/${p.id}`,
    author: { '@type': 'Person', name: p.data.author },
    keywords: p.data.tags.join(', '),
  })),
};
---

<Base
  title="Blog -- SG57 Labs Mission Log"
  description="Engineering notes, product announcements, client case studies, and deep dives from SG57 Labs. Clide, Siftr, Text Easy, and web services."
  jsonLd={blogListSchema}
>
  <div class="mission-log">

    <div class="starfield" aria-hidden="true">
      {Array.from({ length: 80 }).map((_, i) => (
        <span class="star" style={`--x:${Math.random()*100}%;--y:${Math.random()*100}%;--s:${(Math.random()*2+0.5).toFixed(1)}px;--d:${(Math.random()*8).toFixed(1)}s;--op:${(Math.random()*0.6+0.2).toFixed(2)}`}></span>
      ))}
    </div>

    <header class="ml-header container">
      <div class="ml-terminal-chrome">
        <div class="ml-chrome-bar" aria-hidden="true">
          <span class="ml-chrome-dots">
            <span class="ml-dot ml-dot--r"></span>
            <span class="ml-dot ml-dot--y"></span>
            <span class="ml-dot ml-dot--g"></span>
          </span>
          <span class="ml-chrome-title">sg57.dev / blog</span>
          <span class="ml-chrome-sig">LIVE</span>
        </div>
        <div class="ml-chrome-body">
          <h1 class="ml-heading">Mission Log</h1>
          <p class="ml-heading-sub">Engineering notes, case studies &amp; deep dives from SG57 Labs</p>
          <div class="ml-stats" aria-label="Blog statistics">
            <span class="ml-stat"><span class="ml-stat-val" id="js-visible-count">{totalPosts}</span> <span class="ml-stat-label">posts</span></span>
            <span class="ml-stat-sep" aria-hidden="true">·</span>
            <span class="ml-stat"><span class="ml-stat-label">Latest:</span> <span class="ml-stat-val">{lastUpdated}</span></span>
          </div>
        </div>
      </div>
    </header>

    <div class="ml-controls container">
      <div class="ml-search-wrap">
        <span class="ml-search-icon" aria-hidden="true">&#9906;</span>
        <input
          id="ml-search"
          type="search"
          placeholder="Search posts"
          class="ml-search"
          autocomplete="off"
          aria-label="Search blog posts"
        />
        <button id="ml-search-clear" class="ml-search-clear" aria-label="Clear search" hidden>x</button>
      </div>
      <button id="ml-sort" class="ml-sort-btn" aria-pressed="false" title="Sort order">
        <span class="ml-sort-icon" aria-hidden="true">v</span>
        <span class="ml-sort-label">Newest first</span>
      </button>
    </div>

    <div class="ml-tags-bar container" role="group" aria-label="Filter by tag">
      <button class="ml-chip ml-chip--all is-active" data-tag="">All</button>
      {allTags.map((tag) => (
        <button class="ml-chip" data-tag={tag}>#{tag}</button>
      ))}
    </div>

    <main class="ml-feed container" aria-live="polite">
      <ul class="ml-list" id="ml-list">
        {posts.map((post, idx) => {
          const txNum = (totalPosts - idx).toString().padStart(3, '0');
          const formattedDate = post.data.date.toLocaleDateString('en-US', {
            year: 'numeric', month: 'short', day: 'numeric',
          });
          return (
            <li
              class="ml-item"
              data-tags={post.data.tags.join(',')}
              data-ts={String(post.data.date.getTime())}
              data-title={post.data.title.toLowerCase()}
              data-desc={post.data.description.toLowerCase()}
            >
              <a href={`/blog/${post.id}`} class="ml-card">
                <div class="ml-card-chrome">
                  <span class="ml-tx-id">TX-{txNum}</span>
                  <div class="ml-tags">
                    {post.data.tags.map((tag) => (
                      <span class="ml-tag">#{tag}</span>
                    ))}
                  </div>
                  <time class="ml-date" datetime={post.data.date.toISOString()}>{formattedDate.toUpperCase()}</time>
                </div>
                <h2 class="ml-card-title">{post.data.title}</h2>
                <p class="ml-card-desc">{post.data.description}</p>
                <span class="ml-read-more" aria-hidden="true">Read post &rarr;</span>
              </a>
            </li>
          );
        })}
      </ul>

      <div class="ml-empty" id="ml-empty" hidden>
        <span class="ml-empty-icon" aria-hidden="true">&#9672;</span>
        <p>No posts match your search.</p>
        <button class="ml-empty-reset" id="ml-reset">Clear filters</button>
      </div>

      <nav class="ml-pagination" id="ml-pagination" aria-label="Blog pagination" hidden>
        <button class="ml-page-btn" id="ml-prev" aria-label="Previous page" disabled>&larr; Prev</button>
        <span class="ml-page-info" id="ml-page-info" aria-live="polite"></span>
        <button class="ml-page-btn" id="ml-next" aria-label="Next page">Next &rarr;</button>
      </nav>
    </main>

  </div>
</Base>

<script is:inline>
  var PER_PAGE = 12;
  var activeTag = '';
  var searchQuery = '';
  var sortDesc = true;
  var currentPage = 1;
  var searchTimer = null;

  var list = document.getElementById('ml-list');
  var emptyEl = document.getElementById('ml-empty');
  var pagination = document.getElementById('ml-pagination');
  var prevBtn = document.getElementById('ml-prev');
  var nextBtn = document.getElementById('ml-next');
  var pageInfo = document.getElementById('ml-page-info');
  var countEl = document.getElementById('js-visible-count');
  var searchInput = document.getElementById('ml-search');
  var clearBtn = document.getElementById('ml-search-clear');
  var sortBtn = document.getElementById('ml-sort');
  var sortLabel = sortBtn.querySelector('.ml-sort-label');
  var sortIcon = sortBtn.querySelector('.ml-sort-icon');
  var resetBtn = document.getElementById('ml-reset');
  var chips = document.querySelectorAll('.ml-chip');
  var allItems = Array.from(list.querySelectorAll('.ml-item'));

  function itemMatches(item) {
    var tags = (item.getAttribute('data-tags') || '').split(',');
    if (activeTag && tags.indexOf(activeTag) === -1) return false;
    if (searchQuery) {
      var words = searchQuery.toLowerCase().split(/\s+/).filter(Boolean);
      var haystack = (item.getAttribute('data-title') || '') + ' ' + (item.getAttribute('data-desc') || '');
      for (var wi = 0; wi < words.length; wi++) {
        if (haystack.indexOf(words[wi]) === -1) return false;
      }
    }
    return true;
  }

  function render() {
    var visible = allItems.filter(itemMatches);
    visible.sort(function(a, b) {
      var da = parseInt(a.getAttribute('data-ts') || '0', 10);
      var db = parseInt(b.getAttribute('data-ts') || '0', 10);
      return sortDesc ? db - da : da - db;
    });
    var totalPages = Math.max(1, Math.ceil(visible.length / PER_PAGE));
    if (currentPage > totalPages) currentPage = totalPages;
    var start = (currentPage - 1) * PER_PAGE;
    var pageSet = {};
    for (var pi = start; pi < start + PER_PAGE && pi < visible.length; pi++) {
      pageSet[pi - start] = visible[pi];
    }
    var pageItems = [];
    for (var k in pageSet) pageItems.push(pageSet[k]);

    allItems.forEach(function(item) { item.hidden = pageItems.indexOf(item) === -1; });
    emptyEl.hidden = visible.length > 0;
    countEl.textContent = String(visible.length);
    if (totalPages > 1) {
      pagination.hidden = false;
      pageInfo.textContent = 'Page ' + currentPage + ' of ' + totalPages;
      prevBtn.disabled = currentPage === 1;
      nextBtn.disabled = currentPage === totalPages;
    } else {
      pagination.hidden = true;
    }
  }

  searchInput.addEventListener('input', function() {
    searchQuery = searchInput.value.toLowerCase();
    clearBtn.hidden = !searchQuery;
    clearTimeout(searchTimer);
    searchTimer = setTimeout(function() { currentPage = 1; render(); }, 150);
  });

  clearBtn.addEventListener('click', function() {
    searchInput.value = '';
    searchQuery = '';
    clearBtn.hidden = true;
    currentPage = 1; render();
    searchInput.focus();
  });

  chips.forEach(function(chip) {
    chip.addEventListener('click', function() {
      activeTag = chip.getAttribute('data-tag') || '';
      chips.forEach(function(c) { c.classList.toggle('is-active', c === chip); });
      currentPage = 1; render();
    });
  });

  sortBtn.addEventListener('click', function() {
    sortDesc = !sortDesc;
    sortLabel.textContent = sortDesc ? 'Newest first' : 'Oldest first';
    sortIcon.textContent = sortDesc ? 'v' : '^';
    currentPage = 1; render();
  });

  prevBtn.addEventListener('click', function() { currentPage--; render(); window.scrollTo({top:0,behavior:'smooth'}); });
  nextBtn.addEventListener('click', function() { currentPage++; render(); window.scrollTo({top:0,behavior:'smooth'}); });

  resetBtn.addEventListener('click', function() {
    searchInput.value = ''; searchQuery = ''; clearBtn.hidden = true;
    activeTag = '';
    chips.forEach(function(c) { c.classList.toggle('is-active', (c.getAttribute('data-tag') || '') === ''); });
    currentPage = 1; render();
  });

  render();
</script>

<style>
  .mission-log {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
  }

  .starfield {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .star {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: var(--s);
    height: var(--s);
    background: #fff;
    border-radius: 50%;
    opacity: var(--op);
    animation: star-twinkle var(--d, 4s) ease-in-out infinite alternate;
  }

  @keyframes star-twinkle {
    0%   { opacity: var(--op); transform: scale(1); }
    100% { opacity: calc(var(--op) * 0.3); transform: scale(0.6); }
  }

  .mission-log .container {
    position: relative;
    z-index: 1;
    max-width: 800px;
  }

  .ml-header {
    padding-top: 3rem;
    padding-bottom: 0;
  }

  .ml-terminal-chrome {
    border: 1px solid rgba(152, 142, 213, 0.3);
    border-radius: var(--sg57-radius-lg);
    overflow: hidden;
    box-shadow: 0 0 40px rgba(152, 142, 213, 0.08), 0 0 80px rgba(152, 142, 213, 0.04);
    background: var(--sg57-glass-bg);
    backdrop-filter: blur(var(--sg57-glass-blur));
    -webkit-backdrop-filter: blur(var(--sg57-glass-blur));
  }

  .ml-chrome-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 1rem;
    background: rgba(26, 28, 40, 0.9);
    border-bottom: 1px solid rgba(152, 142, 213, 0.15);
  }

  .ml-chrome-dots { display: flex; gap: 6px; flex-shrink: 0; }
  .ml-dot { width: 12px; height: 12px; border-radius: 50%; }
  .ml-dot--r { background: #ff5f57; }
  .ml-dot--y { background: #ffbd2e; }
  .ml-dot--g { background: #28c840; }

  .ml-chrome-title {
    font-family: var(--sg57-font-mono, monospace);
    font-size: 0.75rem;
    color: var(--sg57-text-muted);
    letter-spacing: 0.08em;
    flex: 1;
    text-align: center;
  }

  .ml-chrome-sig {
    font-family: var(--sg57-font-mono, monospace);
    font-size: 0.65rem;
    color: var(--sg57-success);
    letter-spacing: 0.12em;
    flex-shrink: 0;
    animation: sig-pulse 2s ease-in-out infinite;
  }

  @keyframes sig-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .ml-chrome-body {
    padding: 1.5rem 1.75rem 1.75rem;
  }

  .ml-heading {
    font-family: var(--sg57-font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--sg57-text);
    letter-spacing: 0.04em;
    margin-bottom: 0.35rem;
  }

  .ml-heading-sub {
    font-family: var(--sg57-font-display);
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--sg57-text-dim);
    margin-bottom: 1rem;
    line-height: 1.5;
  }

  .ml-stats {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .ml-stat { display: flex; align-items: center; gap: 0.3rem; }

  .ml-stat-val {
    font-family: var(--sg57-font-mono, monospace);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--sg57-accent);
  }

  .ml-stat-label {
    font-family: var(--sg57-font-mono, monospace);
    font-size: 0.8rem;
    color: var(--sg57-text-muted);
  }

  .ml-stat-sep { color: var(--sg57-border); font-size: 0.875rem; }

  /* Controls */
  .ml-controls {
    padding-top: 1.5rem;
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .ml-search-wrap {
    flex: 1;
    position: relative;
    display: flex;
    align-items: center;
  }

  .ml-search-icon {
    position: absolute;
    left: 0.75rem;
    color: var(--sg57-text-muted);
    font-size: 1rem;
    pointer-events: none;
    line-height: 1;
  }

  .ml-search {
    width: 100%;
    padding: 0.6rem 2.25rem 0.6rem 2.25rem;
    background: var(--sg57-elevated);
    border: 1px solid var(--sg57-border);
    border-radius: var(--sg57-radius-md);
    color: var(--sg57-text);
    font-family: var(--sg57-font-display);
    font-size: 1rem;
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    -webkit-appearance: none;
  }

  .ml-search::placeholder { color: var(--sg57-text-muted); }

  .ml-search:focus {
    border-color: rgba(152, 142, 213, 0.5);
    box-shadow: 0 0 0 3px rgba(152, 142, 213, 0.1);
  }

  .ml-search::-webkit-search-cancel-button { display: none; }

  .ml-search-clear {
    position: absolute;
    right: 0.6rem;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--sg57-text-muted);
    font-size: 0.75rem;
    border-radius: var(--sg57-radius-sm);
    transition: color 0.2s ease;
  }

  .ml-search-clear:hover { color: var(--sg57-text); }

  .ml-sort-btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 0.9rem;
    background: var(--sg57-elevated);
    border: 1px solid var(--sg57-border);
    border-radius: var(--sg57-radius-md);
    color: var(--sg57-text-dim);
    font-family: var(--sg57-font-mono, monospace);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    cursor: pointer;
    white-space: nowrap;
    transition: border-color 0.2s ease, color 0.2s ease;
    flex-shrink: 0;
    min-height: 40px;
  }

  .ml-sort-btn:hover {
    border-color: rgba(152, 142, 213, 0.4);
    color: var(--sg57-accent);
  }

  .ml-sort-btn:focus-visible {
    outline: none;
    box-shadow: var(--sg57-focus-ring);
  }

  .ml-sort-icon {
    font-size: 0.85rem;
    line-height: 1;
    font-weight: 700;
  }

  /* Tag chips */
  .ml-tags-bar {
    padding-top: 0.875rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .ml-chip {
    font-family: var(--sg57-font-mono, monospace);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    padding: 0.25rem 0.65rem;
    background: var(--sg57-elevated);
    border: 1px solid var(--sg57-border);
    border-radius: var(--sg57-radius-full);
    color: var(--sg57-text-muted);
    cursor: pointer;
    transition: border-color 0.18s ease, color 0.18s ease, background 0.18s ease;
    white-space: nowrap;
    min-height: 28px;
    line-height: 1;
    display: inline-flex;
    align-items: center;
  }

  .ml-chip:hover {
    border-color: rgba(152, 142, 213, 0.45);
    color: var(--sg57-accent);
  }

  .ml-chip.is-active {
    background: rgba(152, 142, 213, 0.12);
    border-color: rgba(152, 142, 213, 0.5);
    color: var(--sg57-accent);
  }

  .ml-chip:focus-visible {
    outline: none;
    box-shadow: var(--sg57-focus-ring);
  }

  /* Feed */
  .ml-feed {
    padding-top: 1.5rem;
    padding-bottom: 5rem;
  }

  .ml-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Post card */
  .ml-card {
    display: block;
    padding: 1.25rem 1.5rem;
    border: 1px solid rgba(152, 142, 213, 0.18);
    border-radius: var(--sg57-radius-md);
    background: var(--sg57-glass-bg);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    text-decoration: none;
    transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.2s var(--sg57-ease-snap);
    position: relative;
    overflow: hidden;
  }

  .ml-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent, transparent 3px,
      rgba(0,0,0,0.04) 3px, rgba(0,0,0,0.04) 4px
    );
    pointer-events: none;
    border-radius: inherit;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .ml-card:hover::before { opacity: 1; }

  .ml-card:hover {
    border-color: rgba(152, 142, 213, 0.55);
    box-shadow: 0 0 24px rgba(152, 142, 213, 0.12), 0 4px 16px rgba(0,0,0,0.3);
    transform: translateY(-2px);
  }

  .ml-card:active { transform: translateY(0); opacity: 0.9; }

  .ml-card:focus-visible {
    outline: none;
    box-shadow: var(--sg57-focus-ring), 0 0 24px rgba(152, 142, 213, 0.2);
  }

  .ml-card-chrome {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .ml-tx-id {
    font-family: var(--sg57-font-mono, monospace);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--sg57-accent);
    background: rgba(152, 142, 213, 0.1);
    border: 1px solid rgba(152, 142, 213, 0.2);
    padding: 0.15rem 0.45rem;
    border-radius: var(--sg57-radius-sm);
    flex-shrink: 0;
  }

  .ml-tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
    flex: 1;
  }

  .ml-tag {
    font-family: var(--sg57-font-mono, monospace);
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    color: var(--sg57-text-muted);
    padding: 0.1rem 0.35rem;
    border: 1px solid var(--sg57-border);
    border-radius: var(--sg57-radius-sm);
    background: var(--sg57-elevated);
  }

  .ml-date {
    font-family: var(--sg57-font-mono, monospace);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    color: var(--sg57-text-muted);
    margin-left: auto;
    flex-shrink: 0;
  }

  .ml-card-title {
    font-family: var(--sg57-font-display);
    font-size: clamp(1.05rem, 2.5vw, 1.3rem);
    font-weight: 700;
    color: var(--sg57-text);
    letter-spacing: 0.02em;
    line-height: 1.25;
    margin-bottom: 0.45rem;
    transition: color 0.2s ease;
  }

  .ml-card:hover .ml-card-title { color: var(--sg57-accent); }

  .ml-card-desc {
    font-family: var(--sg57-font-display);
    font-size: 0.975rem;
    color: var(--sg57-text-dim);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .ml-read-more {
    font-family: var(--sg57-font-mono, monospace);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--sg57-accent);
    opacity: 0;
    transition: opacity 0.2s ease, transform 0.2s ease;
    transform: translateX(-4px);
    display: inline-block;
  }

  .ml-card:hover .ml-read-more { opacity: 1; transform: translateX(0); }

  /* Empty state */
  .ml-empty[hidden] { display: none; }
  .ml-empty {
    text-align: center;
    padding: 3rem 2rem;
    border: 1px dashed rgba(152, 142, 213, 0.2);
    border-radius: var(--sg57-radius-lg);
    color: var(--sg57-text-muted);
    font-family: var(--sg57-font-mono, monospace);
    font-size: 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .ml-empty-icon { font-size: 2rem; color: var(--sg57-accent); opacity: 0.4; }

  .ml-empty-reset {
    font-family: var(--sg57-font-mono, monospace);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    padding: 0.4rem 1rem;
    background: rgba(152, 142, 213, 0.08);
    border: 1px solid rgba(152, 142, 213, 0.3);
    border-radius: var(--sg57-radius-md);
    color: var(--sg57-accent);
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .ml-empty-reset:hover { background: rgba(152, 142, 213, 0.15); }

  /* Pagination */
  .ml-pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--sg57-border);
