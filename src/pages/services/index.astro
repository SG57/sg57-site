---
import Base from '../../layouts/Base.astro';
import DigitalHealthQuiz from '../../components/services/DigitalHealthQuiz.astro';
---

<Base
  title="Services — SG57 Labs"
  description="Brand systems, websites, and digital infrastructure for businesses that refuse to be invisible. Start with a free 2-minute health check."
  accentColor="#C4896A"
  accentHover="#D49A7A"
  accentMuted="#A87558"
  accentGlow="rgba(196, 137, 106, 0.15)"
>

  <!-- ══════════════════════════════════════════════════════════════════════════
       §1 HERO
       ══════════════════════════════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-scanlines"></div>
      <div class="hero-glow"></div>
    </div>
    <div class="hero-content container">
      <div class="hero-eyebrow">
        <span class="eyebrow-bracket" aria-hidden="true">[</span>
        <span class="eyebrow-glyph" aria-hidden="true">◆</span>
        <span class="eyebrow-label">SG57 LABS // SERVICES</span>
        <span class="eyebrow-bracket" aria-hidden="true">]</span>
      </div>
      <h1 class="hero-title">
        YOUR DIGITAL PRESENCE<br/>
        IS EITHER WORKING FOR YOU<br/>
        <span class="hero-title-accent">— OR AGAINST YOU.</span>
      </h1>
      <p class="hero-sub">Eight questions. Two minutes. Find out exactly where you stand.</p>
      <a href="#health-check" class="hero-cta">
        Start the Free Check
        <span class="hero-cta-arrow" aria-hidden="true">↓</span>
      </a>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════════════════
       §2 DIGITAL HEALTH CHECK (QUIZ)
       ══════════════════════════════════════════════════════════════════════════ -->
  <section class="quiz-section container" id="health-check" aria-labelledby="quiz-section-heading">
    <div class="quiz-section-header">
      <h2 class="section-label" id="quiz-section-heading">THE 2-MINUTE AUDIT</h2>
      <p class="quiz-section-sub">Honest questions. No fluff. A real signal.</p>
    </div>
    <DigitalHealthQuiz />
  </section>

  <!-- ══════════════════════════════════════════════════════════════════════════
       §3 CAPABILITIES
       ══════════════════════════════════════════════════════════════════════════ -->
  <section class="capabilities container" aria-labelledby="capabilities-heading">
    <div class="capabilities-header">
      <h2 class="capabilities-eyebrow" id="capabilities-heading">WHAT WE DO</h2>
      <p class="capabilities-deck">
        Full-spectrum digital execution. Strategy → identity → build → ship.
      </p>
    </div>

    <div class="cap-grid">

      <!-- Brand Systems -->
      <div class="cap-card cap-card--brand">
        <div class="cap-glyph" aria-hidden="true">◈</div>
        <div class="cap-card-body">
          <h3 class="cap-name">BRAND SYSTEMS</h3>
          <p class="cap-tagline">Identities that outlast trends.</p>
          <ul class="cap-list">
            <li>Brand constitution &amp; positioning</li>
            <li>Visual identity &amp; design token architecture</li>
            <li>Brand bible &amp; usage guidelines</li>
            <li>Voice, tone &amp; messaging framework</li>
          </ul>
        </div>
      </div>

      <!-- Web Engineering -->
      <div class="cap-card cap-card--web">
        <div class="cap-glyph" aria-hidden="true">⟐</div>
        <div class="cap-card-body">
          <h3 class="cap-name">WEB ENGINEERING</h3>
          <p class="cap-tagline">Sites that convert, not just impress.</p>
          <ul class="cap-list">
            <li>Custom static &amp; full-stack builds</li>
            <li>Performance-first architecture</li>
            <li>Mobile-first, WCAG-accessible</li>
            <li>CMS integration &amp; content systems</li>
          </ul>
        </div>
      </div>

      <!-- Digital Infrastructure -->
      <div class="cap-card cap-card--infra">
        <div class="cap-glyph" aria-hidden="true">▣</div>
        <div class="cap-card-body">
          <h3 class="cap-name">DIGITAL INFRASTRUCTURE</h3>
          <p class="cap-tagline">The invisible machinery of growth.</p>
          <ul class="cap-list">
            <li>Domain &amp; hosting optimization</li>
            <li>Professional email infrastructure</li>
            <li>Analytics &amp; tracking setup</li>
            <li>SEO foundations &amp; structured data</li>
          </ul>
        </div>
      </div>

      <!-- Product Development -->
      <div class="cap-card cap-card--product">
        <div class="cap-glyph" aria-hidden="true">◉</div>
        <div class="cap-card-body">
          <h3 class="cap-name">PRODUCT DEVELOPMENT</h3>
          <p class="cap-tagline">From idea to production software.</p>
          <ul class="cap-list">
            <li>Full-stack SaaS &amp; web apps</li>
            <li>Mobile application development</li>
            <li>API design &amp; third-party integration</li>
            <li>MVP scaffolding &amp; architecture</li>
          </ul>
        </div>
      </div>

      <!-- Automation & AI -->
      <div class="cap-card cap-card--ai">
        <div class="cap-glyph" aria-hidden="true">⌬</div>
        <div class="cap-card-body">
          <h3 class="cap-name">AUTOMATION &amp; AI</h3>
          <p class="cap-tagline">Intelligence wired into your workflow.</p>
          <ul class="cap-list">
            <li>Custom AI-powered workflows</li>
            <li>LLM integration &amp; prompt engineering</li>
            <li>Process &amp; communications automation</li>
            <li>Intelligent feature development</li>
          </ul>
        </div>
      </div>

      <!-- Growth Architecture -->
      <div class="cap-card cap-card--growth">
        <div class="cap-glyph" aria-hidden="true">⊕</div>
        <div class="cap-card-body">
          <h3 class="cap-name">GROWTH ARCHITECTURE</h3>
          <p class="cap-tagline">Systems that compound over time.</p>
          <ul class="cap-list">
            <li>Social presence architecture</li>
            <li>Email marketing infrastructure</li>
            <li>Content &amp; publishing systems</li>
            <li>Launch campaign strategy</li>
          </ul>
        </div>
      </div>

    </div><!-- /cap-grid -->
  </section>

  <!-- ══════════════════════════════════════════════════════════════════════════
       §4 PROOF OF WORK — DANIELLE
       ══════════════════════════════════════════════════════════════════════════ -->
  <section class="proof container" aria-labelledby="proof-heading">
    <h2 class="section-label" id="proof-heading">PROOF OF WORK</h2>

    <div class="proof-card">

      <div class="proof-card-header">
        <div class="proof-meta">
          <span class="proof-client-tag">Client</span>
          <h3 class="proof-client-name">Staples &amp; Statements</h3>
          <p class="proof-client-type">Wardrobe Stylist &mdash; Personal Brand</p>
        </div>
        <div class="proof-delta">
          <div class="delta-item">
            <span class="delta-before">Before</span>
            <span class="delta-arrow" aria-hidden="true">→</span>
            <span class="delta-after">After</span>
          </div>
          <div class="delta-descriptor">Zero digital identity → Complete brand ecosystem</div>
        </div>
      </div>

      <div class="proof-narrative">
        <p>
          Danielle had built something real. A styling business growing on talent and word of mouth — genuine
          clients who referred her because she was that good. But when someone asked for her website, she cringed.
        </p>
        <p>
          A decade of expertise, represented by nothing.
        </p>
        <p>
          We started with discovery — who she was, who she served, how she spoke. From that came a brand
          constitution: the law of her business. Then a full visual identity, a design token system, a website
          built to convert, professional email infrastructure, and the social architecture to support what
          she&rsquo;d already built.
        </p>
        <p class="proof-result-line">
          The result is <strong>staplesandstatements.com</strong> — a digital presence that finally matches the
          caliber of her work.
        </p>
      </div>

      <div class="proof-deliverables">
        <h4 class="proof-dl-label">What Was Built</h4>
        <ul class="proof-dl-list">
          <li>Brand Constitution &amp; Positioning</li>
          <li>Complete Brand Bible</li>
          <li>Design Token System</li>
          <li>Production Website</li>
          <li>Email Infrastructure</li>
          <li>Social Template System</li>
        </ul>
      </div>

      <div class="proof-testimonial">
        <blockquote>
          <p class="testimonial-text testimonial-pending">Testimonial incoming &mdash; watch this space.</p>
        </blockquote>
      </div>

      <div class="proof-card-footer">
        <a
          href="https://staplesandstatements.com"
          class="proof-link"
          target="_blank"
          rel="noopener noreferrer"
        >
          View Live Site: staplesandstatements.com <span aria-hidden="true">→</span>
        </a>
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════════════════
       §5 TIER 3 / BIG FISH CTA
       ══════════════════════════════════════════════════════════════════════════ -->
  <section class="bigfish" aria-labelledby="bigfish-heading">
    <div class="container">
      <div class="bigfish-inner">
        <div class="bigfish-tag" aria-hidden="true">
          <span class="bf-bracket">[</span>
          <span class="bf-glyph">◉</span>
          <span class="bf-bracket">]</span>
          <span class="bf-label">CUSTOM DEVELOPMENT</span>
        </div>
        <h2 class="bigfish-headline" id="bigfish-heading">
          Building something bigger?
        </h2>
        <p class="bigfish-body">
          Custom SaaS platforms. Mobile applications. Complex product architectures.
          If you&rsquo;re building a real product, we need a different conversation than
          a brand package can accommodate.
        </p>
        <p class="bigfish-body">
          Tell us what you&rsquo;re building. We&rsquo;ll tell you if we&rsquo;re the right fit.
        </p>
        <a href="#intake-form" class="bigfish-cta">
          Send Me the Brief <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════════════════
       §6 INTAKE FORM
       ══════════════════════════════════════════════════════════════════════════ -->
  <section class="intake container" id="intake-form" aria-labelledby="intake-heading">
    <h2 class="section-label" id="intake-heading">START THE CONVERSATION</h2>
    <p class="intake-deck">
      We&rsquo;ll review your situation and follow up within 24 hours.
      No pitch, no pressure — just a real conversation about what you&rsquo;re building.
    </p>

    <div class="intake-card">
      <!--
        FORMSPREE SETUP:
        1. Go to https://formspree.io and sign in (or create an account).
        2. Create a new form — name it "SG57 Services Intake".
        3. Set the notification email to consult@sg57.dev.
        4. Copy your form's endpoint (looks like: https://formspree.io/f/xxxxxxxx).
        5. Replace the action URL below with your endpoint.
      -->
      <form
        class="intake-form"
        id="sg57-intake-form"
        aria-label="Services inquiry form"
        novalidate
      >
        <!-- Formspree honeypot (spam protection) -->
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" aria-hidden="true" />
        <!-- Subject line in email -->
        <input type="hidden" name="_subject" value="New Inquiry — SG57 Services" />

        <div class="form-row form-row--two">
          <div class="form-field">
            <label for="if-name" class="form-label">Your Name <span class="form-required" aria-label="required">*</span></label>
            <input
              type="text"
              id="if-name"
              name="name"
              class="form-input"
              required
              autocomplete="name"
              placeholder="Danielle Diaz"
            />
          </div>
          <div class="form-field">
            <label for="if-email" class="form-label">Email Address <span class="form-required" aria-label="required">*</span></label>
            <input
              type="email"
              id="if-email"
              name="email"
              class="form-input"
              required
              autocomplete="email"
              placeholder="you@yourbusiness.com"
            />
          </div>
        </div>

        <div class="form-row form-row--two">
          <div class="form-field">
            <label for="if-business" class="form-label">Business / Project Name <span class="form-required" aria-label="required">*</span></label>
            <input
              type="text"
              id="if-business"
              name="business"
              class="form-input"
              required
              placeholder="Staples &amp; Statements"
            />
          </div>
          <div class="form-field">
            <label for="if-website" class="form-label">Current Website <span class="form-optional">(if any)</span></label>
            <input
              type="url"
              id="if-website"
              name="website"
              class="form-input"
              autocomplete="url"
              placeholder="https://yoursite.com"
            />
          </div>
        </div>

        <div class="form-row">
          <div class="form-field">
            <label for="if-challenge" class="form-label">What&rsquo;s your biggest digital challenge right now? <span class="form-required" aria-label="required">*</span></label>
            <textarea
              id="if-challenge"
              name="challenge"
              class="form-input form-textarea"
              required
              rows="4"
              placeholder="Tell us what's not working — or what you're trying to build."
            ></textarea>
          </div>
        </div>

        <div class="form-row form-row--two">
          <div class="form-field">
            <label for="if-source" class="form-label">How did you hear about SG57?</label>
            <select id="if-source" name="source" class="form-input form-select">
              <option value="" disabled selected>Select one…</option>
              <option value="referral">Referral / Word of mouth</option>
              <option value="google">Google search</option>
              <option value="linkedin">LinkedIn</option>
              <option value="twitter">X / Twitter</option>
              <option value="github">GitHub</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="form-field form-field--submit">
            <button type="submit" class="form-submit">
              Send My Brief <span aria-hidden="true">→</span>
            </button>
          </div>
        </div>

      </form>

      <!-- Error message -->
      <div class="intake-error hidden" id="intake-error" role="alert" aria-live="polite">
        <p class="intake-error-text">Something went wrong — please try again or email us directly at <a href="mailto:consult@sg57.dev">consult@sg57.dev</a>.</p>
      </div>

      <!-- Success message -->
      <div class="intake-success hidden" id="intake-success" role="alert" aria-live="polite">
        <div class="success-glyph" aria-hidden="true">◆</div>
        <h3 class="success-headline">Brief received.</h3>
        <p class="success-body">We&rsquo;ll review your situation and follow up within 24 hours.</p>
      </div>

    </div><!-- /intake-card -->
  </section>

</Base>

<script>
  document.addEventListener('astro:page-load', () => {
    const form    = document.getElementById('sg57-intake-form');
    const success = document.getElementById('intake-success');
    const error   = document.getElementById('intake-error');
    const submit  = form?.querySelector('.form-submit');
    if (!form) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Basic HTML5 validation
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      // Loading state
      submit.disabled = true;
      submit.textContent = 'Sending…';
      error.classList.add('hidden');

      try {
        const res = await fetch('https://formspree.io/f/mojkpkyj', {
          method: 'POST',
          body: new FormData(form),
          headers: { 'Accept': 'application/json' },
        });

        if (res.ok) {
          form.classList.add('hidden');
          error.classList.add('hidden');
          success.classList.remove('hidden');
          success.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else {
          throw new Error('non-200');
        }
      } catch {
        submit.disabled = false;
        submit.innerHTML = 'Send My Brief <span aria-hidden="true">→</span>';
        error.classList.remove('hidden');
      }
    });
  });
</script>

<style>
  /* Accent scope — matches Base.astro prop values */
  :root {
    --svc-accent:       #C4896A;
    --svc-accent-hover: #D49A7A;
    --svc-accent-muted: #A87558;
    --svc-accent-glow:  rgba(196, 137, 106, 0.15);
  }

  /* ── §1 HERO ─────────────────────────────────────────────────────────────── */

  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 70vh;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(196, 137, 106, 0.025) 2px,
      rgba(196, 137, 106, 0.025) 4px
    );
  }

  .hero-glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 30%, rgba(196, 137, 106, 0.12) 0%, transparent 70%),
      radial-gradient(ellipse 40% 30% at 50% 0%, rgba(196, 137, 106, 0.06) 0%, transparent 60%);
  }

  .hero-content {
    position: relative;
    text-align: center;
    padding: 6rem 1.5rem 5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 2rem;
    animation: fade-in 0.9s 0.1s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .eyebrow-bracket {
    font-family: var(--sg57-font-display);
    font-weight: 200;
    font-size: 1.1rem;
    color: var(--sg57-accent-muted);
    opacity: 0.55;
  }

  .eyebrow-glyph {
    font-size: 0.65rem;
    color: var(--sg57-accent);
    animation: pulse-glow 4s ease-in-out infinite;
  }

  .eyebrow-label {
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 0.68rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--sg57-accent);
  }

  .hero-title {
    font-family: var(--sg57-font-display);
    font-weight: 800;
    font-size: clamp(1.8rem, 5.5vw, 3.6rem);
    color: #ffffff;
    letter-spacing: 0.04em;
    line-height: 1.15;
    margin-bottom: 1.5rem;
    animation: slide-up 1.0s 0.2s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .hero-title-accent {
    color: var(--sg57-accent);
  }

  .hero-sub {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: clamp(0.9rem, 1.8vw, 1.1rem);
    color: var(--sg57-text-dim);
    letter-spacing: 0.04em;
    margin-bottom: 2.5rem;
    animation: slide-up 1.0s 0.35s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: #ffffff;
    background: var(--sg57-accent);
    padding: 0.85rem 2.25rem;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.2s ease, box-shadow 0.2s ease, gap 0.2s ease;
    animation: slide-up 1.0s 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .hero-cta:hover {
    background: var(--sg57-accent-hover);
    box-shadow: 0 0 28px var(--sg57-accent-glow);
    gap: 0.85rem;
    color: #ffffff;
  }

  .hero-cta-arrow {
    font-size: 1.1rem;
    transition: transform 0.2s ease;
  }

  .hero-cta:hover .hero-cta-arrow {
    transform: translateY(3px);
  }

  /* ── §2 QUIZ SECTION ─────────────────────────────────────────────────────── */

  .quiz-section {
    padding: 4rem 1.5rem 5rem;
  }

  .quiz-section-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .quiz-section-sub {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: 0.92rem;
    color: var(--sg57-text-dim);
    letter-spacing: 0.04em;
    margin-top: 0.5rem;
  }

  /* ── §3 CAPABILITIES ─────────────────────────────────────────────────────── */

  .capabilities {
    padding: 2rem 1.5rem 6rem;
  }

  .capabilities-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .capabilities-eyebrow {
    font-family: var(--sg57-font-display);
    font-weight: 800;
    font-size: clamp(2rem, 6vw, 4.5rem);
    letter-spacing: 0.12em;
    color: #ffffff;
    line-height: 1;
    margin-bottom: 1rem;
  }

  .capabilities-deck {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: clamp(0.9rem, 1.6vw, 1rem);
    color: var(--sg57-text-dim);
    letter-spacing: 0.06em;
  }

  .cap-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    border: 1px solid var(--sg57-border);
    border-radius: 10px;
    overflow: hidden;
    background: var(--sg57-border); /* gap color = border lines */
  }

  .cap-card {
    display: flex;
    flex-direction: column;
    padding: 2.25rem 2rem;
    background: rgba(10, 10, 18, 0.85);
    transition: background 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .cap-card::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .cap-card:hover {
    background: rgba(15, 15, 25, 0.95);
  }

  .cap-card:hover::before {
    opacity: 1;
  }

  /* Per-card accent overlays */
  .cap-card--brand::before  { background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(196,137,106,0.08) 0%, transparent 70%); }
  .cap-card--web::before    { background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(91,192,190,0.08) 0%, transparent 70%); }
  .cap-card--infra::before  { background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(120,150,200,0.08) 0%, transparent 70%); }
  .cap-card--product::before{ background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(196,137,106,0.08) 0%, transparent 70%); }
  .cap-card--ai::before     { background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(180,120,220,0.08) 0%, transparent 70%); }
  .cap-card--growth::before { background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(91,192,100,0.07) 0%, transparent 70%); }

  .cap-glyph {
    font-size: 2.25rem;
    line-height: 1;
    margin-bottom: 1.25rem;
    color: var(--sg57-accent);
    transition: transform 0.3s ease, filter 0.3s ease;
  }

  /* Per-card glyph colors */
  .cap-card--web    .cap-glyph  { color: #5BC0BE; }
  .cap-card--infra  .cap-glyph  { color: #8ab0d8; }
  .cap-card--ai     .cap-glyph  { color: #c07fe0; }
  .cap-card--growth .cap-glyph  { color: #6adc7e; }

  .cap-card:hover .cap-glyph {
    transform: scale(1.1) translateY(-2px);
    filter: drop-shadow(0 0 12px currentColor);
  }

  .cap-card-body {
