---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Brand DNA Consulting — SG57 Labs"
  description="From rough web presence to complete brand identity. Constitution, bible, design tokens, website — the full ecosystem, built once, right."
  accentColor="#C4896A"
  accentHover="#D49A7A"
  accentMuted="#A87558"
  accentGlow="rgba(196, 137, 106, 0.15)"
>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-content container">
      <div class="service-mark">
        <span class="mark-bracket">[</span>
        <span class="mark-glyph">&#9670;</span>
        <span class="mark-bracket">]</span>
      </div>
      <h1 class="hero-title">
        <span class="accent">BRAND DNA //</span> CONSULTING
      </h1>
      <p class="hero-tagline">From rough presence to complete brand identity.</p>
      <p class="hero-subtitle">Constitution, bible, design tokens, website &mdash; the full ecosystem, built once, right.</p>
      <a href="mailto:consult@sg57.dev" class="cta-button">
        Book a Consultation &rarr;
      </a>
    </div>
  </section>

  <!-- Problem Statement -->
  <section class="problem container">
    <p class="problem-text">
      You have a business. Maybe a logo. Maybe a WordPress site from 2019.
      But when a client asks for your brand guidelines, you send a PDF with your logo on it.
      <strong>That&rsquo;s not a brand. We build the real thing.</strong>
    </p>
  </section>

  <!-- Deliverables -->
  <section class="deliverables container">
    <h2 class="section-heading">What You Get</h2>
    <div class="deliverables-grid">

      <div class="deliverable-card">
        <div class="feature-icon">&#9670;</div>
        <h3 class="feature-heading">Brand Constitution</h3>
        <p class="feature-desc">
          The federal law of your brand. Mission, values, voice, audience, positioning.
          Non-negotiable. Everything downstream references it.
        </p>
      </div>

      <div class="deliverable-card">
        <div class="feature-icon">&#8801;</div>
        <h3 class="feature-heading">Brand Bible</h3>
        <p class="feature-desc">
          Complete visual identity guide. Typography hierarchy, color system, photography
          direction, application rules, what to do and what never to do.
        </p>
      </div>

      <div class="deliverable-card">
        <div class="feature-icon">&#9881;</div>
        <h3 class="feature-heading">Design Tokens</h3>
        <p class="feature-desc">
          Machine-readable design system. CSS custom properties encoding every color,
          spacing, radius, and animation from your brand bible. Plug into any project.
        </p>
      </div>

      <div class="deliverable-card">
        <div class="feature-icon">&#9673;</div>
        <h3 class="feature-heading">Website</h3>
        <p class="feature-desc">
          Full production web presence built on your design tokens. Fast, accessible,
          built to last &mdash; not a template, not a page builder.
        </p>
      </div>

      <div class="deliverable-card">
        <div class="feature-icon">&#9651;</div>
        <h3 class="feature-heading">App Foundation</h3>
        <p class="feature-desc">
          Technical scaffold for future software. Your brand DNA wired in from day one.
          Repository setup, CI/CD, hosting &mdash; production-ready from the first commit.
        </p>
      </div>

      <div class="deliverable-card">
        <div class="feature-icon">&#8853;</div>
        <h3 class="feature-heading">Downstream Projects</h3>
        <p class="feature-desc">
          Email signatures, social templates, presentation decks &mdash; every touchpoint
          expressing the same brand with precision.
        </p>
      </div>

    </div>
  </section>

  <!-- Proof of Work -->
  <section class="proof container">
    <h2 class="section-heading">Proof of Work</h2>
    <div class="case-study">

      <div class="case-header">
        <div class="case-meta">
          <span class="case-label">Client</span>
          <h3 class="case-name">Staples &amp; Statements</h3>
          <p class="case-type">Wardrobe Stylist &mdash; Personal Brand</p>
        </div>
        <div class="case-stats">
          <div class="stat">
            <span class="stat-value">52k+</span>
            <span class="stat-label">Instagram</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-value">0 &rarr; 1</span>
            <span class="stat-label">Brand Identity</span>
          </div>
        </div>
      </div>

      <div class="case-body">
        <div class="case-built">
          <h4 class="case-section-label">What We Built</h4>
          <ul class="built-list">
            <li>Brand constitution &amp; positioning</li>
            <li>Complete brand bible</li>
            <li>Design token system</li>
            <li>Full website</li>
            <li>Social presence architecture</li>
          </ul>
        </div>

        <div class="case-testimonial">
          <blockquote class="testimonial-quote">
            <p class="quote-text quote-pending">Testimonial incoming &mdash; watch this space.</p>
          </blockquote>
        </div>
      </div>

      <div class="case-footer">
        <a
          href="https://staplesandstatements.com"
          class="case-link"
          target="_blank"
          rel="noopener noreferrer"
        >
          View Live Site: staplesandstatements.com &rarr;
        </a>
      </div>

    </div>
  </section>

  <!-- Contact CTA -->
  <section class="contact container">
    <div class="contact-panel">
      <h2 class="contact-heading">Start with a Conversation</h2>
      <p class="contact-text">
        Every engagement begins with a discovery call. We scope the work, price it precisely,
        and build it right. No retainers, no hourly surprises.
      </p>
      <p class="contact-price">Starting at $2,500 &mdash; scoped to your business.</p>
      <a href="mailto:consult@sg57.dev" class="cta-button">
        consult@sg57.dev &rarr;
      </a>
    </div>
  </section>

</Base>

<style>
  /* Accent scope */
  .hero, .problem, .deliverables, .proof, .contact {
    --sg57-accent:       #C4896A;
    --sg57-accent-hover: #D49A7A;
    --sg57-accent-muted: #A87558;
    --sg57-accent-glow:  rgba(196, 137, 106, 0.15);
  }

  /* --- Hero --- */
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 55vh;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(196, 137, 106, 0.02) 2px,
        rgba(196, 137, 106, 0.02) 4px
      ),
      radial-gradient(ellipse at 50% 40%, rgba(196, 137, 106, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    text-align: center;
    padding: 5rem 1.5rem 4rem;
  }

  .service-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    margin-bottom: 1.5rem;
    animation: hero-in 1.0s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .mark-bracket {
    font-family: var(--sg57-font-display);
    font-weight: 200;
    font-size: 1.75rem;
    color: var(--sg57-accent-muted);
    opacity: 0.6;
  }

  .mark-glyph {
    font-size: 1.1rem;
    color: var(--sg57-accent);
    animation: pulse-glow 4s ease-in-out infinite;
  }

  .hero-title {
    font-family: var(--sg57-font-display);
    font-weight: 700;
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    color: #ffffff;
    letter-spacing: 0.08em;
    margin-bottom: 1rem;
    line-height: 1.2;
    animation: hero-in 1.2s 0.1s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .hero-title .accent {
    color: var(--sg57-accent);
  }

  .hero-tagline {
    font-family: var(--sg57-font-display);
    font-weight: 500;
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--sg57-text);
    margin-bottom: 0.35rem;
    animation: hero-in 1.2s 0.2s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .hero-subtitle {
    font-family: var(--sg57-font-display);
    font-weight: 300;
    font-size: clamp(0.9rem, 1.5vw, 1.1rem);
    color: var(--sg57-text-dim);
    margin-bottom: 2rem;
    animation: hero-in 1.2s 0.3s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes hero-in {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0);    }
  }

  .cta-button {
    display: inline-block;
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.05em;
    color: #ffffff;
    background: var(--sg57-accent);
    padding: 0.75rem 2rem;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.2s ease, box-shadow 0.2s ease;
  }

  .cta-button:hover {
    background: var(--sg57-accent-hover);
    box-shadow: 0 0 24px var(--sg57-accent-glow);
    color: #ffffff;
  }

  /* --- Problem --- */
  .problem {
    padding: 3rem 1.5rem 4rem;
    max-width: 780px;
  }

  .problem-text {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: clamp(1rem, 1.8vw, 1.15rem);
    color: var(--sg57-text-dim);
    line-height: 1.8;
    text-align: center;
  }

  .problem-text strong {
    color: var(--sg57-text);
    font-weight: 600;
  }

  /* --- Deliverables --- */
  .deliverables {
    padding: 2rem 1.5rem 5rem;
  }

  .section-heading {
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 1.1rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sg57-accent);
    text-align: center;
    margin-bottom: 2rem;
  }

  .deliverables-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .deliverable-card {
    background: var(--sg57-surface);
    border: 1px solid var(--sg57-border);
    border-radius: 8px;
    padding: 2rem;
    transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.2s var(--sg57-ease-out);
  }

  .deliverable-card:hover {
    border-color: var(--sg57-accent-muted);
    box-shadow: 0 0 20px var(--sg57-accent-glow);
    transform: translateY(-2px);
  }

  .feature-icon {
    font-size: 1.75rem;
    color: var(--sg57-accent);
    margin-bottom: 1rem;
    line-height: 1;
  }

  .feature-heading {
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 1.05rem;
    letter-spacing: 0.08em;
    color: #ffffff;
    margin-bottom: 0.75rem;
  }

  .feature-desc {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: 0.9rem;
    color: var(--sg57-text-dim);
    line-height: 1.6;
  }

  /* --- Proof of Work --- */
  .proof {
    padding: 0 1.5rem 5rem;
  }

  .case-study {
    background: var(--frost-bg);
    backdrop-filter: blur(var(--frost-blur));
    -webkit-backdrop-filter: blur(var(--frost-blur));
    border: 1px solid var(--sg57-accent-muted);
    box-shadow: 0 0 40px var(--sg57-accent-glow), var(--frost-shadow);
    border-radius: 8px;
    overflow: hidden;
  }

  .case-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
    padding: 2rem 2.5rem;
    border-bottom: 1px solid var(--frost-border);
  }

  .case-label {
    font-family: var(--sg57-font-display);
    font-weight: 500;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--sg57-accent);
    display: block;
    margin-bottom: 0.4rem;
  }

  .case-name {
    font-family: var(--sg57-font-display);
    font-weight: 700;
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    color: #ffffff;
    letter-spacing: 0.03em;
    margin-bottom: 0.3rem;
  }

  .case-type {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: 0.9rem;
    color: var(--sg57-text-dim);
  }

  .case-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-shrink: 0;
  }

  .stat {
    text-align: center;
  }

  .stat-value {
    display: block;
    font-family: var(--sg57-font-display);
    font-weight: 700;
    font-size: 1.5rem;
    color: var(--sg57-accent);
    letter-spacing: 0.03em;
  }

  .stat-label {
    display: block;
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sg57-text-dim);
    margin-top: 0.2rem;
  }

  .stat-divider {
    width: 1px;
    height: 2.5rem;
    background: var(--frost-border);
    flex-shrink: 0;
  }

  .case-body {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
  }

  .case-built {
    padding: 2rem 2.5rem;
    border-right: 1px solid var(--frost-border);
  }

  .case-section-label {
    font-family: var(--sg57-font-display);
    font-weight: 500;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sg57-text-dim);
    margin-bottom: 1rem;
  }

  .built-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .built-list li {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: 0.9rem;
    color: var(--sg57-text);
    padding-left: 1.25rem;
    position: relative;
  }

  .built-list li::before {
    content: '◆';
    position: absolute;
    left: 0;
    font-size: 0.4rem;
    color: var(--sg57-accent);
    top: 0.38em;
  }

  .case-testimonial {
    padding: 2rem 2.5rem;
    display: flex;
    align-items: center;
  }

  .testimonial-quote {
    border-left: 2px solid var(--sg57-accent-muted);
    padding-left: 1.25rem;
  }

  .quote-text {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: 0.95rem;
    color: var(--sg57-text-dim);
    line-height: 1.7;
    font-style: italic;
  }

  .quote-pending {
    opacity: 0.38;
    font-style: normal;
    font-size: 0.82rem;
    letter-spacing: 0.05em;
  }

  .case-footer {
    padding: 1.25rem 2.5rem;
    border-top: 1px solid var(--frost-border);
  }

  .case-link {
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    color: var(--sg57-accent);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .case-link:hover {
    color: var(--sg57-accent-hover);
  }

  /* --- Contact CTA --- */
  .contact {
    padding: 0 1.5rem 6rem;
    max-width: 720px;
  }

  .contact-panel {
    background: var(--frost-bg);
    backdrop-filter: blur(var(--frost-blur));
    -webkit-backdrop-filter: blur(var(--frost-blur));
    border: 1px solid var(--frost-border);
    box-shadow: var(--frost-shadow);
    border-radius: 8px;
    padding: 3rem 2.5rem;
    text-align: center;
  }

  .contact-heading {
    font-family: var(--sg57-font-display);
    font-weight: 700;
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    color: #ffffff;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .contact-text {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: 1rem;
    color: var(--sg57-text-dim);
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  .contact-price {
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--sg57-accent);
    letter-spacing: 0.05em;
    margin-bottom: 2rem;
  }

  /* --- Responsive --- */
  @media (max-width: 900px) {
    .deliverables-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .case-body {
      grid-template-columns: 1fr;
    }

    .case-built {
      border-right: none;
      border-bottom: 1px solid var(--frost-border);
    }
  }

  @media (max-width: 720px) {
    .hero {
      min-height: 45vh;
    }

    .hero-content {
      padding: 3.5rem 1.5rem 3rem;
    }

    .deliverables-grid {
      grid-template-columns: 1fr;
    }

    .case-header {
      flex-direction: column;
      gap: 1.5rem;
      padding: 1.5rem;
    }

    .case-built,
    .case-testimonial,
    .case-footer {
      padding: 1.5rem;
    }
  }
</style>
