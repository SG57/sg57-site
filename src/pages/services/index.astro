---
import Base from '../../layouts/Base.astro';
import DigitalHealthQuiz from '../../components/services/DigitalHealthQuiz.astro';
import ProofOfWork from '../../components/shared/ProofOfWork.astro';
---

<Base
  title="Services — SG57 Labs"
  description="Brand systems, websites, and digital infrastructure for businesses that refuse to be invisible. Start with a free 2-minute health check."
  accentColor="#C4896A"
  accentHover="#D49A7A"
  accentMuted="#A87558"
  accentGlow="rgba(196, 137, 106, 0.15)"
>

  <!-- ══════════════════════════════════════════════════════════════════════════
       §1 HERO
       ══════════════════════════════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-scanlines"></div>
      <div class="hero-glow"></div>
    </div>
    <div class="hero-content container bloom">
      <div class="hero-eyebrow">
        <span class="eyebrow-bracket" aria-hidden="true">[</span>
        <span class="eyebrow-glyph" aria-hidden="true">◆</span>
        <span class="eyebrow-label">SG57 LABS // SERVICES</span>
        <span class="eyebrow-bracket" aria-hidden="true">]</span>
      </div>
      <h1 class="hero-title">
        YOUR DIGITAL PRESENCE<br/>
        IS EITHER WORKING FOR YOU<br/>
        <span class="hero-title-accent">— OR AGAINST YOU.</span>
      </h1>
      <p class="hero-sub">Eight questions. Two minutes. Find out exactly where you stand.</p>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════════════════
       §2 DIGITAL HEALTH CHECK (QUIZ)
       ══════════════════════════════════════════════════════════════════════════ -->
  <section class="quiz-section container" id="health-check" aria-labelledby="quiz-section-heading">
    <div class="quiz-section-header">
      <h2 class="section-label" id="quiz-section-heading">THE 2-MINUTE AUDIT</h2>
      <p class="quiz-section-sub">Honest questions. No fluff. A real signal.</p>
    </div>
    <DigitalHealthQuiz />
  </section>

  <!-- ══════════════════════════════════════════════════════════════════════════
       §3 CAPABILITIES
       ══════════════════════════════════════════════════════════════════════════ -->
  <section class="capabilities container" aria-labelledby="capabilities-heading">
    <div class="capabilities-header bloom">
      <h2 class="capabilities-eyebrow" id="capabilities-heading">WHAT WE DO</h2>
      <p class="capabilities-deck">
        Full-spectrum digital execution. Strategy → identity → build → ship.
      </p>
    </div>

    <div class="cap-grid">

      <!-- Brand Systems -->
      <div class="cap-card cap-card--brand">
        <div class="cap-glyph" aria-hidden="true">◈</div>
        <div class="cap-card-body">
          <h3 class="cap-name">BRAND SYSTEMS</h3>
          <p class="cap-tagline">Identities that outlast trends.</p>
          <ul class="cap-list">
            <li>Brand constitution &amp; positioning</li>
            <li>Visual identity &amp; design token architecture</li>
            <li>Brand bible &amp; usage guidelines</li>
            <li>Voice, tone &amp; messaging framework</li>
          </ul>
        </div>
      </div>

      <!-- Web Engineering -->
      <div class="cap-card cap-card--web">
        <div class="cap-glyph" aria-hidden="true">⟐</div>
        <div class="cap-card-body">
          <h3 class="cap-name">WEB ENGINEERING</h3>
          <p class="cap-tagline">Sites that convert, not just impress.</p>
          <ul class="cap-list">
            <li>Custom static &amp; full-stack builds</li>
            <li>Performance-first architecture</li>
            <li>Mobile-first, WCAG-accessible</li>
            <li>CMS integration &amp; content systems</li>
          </ul>
        </div>
      </div>

      <!-- Digital Infrastructure -->
      <div class="cap-card cap-card--infra">
        <div class="cap-glyph" aria-hidden="true">▣</div>
        <div class="cap-card-body">
          <h3 class="cap-name">DIGITAL INFRASTRUCTURE</h3>
          <p class="cap-tagline">The invisible machinery of growth.</p>
          <ul class="cap-list">
            <li>Domain &amp; hosting optimization</li>
            <li>Professional email infrastructure</li>
            <li>Analytics &amp; tracking setup</li>
            <li>SEO foundations &amp; structured data</li>
          </ul>
        </div>
      </div>

      <!-- Product Development -->
      <div class="cap-card cap-card--product">
        <div class="cap-glyph" aria-hidden="true">◉</div>
        <div class="cap-card-body">
          <h3 class="cap-name">PRODUCT DEVELOPMENT</h3>
          <p class="cap-tagline">From idea to production software.</p>
          <ul class="cap-list">
            <li>Full-stack SaaS &amp; web apps</li>
            <li>Mobile application development</li>
            <li>API design &amp; third-party integration</li>
            <li>MVP scaffolding &amp; architecture</li>
          </ul>
        </div>
      </div>

      <!-- Automation & AI -->
      <div class="cap-card cap-card--ai">
        <div class="cap-glyph" aria-hidden="true">⌬</div>
        <div class="cap-card-body">
          <h3 class="cap-name">AUTOMATION &amp; AI</h3>
          <p class="cap-tagline">Intelligence wired into your workflow.</p>
          <ul class="cap-list">
            <li>Custom AI-powered workflows</li>
            <li>LLM integration &amp; prompt engineering</li>
            <li>Process &amp; communications automation</li>
            <li>Intelligent feature development</li>
          </ul>
        </div>
      </div>

      <!-- Growth Architecture -->
      <div class="cap-card cap-card--growth">
        <div class="cap-glyph" aria-hidden="true">⊕</div>
        <div class="cap-card-body">
          <h3 class="cap-name">GROWTH ARCHITECTURE</h3>
          <p class="cap-tagline">Systems that compound over time.</p>
          <ul class="cap-list">
            <li>Social presence architecture</li>
            <li>Email marketing infrastructure</li>
            <li>Content &amp; publishing systems</li>
            <li>Launch campaign strategy</li>
          </ul>
        </div>
      </div>

    </div><!-- /cap-grid -->
  </section>

  <!-- ══════════════════════════════════════════════════════════════════════════
       §4 PROOF OF WORK — DANIELLE
       ══════════════════════════════════════════════════════════════════════════ -->
  <ProofOfWork />

  <!-- ══════════════════════════════════════════════════════════════════════════
       §5 TIER 3 / BIG FISH CTA
       ══════════════════════════════════════════════════════════════════════════ -->
  <section class="bigfish" aria-labelledby="bigfish-heading">
    <div class="container">
      <div class="bigfish-inner bloom">
        <div class="bigfish-tag" aria-hidden="true">
          <span class="bf-bracket">[</span>
          <span class="bf-glyph">◉</span>
          <span class="bf-bracket">]</span>
          <span class="bf-label">CUSTOM DEVELOPMENT</span>
        </div>
        <h2 class="bigfish-headline" id="bigfish-heading">
          Building something bigger?
        </h2>
        <p class="bigfish-body">
          Custom SaaS platforms. Mobile applications. Complex product architectures.
          If you&rsquo;re building a real product, we need a different conversation than
          a brand package can accommodate.
        </p>
        <p class="bigfish-body">
          Tell us what you&rsquo;re building. We&rsquo;ll tell you if we&rsquo;re the right fit.
        </p>
        <a href="#intake-form" class="bigfish-cta">
          Send Me the Brief <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════════════════
       §6 INTAKE FORM
       ══════════════════════════════════════════════════════════════════════════ -->
  <section class="intake container" id="intake-form" aria-labelledby="intake-heading">
    <h2 class="section-label" id="intake-heading">START THE CONVERSATION</h2>
    <p class="intake-deck">
      We&rsquo;ll review your situation and follow up within 24 hours.
      No pitch, no pressure — just a real conversation about what you&rsquo;re building.
    </p>

    <div class="intake-card" id="intake-card">

      <!-- ── FORM ── -->
      <form
        class="intake-form"
        id="sg57-intake-form"
        action="https://formspree.io/f/mojkpkyj"
        method="POST"
        aria-label="Services inquiry form"
        novalidate
      >
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" aria-hidden="true" />
        <input type="hidden" name="_subject" value="New Inquiry — SG57 Services" />

        <div class="form-row form-row--two">
          <div class="form-field">
            <label for="if-name" class="form-label">Your Name <span class="form-required" aria-label="required">*</span></label>
            <input type="text" id="if-name" name="name" class="form-input" required autocomplete="name" placeholder="Danielle Diaz" maxlength="200" />
          </div>
          <div class="form-field">
            <label for="if-email" class="form-label">Email Address <span class="form-required" aria-label="required">*</span></label>
            <input type="email" id="if-email" name="email" class="form-input" required autocomplete="email" placeholder="you@yourbusiness.com" maxlength="320" />
          </div>
        </div>

        <div class="form-row form-row--two">
          <div class="form-field">
            <label for="if-business" class="form-label">Business / Project Name <span class="form-required" aria-label="required">*</span></label>
            <input type="text" id="if-business" name="business" class="form-input" required placeholder="Staples &amp; Statements" maxlength="200" />
          </div>
          <div class="form-field">
            <label for="if-website" class="form-label">Current Website <span class="form-optional">(if any)</span></label>
            <input type="url" id="if-website" name="website" class="form-input" autocomplete="url" placeholder="https://yoursite.com" maxlength="2048" />
          </div>
        </div>

        <div class="form-row">
          <div class="form-field">
            <label for="if-challenge" class="form-label">What&rsquo;s your biggest digital challenge right now? <span class="form-required" aria-label="required">*</span></label>
            <textarea id="if-challenge" name="challenge" class="form-input form-textarea" required rows="4" placeholder="Tell us what's not working — or what you're trying to build." maxlength="5000"></textarea>
          </div>
        </div>

        <div class="form-row form-row--two">
          <div class="form-field">
            <label for="if-source" class="form-label">How did you hear about SG57?</label>
            <select id="if-source" name="source" class="form-input form-select">
              <option value="" disabled selected>Select one…</option>
              <option value="referral">Referral / Word of mouth</option>
              <option value="google">Google search</option>
              <option value="linkedin">LinkedIn</option>
              <option value="twitter">X / Twitter</option>
              <option value="github">GitHub</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="form-field form-field--submit">
            <button type="submit" class="form-submit" id="intake-submit">
              Send My Brief <span class="submit-arrow" aria-hidden="true">→</span>
            </button>
          </div>
        </div>

      </form>

      <!-- ── ERROR ── -->
      <div class="intake-error hidden" id="intake-error" role="alert" aria-live="polite" tabindex="-1">
        <p class="intake-error-text">Something went wrong — try again or reach us at <a href="mailto:consult@sg57.dev">consult@sg57.dev</a>.</p>
      </div>

      <!-- ── SUCCESS ── -->
      <div class="intake-success hidden" id="intake-success" role="status" aria-live="polite" tabindex="-1">
        <div class="success-ring" aria-hidden="true">
          <span class="success-ring-glyph">◆</span>
        </div>
        <div class="success-label" aria-hidden="true">// TRANSMISSION RECEIVED</div>
        <h3 class="success-headline">Brief received, <span id="success-name">there</span>.</h3>
        <p class="success-body">
          We&rsquo;ll follow up at <strong id="success-email"></strong> within 24 hours.<br/>
          No pitch. No pressure. Just a real conversation.
        </p>
      </div>

      <!-- ── PROGRESS BAR (absolute, bottom of card) ── -->
      <div class="intake-progress" id="intake-progress" aria-hidden="true">
        <div class="intake-progress-fill" id="intake-progress-fill"></div>
      </div>

    </div><!-- /intake-card -->
  </section>

</Base>

<script>
  document.addEventListener('astro:page-load', () => {
    try {
    const form         = document.getElementById('sg57-intake-form');
    const card         = document.getElementById('intake-card');
    const submitBtn    = document.getElementById('intake-submit');
    const successEl    = document.getElementById('intake-success');
    const errorEl      = document.getElementById('intake-error');
    const progressEl   = document.getElementById('intake-progress');
    const progressFill = document.getElementById('intake-progress-fill');
    if (!form || !card) return;

    let submitted = false; // hard lock — prevents any double submission

    function wait(ms) {
      return new Promise(r => setTimeout(r, ms));
    }

    // ── Animate progress fill ─────────────────────────────────────────────────
    function setProgress(pct, durationMs) {
      if (!progressFill) return;
      progressFill.style.transition = `width ${durationMs}ms cubic-bezier(0.4, 0, 0.6, 1)`;
      progressFill.style.width = `${pct}%`;
    }

    // ── Reset to idle (only on error) ─────────────────────────────────────────
    function resetToIdle() {
      submitted = false;
      card.classList.remove('card-sending');
      [...form.elements].forEach(el => (el.disabled = false));
      form.style.opacity = '';
      form.style.pointerEvents = '';
      if (submitBtn) {
        submitBtn.classList.remove('is-sending');
        submitBtn.innerHTML = 'Send My Brief <span class="submit-arrow" aria-hidden="true">\u2192</span>';
      }
      setProgress(0, 300);
      if (progressEl) setTimeout(() => { progressEl.style.opacity = '0'; }, 350);
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (submitted) return; // hard stop — catches rapid double-clicks

      // HTML5 validation
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      submitted = true;
      if (errorEl) errorEl.classList.add('hidden');

      // Capture personal details before we touch the form
      const firstName = (form.querySelector('#if-name')?.value?.trim() ?? '').split(' ')[0] || 'there';
      const email     = form.querySelector('#if-email')?.value?.trim() ?? '';

      try {
      // ── Phase 1: Lock everything, start scanner + progress ────────────────
      [...form.elements].forEach(el => (el.disabled = true));
      form.style.opacity = '0.45';
      form.style.pointerEvents = 'none';

      if (submitBtn) {
        submitBtn.classList.add('is-sending');
        submitBtn.innerHTML = '<span class="btn-spinner" aria-hidden="true">&#x25C8;</span> Transmitting\u2026';
      }

      card.classList.add('card-sending');
      if (progressEl) progressEl.style.opacity = '1';
      setProgress(0, 0);
      await wait(40); // let browser paint 0% before animating
      setProgress(72, 1800);

      // ── Phase 2: Fire request alongside minimum animation time ────────────
      const fetchPromise = fetch('https://formspree.io/f/mojkpkyj', {
        method: 'POST',
        body: new FormData(form),
        headers: { 'Accept': 'application/json' },
      }).catch(() => ({ ok: false }));

      const [res] = await Promise.all([fetchPromise, wait(1900)]);

      if (!res.ok) {
        resetToIdle();
        if (errorEl) {
          errorEl.classList.remove('hidden');
          errorEl.focus();
        }
        return;
      }

      // ── Phase 3: Complete the progress bar ────────────────────────────────
      setProgress(100, 220);
      await wait(340);

      // ── Phase 4: Collapse the form ────────────────────────────────────────
      card.classList.remove('card-sending');
      form.style.transition = 'opacity 0.38s ease, transform 0.38s cubic-bezier(0.4, 0, 1, 1)';
      form.style.opacity    = '0';
      form.style.transform  = 'translateY(-10px)';
      if (progressFill) {
        progressFill.style.transition = 'opacity 0.25s ease';
        progressFill.style.opacity    = '0';
      }
      await wait(400);

      form.style.display = 'none';
      if (progressEl) progressEl.style.display = 'none';

      // ── Phase 5: Reveal success ───────────────────────────────────────────
      const successNameEl = document.getElementById('success-name');
      const successEmailEl = document.getElementById('success-email');
      if (successNameEl) successNameEl.textContent = firstName;
      if (successEmailEl) successEmailEl.textContent = email;

      if (successEl) {
        card.classList.add('card-success');
        successEl.classList.remove('hidden');
        successEl.style.opacity   = '0';
        successEl.style.transform = 'translateY(12px) scale(0.97)';

        void successEl.offsetWidth; // reflow
        successEl.style.transition = 'opacity 0.55s ease, transform 0.55s cubic-bezier(0.22, 1, 0.36, 1)';
        successEl.style.opacity    = '1';
        successEl.style.transform  = 'translateY(0) scale(1)';

        successEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
        successEl.focus({ preventScroll: true });
      }

      } catch (err) {
        // If anything in the submission pipeline throws, reset the form
        // so the user can try again instead of being stuck in "sending" state.
        resetToIdle();
        if (errorEl) {
          errorEl.classList.remove('hidden');
          errorEl.focus();
        }
      }
    });
    } catch (_) { /* Form init failed — the fallback mailto link in the error state remains accessible */ }
  });
</script>

<style>
  /* Accent scope — matches Base.astro prop values */
  :root {
    --svc-accent:       var(--sg57-services-accent);
    --svc-accent-hover: var(--sg57-services-accent-hover);
    --svc-accent-muted: #A87558;
    --svc-accent-glow:  rgba(196, 137, 106, 0.15);
  }

  /* ── §1 HERO ─────────────────────────────────────────────────────────────── */

  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 70vh;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(196, 137, 106, 0.025) 2px,
      rgba(196, 137, 106, 0.025) 4px
    );
  }

  .hero-glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 30%, rgba(196, 137, 106, 0.12) 0%, transparent 70%),
      radial-gradient(ellipse 40% 30% at 50% 0%, rgba(196, 137, 106, 0.06) 0%, transparent 60%);
  }

  .hero-content {
    position: relative;
    text-align: center;
    padding: 6rem 1.5rem 5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 2rem;
    animation: fade-in 0.9s 0.1s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .eyebrow-bracket {
    font-family: var(--sg57-font-display);
    font-weight: 200;
    font-size: 1.125rem;
    color: var(--sg57-accent-muted);
    opacity: 0.55;
  }

  .eyebrow-glyph {
    font-size: 1.125rem;
    color: var(--sg57-accent);
    animation: pulse-glow 4s ease-in-out infinite;
  }

  .eyebrow-label {
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 1.125rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--sg57-accent);
  }

  .hero-title {
    font-family: var(--sg57-font-display);
    font-weight: 700;
    font-size: clamp(1.8rem, 5.5vw, 3.6rem);
    color: var(--sg57-text);
    letter-spacing: 0.04em;
    line-height: 1.15;
    margin-bottom: 1.5rem;
    animation: slide-up 1.0s 0.2s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .hero-title-accent {
    color: var(--sg57-accent);
  }

  .hero-sub {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: clamp(1.125rem, 1.8vw, 1.25rem);
    color: var(--sg57-text-dim);
    letter-spacing: 0.04em;
    margin-bottom: 2.5rem;
    animation: slide-up 1.0s 0.35s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  /* ── §2 QUIZ SECTION ─────────────────────────────────────────────────────── */

  .quiz-section {
    padding: 4rem 1.5rem 5rem;
  }

  .quiz-section-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .quiz-section-sub {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: 1.125rem;
    color: var(--sg57-text-dim);
    letter-spacing: 0.04em;
    margin-top: 0.5rem;
  }

  /* ── §3 CAPABILITIES ─────────────────────────────────────────────────────── */

  .capabilities {
    padding: 2rem 1.5rem 6rem;
  }

  .capabilities-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .capabilities-eyebrow {
    font-family: var(--sg57-font-display);
    font-weight: 700;
    font-size: clamp(2rem, 6vw, 4.5rem);
    letter-spacing: 0.12em;
    color: var(--sg57-text);
    line-height: 1;
    margin-bottom: 1rem;
  }

  .capabilities-deck {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: clamp(1.125rem, 1.6vw, 1.25rem);
    color: var(--sg57-text-dim);
    letter-spacing: 0.06em;
  }

  /* ──────────────────────────────────────────────────────────────────────
     CAPABILITY CARDS — 10+ conversion-driving improvements:
     1.  Whole-card scale on hover (not just glyph)
     2.  Z-index lift so hovered card overlaps neighbors
     3.  Per-card accent border-top glow line appears on hover
     4.  Per-card accent radial gradient intensifies 3× on hover
     5.  Glyph pulses with glow animation on hover
     6.  Card name text brightens to full white on hover
     7.  Tagline shifts from dim to readable on hover
     8.  List items stagger-fade brighter on hover (CSS-only)
     9.  List bullet dashes brighten to full accent on hover
     10. Subtle inner shadow adds depth on hover
     11. Card background shifts from dark to glass-dense
     12. Cursor changes to pointer to signal interactivity
     ────────────────────────────────────────────────────────────────────── */

  .cap-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    border: 1px solid var(--sg57-border);
    border-radius: var(--sg57-radius-lg);
    overflow: visible;
    background: var(--sg57-border);
  }

  .cap-card {
    display: flex;
    flex-direction: column;
    padding: 2.25rem 2rem;
    background: rgba(10, 10, 18, 0.85);
    position: relative;
    overflow: hidden;
    cursor: pointer;
    transition:
      transform 0.4s var(--sg57-ease-snap),
      box-shadow 0.4s ease,
      background 0.35s ease,
      z-index 0s;
  }

  /* Accent glow overlay — intensifies on hover */
  .cap-card::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  /* Top accent line — hidden until hover */
  .cap-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 10%;
    right: 10%;
    height: 2px;
    border-radius: 0 0 2px 2px;
    opacity: 0;
    transform: scaleX(0);
    transition: opacity 0.3s ease, transform 0.4s var(--sg57-ease-snap);
    pointer-events: none;
  }

  /* ── HOVER STATE — the whole card comes alive ── */
  .cap-card:hover {
