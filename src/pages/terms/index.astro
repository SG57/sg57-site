<style>
  .terms-page {
    position: relative;
    z-index: 1;
    padding: 6rem 0 6rem;
  }

  .container {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Page header ── */
  .page-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .page-label {
    font-family: var(--sg57-font-mono);
    font-size: 0.8125rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--sg57-accent);
    margin-bottom: 0.75rem;
  }

  .page-title {
    font-family: var(--sg57-font-display);
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--sg57-text-bright);
    letter-spacing: 0.04em;
    margin-bottom: 0.75rem;
  }

  .page-meta {
    font-family: var(--sg57-font-display);
    font-size: 0.9375rem;
    color: var(--sg57-text-muted);
  }

  /* ── Policy body ── */
  .policy-body {
    background: var(--sg57-surface);
    border: 1px solid var(--sg57-border);
    border-radius: var(--sg57-radius-md);
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .policy-section {
    padding: 2rem 0;
    border-bottom: 1px solid var(--sg57-border-subtle);
  }

  .policy-section--last {
    border-bottom: none;
    padding-bottom: 0;
  }

  .intro-text {
    font-family: var(--sg57-font-display);
    font-size: 1.0625rem;
    color: var(--sg57-text);
    line-height: 1.7;
  }

  .section-heading {
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 1.25rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sg57-accent);
    margin-bottom: 1.25rem;
  }

