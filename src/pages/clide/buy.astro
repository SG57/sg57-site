<!-- ══════════════════════════════════════════════════════════════════════════
     LemonSqueezy overlay overrides — GLOBAL
     The LS overlay is injected into document.body by lemon.js at runtime, so
     scoped styles above don't reach it. These rules:
       1. Hide the overlay while `body.ls-loading` — gives us a ~1.8 s head start
          to preload the iframe under cover of our scan animation.
       2. Cross-fade the overlay in when `body.ls-ready` — feels instant.
       3. Darken LS's default backdrop to match our void palette and wrap the
          (cross-origin, unstyleable) iframe in an accent halo so it reads as
          part of our interface.
     We cannot style inside the iframe (cross-origin). Everything here lives
     on OUR side of the iframe boundary.
     ══════════════════════════════════════════════════════════════════════════ -->
<style is:global>
  /* ── 1. Hide during scan ─────────────────────────────────────────────── */
  body.ls-loading .lemonsqueezy-overlay,
  body.ls-loading iframe[src*="lemonsqueezy.com"] {
    opacity: 0 !important;
    pointer-events: none !important;
    transition: opacity 0.35s ease !important;
  }

  /* ── 2. Reveal when ready ────────────────────────────────────────────── */
  body.ls-ready .lemonsqueezy-overlay,
  body.ls-ready iframe[src*="lemonsqueezy.com"] {
    opacity: 1 !important;
    pointer-events: auto !important;
    transition: opacity 0.45s cubic-bezier(0.22, 1, 0.36, 1) !important;
  }

  /* ── 3. Brand the surroundings ──────────────────────────────────────── */
  /* Replace LS's default near-black backdrop with our site's void gradient.
     Matches the rest of sg57.dev so the overlay doesn't feel like a foreign
     object landing mid-page. */
  .lemonsqueezy-overlay {
    background: radial-gradient(
      ellipse at center,
      rgba(12, 15, 22, 0.82) 0%,
      rgba(8, 10, 14, 0.94) 100%
    ) !important;
    backdrop-filter: blur(10px) !important;
    -webkit-backdrop-filter: blur(10px) !important;
  }

  /* Accent halo around the (necessarily white) iframe so it reads as a
     framed artefact rather than a plain white rectangle. The iframe itself
     retains LS's interior styling — dashboard theme is the only way to
     change those colors. */
  body.ls-ready iframe[src*="lemonsqueezy.com"] {
    border-radius: 14px !important;
    box-shadow:
      0 0 0 1px var(--sg57-accent-muted, rgba(91, 192, 190, 0.6)),
      0 0 60px rgba(91, 192, 190, 0.22),
      0 30px 90px rgba(0, 0, 0, 0.55) !important;
    outline: none !important;
  }
</style>
