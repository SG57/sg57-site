</Base>

<script>
  (async () => {
    try {
      const res = await fetch('https://api.github.com/repos/SG57/clide-releases/releases/latest');
      if (!res.ok) return;
      const release = await res.json();
      const assets = release.assets || [];
      const installer = assets.find(a => /Setup.*\.exe$/i.test(a.name));
      const portable = assets.find(a => /portable.*\.exe$/i.test(a.name));
      const version = release.tag_name;

      document.querySelectorAll('[data-download="installer"]').forEach(el => {
        if (installer) el.href = installer.browser_download_url;
        const badge = el.querySelector('[data-version]');
        if (badge) badge.textContent = version;
      });

      document.querySelectorAll('[data-download="portable"]').forEach(el => {
        if (portable) el.href = portable.browser_download_url;
      });
    } catch { /* network error — buttons still link to releases page */ }
  })();
</script>

<script>
  /* --- Screenshot Gallery --- */
  (() => {
    const track = document.getElementById('gallery-track');
    const dots = document.querySelectorAll('.gallery-dot');
    const prev = document.getElementById('gallery-prev');
    const next = document.getElementById('gallery-next');
    if (!track || !dots.length) return;

    const slides = track.querySelectorAll('.gallery-slide');
    const total = slides.length;
    let current = 0;

    function goTo(i: number) {
      current = ((i % total) + total) % total;
      slides[current].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
      dots.forEach((d, idx) => {
        d.classList.toggle('active', idx === current);
        d.setAttribute('aria-selected', String(idx === current));
      });
    }

    // Sync dots on native scroll-snap settle
    let scrollTimer: ReturnType<typeof setTimeout>;
    track.addEventListener('scroll', () => {
      clearTimeout(scrollTimer);
      scrollTimer = setTimeout(() => {
        const rect = track.getBoundingClientRect();
        const center = rect.left + rect.width / 2;
        let closest = 0;
        let minDist = Infinity;
        slides.forEach((s, i) => {
          const sr = s.getBoundingClientRect();
          const dist = Math.abs(sr.left + sr.width / 2 - center);
          if (dist < minDist) { minDist = dist; closest = i; }
        });
        if (closest !== current) {
          current = closest;
          dots.forEach((d, idx) => {
            d.classList.toggle('active', idx === current);
            d.setAttribute('aria-selected', String(idx === current));
          });
        }
      }, 80);
    }, { passive: true });

    dots.forEach(d => d.addEventListener('click', () => goTo(Number((d as HTMLElement).dataset.slide))));
    prev?.addEventListener('click', () => goTo(current - 1));
    next?.addEventListener('click', () => goTo(current + 1));

    // Keyboard nav when gallery is focused
    track.closest('.gallery')?.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'ArrowLeft') { e.preventDefault(); goTo(current - 1); }
      if (e.key === 'ArrowRight') { e.preventDefault(); goTo(current + 1); }
    });
  })();
</script>

