---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Clide — AI Terminal Command Center | SG57"
  description="Mission Control for your AI terminal sessions. Manage dozens of CLI AI agents from one cockpit."
  ogImage="/brand/clide-icon.svg"
  accentColor="#5BC0BE"
  accentHover="#6DD4D2"
  accentMuted="#4A9E9C"
  accentGlow="rgba(91, 192, 190, 0.15)"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Clide',
    description: 'Mission Control for your AI terminal sessions. Manage dozens of CLI AI agents from one cockpit.',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Windows, macOS, Linux',
    offers: [
      { '@type': 'Offer', price: '0', priceCurrency: 'USD', name: 'Free' },
      { '@type': 'Offer', price: '39', priceCurrency: 'USD', name: 'Pro', priceValidUntil: '2027-12-31' },
    ],
    author: { '@type': 'Organization', name: 'SG57 Labs', url: 'https://sg57.dev' },
  }}
>
  <!-- Hero — cinematic banner -->
  <section class="hero">
    <div class="hero-bg"></div>
    <!-- Mobile/portrait: product card replaces fullscreen hero bg -->
    <div class="mobile-hero-card" aria-hidden="true">
      <div class="mobile-hero-card-bg"></div>
      <div class="mobile-hero-card-scrim"></div>
    </div>
    <div class="hero-atmosphere" aria-hidden="true">
      <svg class="hero-stars" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <circle cx="145" cy="180" r="2.2" fill="#e4e0f5" opacity="0.45" class="star star-a" style="--td:-0.0s;--dur:9s"/>
        <circle cx="420" cy="320" r="1.8" fill="#c4bce8" opacity="0.35" class="star star-b" style="--td:-3.1s;--dur:11s"/>
        <circle cx="680" cy="85"  r="2.5" fill="#e4e0f5" opacity="0.45" class="star star-a" style="--td:-1.7s;--dur:8.5s"/>
        <circle cx="950" cy="440" r="2.0" fill="#b8b0e0" opacity="0.35" class="star star-b" style="--td:-5.2s;--dur:10.5s"/>
        <circle cx="1230" cy="210" r="1.8" fill="#e4e0f5" opacity="0.4" class="star star-a" style="--td:-2.4s;--dur:9.5s"/>
        <circle cx="260" cy="620" r="2.2" fill="#c4bce8" opacity="0.35" class="star star-b" style="--td:-7.8s;--dur:12s"/>
        <circle cx="830" cy="730" r="1.8" fill="#e4e0f5" opacity="0.4" class="star star-a" style="--td:-0.9s;--dur:8s"/>
        <circle cx="1100" cy="560" r="2.2" fill="#b8b0e0" opacity="0.35" class="star star-b" style="--td:-4.5s;--dur:11.5s"/>
        <circle cx="70" cy="450" r="1.3" fill="#9098b8" opacity="0.22" class="star star-c" style="--td:-8.1s;--dur:15s"/>
        <circle cx="490" cy="530" r="1.3" fill="#9098b8" opacity="0.22" class="star star-c" style="--td:-11.4s;--dur:14.5s"/>
        <circle cx="730" cy="200" r="1.4" fill="#8090b0" opacity="0.2" class="star star-d" style="--td:-4.2s;--dur:16s"/>
        <circle cx="1020" cy="120" r="1.3" fill="#9098b8" opacity="0.22" class="star star-c" style="--td:-9.8s;--dur:18s"/>
        <circle cx="1280" cy="400" r="1.5" fill="#8090b0" opacity="0.2" class="star star-d" style="--td:-1.5s;--dur:15.5s"/>
      </svg>
    </div>
    <div class="hero-content container bloom">
      <!-- h1 for SEO/a11y — visually minimal since "CLIDE_" is in the banner image -->
      <h1 class="hero-title sr-only">Clide — AI Terminal Command Center</h1>
      <span class="hero-label">AI TERMINAL COMMAND CENTER</span>
      <p class="hero-tagline">Mission Control for your AI terminal sessions.</p>
      <p class="hero-subtitle">Manage dozens of Claude Code, Cursor, and Aider sessions from one cockpit — without the tab chaos.</p>
      <div class="hero-actions">
        <a href="https://github.com/SG57/clide-releases/releases/latest" class="platform-btn platform-btn--windows" data-download="installer" aria-label="Download Clide for Windows">
          <svg class="pbtn-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <rect x="2" y="2" width="9" height="9" rx="1.5"/>
            <rect x="13" y="2" width="9" height="9" rx="1.5"/>
            <rect x="2" y="13" width="9" height="9" rx="1.5"/>
            <rect x="13" y="13" width="9" height="9" rx="1.5"/>
          </svg>
          <span class="pbtn-text">
            <span class="pbtn-sub">Download for</span>
            <span class="pbtn-main">Windows</span>
          </span>
          <span class="pbtn-badge" data-version>Latest</span>
        </a>
        <a href="https://github.com/SG57/clide-releases/releases/latest" class="download-alt" data-download="portable">or get the portable version</a>
      </div>
    </div>
  </section>


  <!-- Problem Statement -->
  <section class="problem container bloom">
    <p class="problem-text">
      You're running Claude Code, Cursor, Aider, and Copilot CLI &mdash; all at once.
      Tab switching between 12 terminal windows. Missing prompts. Losing context.
    </p>
    <p class="problem-text problem-punchline">
      <strong>Clide gives you one cockpit for all of them.</strong>
    </p>
  </section>

  <!-- Feature Cards -->
  <section class="features container">
    <h2 class="section-heading">Capabilities</h2>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">&#9638;</div>
        <h3 class="feature-heading">Mission Control</h3>
        <p class="feature-desc">
          Grid dashboard showing all your AI sessions at a glance.
          Status, duration, last output &mdash; everything visible without switching tabs.
        </p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">&#9655;</div>
        <h3 class="feature-heading">Sidekicks</h3>
        <p class="feature-desc">
          Run your dev server, test watcher, or log tail alongside your AI session.
          Up to 5 background companions per session on Pro.
        </p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">&#9998;</div>
        <h3 class="feature-heading">Structured Notes</h3>
        <p class="feature-desc">
          Capture prompts, diffs, and context as titled searchable cards.
          Pro unlocks the card mode; all users get freeform notes.
        </p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">&#128269;</div>
        <h3 class="feature-heading">Session Explorer</h3>
        <p class="feature-desc">
          Folder-based organization for your AI sessions. Pin, archive, recover
          from crashes, jump between dozens of contexts.
        </p>
      </div>
    </div>
  </section>

  <!-- Store Gallery -->
  <section class="media container">
    <h2 class="section-heading">Built for the AI Era</h2>
    <p class="media-tagline">Managing one AI session is easy. Managing ten is chaos. Clide is your mission control.</p>
  </section>

  <!-- Why Pro -->
  <section class="why-pro container bloom">
    <h2 class="section-heading">Why upgrade?</h2>
    <div class="why-pro-grid">
      <div class="why-pro-card">
        <div class="why-pro-icon">&#8734;</div>
        <h3>No session limits</h3>
        <p>Run as many AI agents simultaneously as your machine can handle. No artificial caps.</p>
      </div>
      <div class="why-pro-card">
        <div class="why-pro-icon">&#9998;</div>
        <h3>Structured notes</h3>
        <p>Organize AI context into titled, searchable cards per session. Never lose that one prompt that worked.</p>
      </div>
      <div class="why-pro-card">
        <div class="why-pro-icon">&#9889;</div>
        <h3>Sidekick presets</h3>
        <p>Save <code>pnpm dev</code>, <code>pnpm test --watch</code>, and your log tails once. Pro gives you 5 sidekicks per session (vs 1 on Free) and one-click presets to spawn them.</p>
      </div>
      <div class="why-pro-card">
        <div class="why-pro-icon">&#10760;</div>
        <h3>One-time payment</h3>
        <p>$39, forever. No subscription, no cloud lock-in. Your license, your machine.</p>
      </div>
    </div>
  </section>

  <!-- Pricing Table -->
  <section class="pricing container">
    <h2 class="section-heading">Simple, Honest Pricing</h2>
    <p class="section-subheading">One payment. No subscription. Yours forever.</p>
    <div class="pricing-grid">
      <!-- Free -->
      <div class="pricing-card">
        <div class="pricing-header">
          <h3 class="pricing-tier">Free</h3>
          <p class="pricing-price">$0</p>
        </div>
        <ul class="pricing-features">
          <li>3 concurrent sessions</li>
          <li>Freeform notes</li>
          <li>1 sidekick per session</li>
          <li>Notes export</li>
          <li>Terminal search</li>
          <li>Power Launch</li>
          <li>Full appearance customization</li>
          <li class="disabled">Structured notes</li>
          <li class="disabled">Sidekick presets</li>
        </ul>
      </div>

      <!-- Pro -->
      <div class="pricing-card highlighted">
        <div class="pricing-badge">Most Popular</div>
        <div class="pricing-header">
          <h3 class="pricing-tier">Pro</h3>
          <p class="pricing-price">$39 <span class="price-note">one-time</span></p>
          <p class="pricing-benefit">Everything you need to run dozens of AI agents.</p>
        </div>
        <ul class="pricing-features">
          <li>Unlimited concurrent sessions</li>
          <li class="included">Structured notes with search</li>
          <li class="included">Sidekick presets</li>
          <li class="included">5 sidekicks per session</li>
          <li class="included">Notes export</li>
          <li class="included">Terminal search</li>
          <li class="included">Power Launch</li>
          <li class="included">Full appearance customization</li>
          <li class="included">Priority support</li>
        </ul>
        <a href="https://sg57.dev/buy/clide-pro" class="pricing-cta">Get Pro &mdash; $39</a>
      </div>
    </div>
  </section>

  <!-- Download CTA -->
  <section class="download container">
    <h2 class="download-heading">Ready to take control?</h2>
    <a href="https://github.com/SG57/clide-releases/releases/latest" class="platform-btn platform-btn--windows" data-download="installer" aria-label="Download Clide for Windows">
      <svg class="pbtn-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <rect x="2" y="2" width="9" height="9" rx="1.5"/>
        <rect x="13" y="2" width="9" height="9" rx="1.5"/>
        <rect x="2" y="13" width="9" height="9" rx="1.5"/>
        <rect x="13" y="13" width="9" height="9" rx="1.5"/>
      </svg>
      <span class="pbtn-text">
        <span class="pbtn-sub">Download for</span>
        <span class="pbtn-main">Windows</span>
      </span>
      <span class="pbtn-badge" data-version>Latest</span>
    </a>
    <a href="https://github.com/SG57/clide-releases/releases/latest" class="download-alt" data-download="portable">or get the portable version</a>
  </section>
</Base>

<script>
  (async () => {
    try {
      const res = await fetch('https://api.github.com/repos/SG57/clide-releases/releases/latest');
      if (!res.ok) return;
      const release = await res.json();
      const assets = release.assets || [];
      const installer = assets.find(a => /Setup.*\.exe$/i.test(a.name));
      const portable = assets.find(a => /portable.*\.exe$/i.test(a.name));
      const version = release.tag_name;

      document.querySelectorAll('[data-download="installer"]').forEach(el => {
        if (installer) el.href = installer.browser_download_url;
        const badge = el.querySelector('[data-version]');
        if (badge) badge.textContent = version;
      });

      document.querySelectorAll('[data-download="portable"]').forEach(el => {
        if (portable) el.href = portable.browser_download_url;
      });
    } catch { /* network error — buttons still link to releases page */ }
  })();
</script>

<style>
  /* --- Hero --- */
  .hero {
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    min-height: 100vh;
    min-height: 100svh; /* safe viewport height — correct on mobile browsers */
    /* overflow-x: clip (not hidden) — clips sway animation horizontal overflow
       without clipping vertical bloom extension below section boundary.
       overflow: hidden was causing a hard-clipped edge at hero bottom that
       created a visible crease against the adjacent .bloom section. */
    overflow-x: clip;
  }

  /* Banner image — cinematic handheld sway
     Sway intensity: --sway: 6px  = small (subtle)
                     --sway: 12px = medium (default)
                     --sway: 20px = large (dramatic)  */
  .hero-bg {
    position: absolute;
    inset: -3%;
    background-image: url('/clide/clide-hero.webp');
    background-size: cover;
    background-position: center;
    pointer-events: none;
    --sway: 12px;
    animation: hero-sway 28s cubic-bezier(0.45, 0.05, 0.55, 0.95) infinite;
    will-change: transform;
    mask-image: linear-gradient(to bottom, black 68%, transparent 95%);
    -webkit-mask-image: linear-gradient(to bottom, black 68%, transparent 95%);
  }

  @keyframes hero-sway {
    0%   { transform: translate(0, 0)                         scale(1.002); }
    12%  { transform: translate(var(--sway), calc(var(--sway) * 0.6))   scale(1.005); }
    27%  { transform: translate(calc(var(--sway) * -0.7), var(--sway))  scale(1.001); }
    41%  { transform: translate(calc(var(--sway) * -1), calc(var(--sway) * -0.4)) scale(1.004); }
    58%  { transform: translate(calc(var(--sway) * 0.5), calc(var(--sway) * -0.9)) scale(1.002); }
    73%  { transform: translate(calc(var(--sway) * 0.8), calc(var(--sway) * 0.3))  scale(1.005); }
    87%  { transform: translate(calc(var(--sway) * -0.4), calc(var(--sway) * 0.7)) scale(1.001); }
    100% { transform: translate(0, 0)                         scale(1.002); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-bg { animation: none; inset: 0; }
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 0 1.5rem 4rem;
    width: 100%;
  }

  .hero-label {
    display: block;
    font-family: var(--sg57-font-mono);
    font-size: 1.125rem;
    letter-spacing: 0.22em;
    color: var(--sg57-accent);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  /* Product accent override — scoped to all page sections */
  .hero,
  .problem,
  .features,
  .media,
  .why-pro,
  .pricing,
  .download {
    --sg57-accent: var(--sg57-clide-accent);
    --sg57-accent-hover: var(--sg57-clide-accent-hover);
    --sg57-accent-muted: #4A9E9C;
    --sg57-accent-glow: rgba(91, 192, 190, 0.15);
  }

  .hero-tagline {
    font-family: var(--sg57-font-display);
    font-weight: 500;
    font-size: clamp(1.125rem, 2vw, 1.25rem);
    color: var(--sg57-text);
    margin-bottom: 0.35rem;
  }

  .hero-subtitle {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: clamp(1.125rem, 1.5vw, 1.25rem);
    color: var(--sg57-text);
    margin-bottom: 2rem;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.8);
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 1.125rem;
    letter-spacing: 0.05em;
    color: var(--sg57-accent);
    background: var(--sg57-glass-bg);
    backdrop-filter: blur(var(--sg57-glass-blur));
    -webkit-backdrop-filter: blur(var(--sg57-glass-blur));
    border: 1px solid var(--sg57-accent-muted);
    padding: 0.75rem 2rem;
    border-radius: var(--sg57-radius-md);
    text-decoration: none;
    transition: color 0.25s ease, background 0.25s ease, border-color 0.25s ease,
                box-shadow 0.3s ease, transform 0.2s var(--sg57-ease-out);
  }

  .cta-button:hover {
    color: var(--sg57-text-on-accent);
    background: var(--sg57-accent);
    border-color: var(--sg57-accent);
    box-shadow: 0 0 28px var(--sg57-accent-glow);
    transform: translateY(-1px);
  }

  .cta-button:active {
    transform: scale(0.97) translateY(0);
  }

  .cta-button:focus-visible {
    box-shadow: var(--sg57-focus-ring), 0 0 28px var(--sg57-accent-glow);
    outline: none;
  }

  /* --- Hero atmosphere: ambient glow + starfield above wallpaper --- */
  /* Hero atmosphere — starfield container only.
     Ambient glow handled globally by .ambient-drift in Base.astro (screen blend). */
  .hero-atmosphere {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    mask-image: linear-gradient(to bottom, black 70%, transparent 95%);
    -webkit-mask-image: linear-gradient(to bottom, black 70%, transparent 95%);
  }

  .hero-stars {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .star {
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
    animation-fill-mode: both;
  }

  .star-a {
    animation-name: star-drift-a, star-twinkle;
    animation-duration: var(--dur, 10s), 4.5s;
    animation-delay: var(--td, 0s), var(--td, 0s);
  }
  .star-b {
    animation-name: star-drift-b, star-twinkle;
    animation-duration: var(--dur, 10s), 5.8s;
    animation-delay: var(--td, 0s), var(--td, 0s);
  }
  .star-c {
    animation-name: star-drift-c;
    animation-duration: var(--dur, 16s);
    animation-delay: var(--td, 0s);
  }
  .star-d {
    animation-name: star-drift-d;
    animation-duration: var(--dur, 16s);
    animation-delay: var(--td, 0s);
  }

  @keyframes star-drift-a {
    0%   { transform: translate(0, 0); }
    25%  { transform: translate(13px, -9px); }
    55%  { transform: translate(7px, 14px); }
    80%  { transform: translate(-11px, 4px); }
    100% { transform: translate(0, 0); }
  }
  @keyframes star-drift-b {
    0%   { transform: translate(0, 0); }
    30%  { transform: translate(-14px, 8px); }
    65%  { transform: translate(10px, -12px); }
    100% { transform: translate(0, 0); }
  }
  @keyframes star-drift-c {
    0%   { transform: translate(0, 0); }
    35%  { transform: translate(9px, -6px); }
    60%  { transform: translate(4px, 10px); }
    85%  { transform: translate(-8px, 3px); }
    100% { transform: translate(0, 0); }
  }
  @keyframes star-drift-d {
    0%   { transform: translate(0, 0); }
    40%  { transform: translate(-7px, 10px); }
    70%  { transform: translate(8px, -5px); }
    100% { transform: translate(0, 0); }
  }
  @keyframes star-twinkle {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.3; }
  }


  /* --- Problem Statement --- */
  .problem {
    position: relative;
    z-index: 1;
    padding: 3rem 1.5rem 4rem;
    max-width: 780px;
  }

  .problem-text {
    font-family: var(--sg57-font-display);
    font-weight: 500;
    font-size: clamp(1.125rem, 1.8vw, 1.25rem);
    color: var(--sg57-text);
    line-height: 1.8;
    text-align: center;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.8), 0 0 4px rgba(0, 0, 0, 0.9);
  }

  .problem-text strong {
    color: var(--sg57-text-bright);
    font-weight: 700;
  }

  /* --- Features --- */
  .features {
    padding: 2rem 1.5rem 5rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .feature-card {
    background: var(--sg57-surface);
    border: 1px solid var(--sg57-border);
    border-radius: var(--sg57-radius-md);
    padding: 2rem;
    transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.2s var(--sg57-ease-out);
  }

  .feature-card:hover {
    border-color: var(--sg57-accent-muted);
    box-shadow: 0 0 20px var(--sg57-accent-glow);
    transform: translateY(-2px);
  }

  .feature-card:focus-visible {
    box-shadow: var(--sg57-focus-ring);
    outline: none;
  }

  .feature-icon {
    font-size: 1.75rem;
    color: var(--sg57-accent);
    margin-bottom: 1rem;
    line-height: 1;
  }

  .feature-heading {
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 1.125rem;
    letter-spacing: 0.08em;
    color: var(--sg57-text);
    margin-bottom: 0.75rem;
  }

  .feature-desc {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: 1.125rem;
    color: var(--sg57-text-dim);
    line-height: 1.6;
  }

  /* --- Store Media --- */
  .media {
    padding: 0 1.5rem 5rem;
  }

  /* --- Media tagline --- */
  .media-tagline {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
    color: var(--sg57-text-muted);
    font-family: var(--sg57-font-display);
    font-size: var(--font-lg, 1.1rem);
    line-height: 1.7;
  }

  /* --- Pricing --- */
  .pricing {
    padding: 2rem 1.5rem 5rem;
  }

  .section-heading {
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 1.125rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sg57-accent);
    text-align: center;
    margin-bottom: 2rem;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 380px));
    gap: 1.5rem;
    align-items: start;
    justify-content: center;
  }

  .pricing-card {
    position: relative;
    background: var(--sg57-surface);
    border: 1px solid var(--sg57-border);
    border-radius: var(--sg57-radius-md);
    padding: 2rem 1.5rem;
    transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.2s var(--sg57-ease-out);
  }

  .pricing-card:hover {
    border-color: var(--sg57-accent-muted);
    box-shadow: 0 0 20px var(--sg57-accent-glow);
    transform: translateY(-2px);
  }

  .pricing-card:focus-visible {
    box-shadow: var(--sg57-focus-ring);
    outline: none;
  }

