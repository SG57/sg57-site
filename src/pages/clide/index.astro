      <div class="feature-card">
        <div class="feature-left">
          <div class="feature-icon" aria-hidden="true">
            <svg viewBox="0 0 44 44" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="8" y="8" width="28" height="28" rx="3"/>
              <path d="M18 16l10 6-10 6V16z" fill="none" stroke-width="1.5"/>
