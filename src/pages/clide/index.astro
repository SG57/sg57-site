              <rect x="24" y="6" width="14" height="14" rx="2"/>
              <rect x="6" y="24" width="14" height="14" rx="2"/>
              <rect x="24" y="24" width="14" height="14" rx="2"/>
              <circle cx="13" cy="13" r="2" opacity="0.4"/>
              <circle cx="31" cy="13" r="2" opacity="0.4"/>
              <circle cx="13" cy="31" r="2" opacity="0.4"/>
              <circle cx="31" cy="31" r="2" opacity="0.4"/>
            </svg>
          </div>
          <h3 class="feature-name">Mission Control</h3>
        </div>
        <div class="feature-right">
