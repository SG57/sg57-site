              <path d="M22 6v10l6 4"/>
              <path d="M12 16l10 8 10-8" opacity="0.25"/>
              <path d="M16 30l6-4 6 4" stroke-width="2"/>
              <circle cx="22" cy="34" r="4" opacity="0.3"/>
            </svg>
          </div>
          <h3 class="feature-name">Sidekick presets</h3>
        </div>
        <div class="feature-right">
