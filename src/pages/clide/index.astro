---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Clide — AI Terminal Command Center | SG57"
  description="Mission Control for your AI terminal sessions. Manage dozens of CLI AI agents from one cockpit."
  ogImage="/brand/clide-icon.svg"
  accentColor="#5BC0BE"
  accentHover="#6DD4D2"
  accentMuted="#4A9E9C"
  accentGlow="rgba(91, 192, 190, 0.15)"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Clide',
    description: 'Mission Control for your AI terminal sessions. Manage dozens of CLI AI agents from one cockpit.',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Windows 10, Windows 11',
    inLanguage: ['en', 'es', 'ja', 'de', 'fr', 'ko', 'zh-Hans', 'pt-BR'],
    offers: [
      { '@type': 'Offer', price: '0', priceCurrency: 'USD', name: 'Free' },
      { '@type': 'Offer', price: '39', priceCurrency: 'USD', name: 'Pro', priceValidUntil: '2027-12-31' },
    ],
    author: { '@type': 'Organization', name: 'SG57 Labs', url: 'https://sg57.dev' },
  }}
>
  <!-- Hero — cinematic banner -->
  <section class="hero">
    <div class="hero-bg"></div>
    <!-- Mobile/portrait: product card replaces fullscreen hero bg -->
    <div class="mobile-hero-card" aria-hidden="true">
      <div class="mobile-hero-card-bg"></div>
      <div class="mobile-hero-card-scrim"></div>
    </div>
    <div class="hero-atmosphere" aria-hidden="true">
      <svg class="hero-stars" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <circle cx="145" cy="180" r="2.2" fill="#e4e0f5" opacity="0.45" class="star star-a" style="--td:-0.0s;--dur:9s"/>
        <circle cx="420" cy="320" r="1.8" fill="#c4bce8" opacity="0.35" class="star star-b" style="--td:-3.1s;--dur:11s"/>
        <circle cx="680" cy="85"  r="2.5" fill="#e4e0f5" opacity="0.45" class="star star-a" style="--td:-1.7s;--dur:8.5s"/>
        <circle cx="950" cy="440" r="2.0" fill="#b8b0e0" opacity="0.35" class="star star-b" style="--td:-5.2s;--dur:10.5s"/>
        <circle cx="1230" cy="210" r="1.8" fill="#e4e0f5" opacity="0.4" class="star star-a" style="--td:-2.4s;--dur:9.5s"/>
        <circle cx="260" cy="620" r="2.2" fill="#c4bce8" opacity="0.35" class="star star-b" style="--td:-7.8s;--dur:12s"/>
        <circle cx="830" cy="730" r="1.8" fill="#e4e0f5" opacity="0.4" class="star star-a" style="--td:-0.9s;--dur:8s"/>
        <circle cx="1100" cy="560" r="2.2" fill="#b8b0e0" opacity="0.35" class="star star-b" style="--td:-4.5s;--dur:11.5s"/>
        <circle cx="70" cy="450" r="1.3" fill="#9098b8" opacity="0.22" class="star star-c" style="--td:-8.1s;--dur:15s"/>
        <circle cx="490" cy="530" r="1.3" fill="#9098b8" opacity="0.22" class="star star-c" style="--td:-11.4s;--dur:14.5s"/>
        <circle cx="730" cy="200" r="1.4" fill="#8090b0" opacity="0.2" class="star star-d" style="--td:-4.2s;--dur:16s"/>
        <circle cx="1020" cy="120" r="1.3" fill="#9098b8" opacity="0.22" class="star star-c" style="--td:-9.8s;--dur:18s"/>
        <circle cx="1280" cy="400" r="1.5" fill="#8090b0" opacity="0.2" class="star star-d" style="--td:-1.5s;--dur:15.5s"/>
      </svg>
    </div>
    <div class="hero-panel">
      <div class="hero-panel-inner container">
        <div class="hero-identity">
          <!-- h1 for SEO/a11y — "CLIDE_" is in the banner image -->
          <h1 class="sr-only">Clide — AI Terminal Command Center</h1>
          <span class="hero-label">AI TERMINAL COMMAND CENTER</span>
          <p class="hero-tagline">Mission Control for your AI terminal sessions.</p>
          <p class="hero-subtitle">Manage dozens of Claude Code, Cursor, and Aider sessions from one cockpit — without the tab chaos.</p>
        </div>
        <div class="hero-actions">
          <a href="https://github.com/SG57/clide-releases/releases/latest" class="platform-btn platform-btn--windows" data-download="installer" aria-label="Download Clide for Windows">
            <svg class="pbtn-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <rect x="2" y="2" width="9" height="9" rx="1.5"/>
              <rect x="13" y="2" width="9" height="9" rx="1.5"/>
              <rect x="2" y="13" width="9" height="9" rx="1.5"/>
              <rect x="13" y="13" width="9" height="9" rx="1.5"/>
            </svg>
            <span class="pbtn-text">
              <span class="pbtn-sub">Download for</span>
              <span class="pbtn-main">Windows</span>
            </span>
            <span class="pbtn-badge" data-version>Latest</span>
          </a>
          <a href="https://github.com/SG57/clide-releases/releases/latest" class="download-alt" data-download="portable">or get the portable version</a>
        </div>
      </div>
    </div>
  </section>


  <!-- Problem Statement -->
  <section class="problem container bloom">
    <p class="problem-text">
      You're running Claude Code, Cursor, Aider, and Copilot CLI &mdash; all at once.
      Tab switching between 12 terminal windows. Missing prompts. Losing context.
    </p>
    <p class="problem-text problem-punchline">
      <strong>Clide gives you one cockpit for all of them.</strong>
    </p>
  </section>

  <!-- Screenshot Gallery -->
  <section class="media container">
    <h2 class="section-heading">See It in Action</h2>
    <p class="media-tagline">Managing one AI session is easy. Managing ten is chaos. Clide is your mission control.</p>

    <div class="gallery" role="region" aria-label="Screenshot gallery" tabindex="0">
      <!-- Side arrows -->
      <button class="gallery-arrow gallery-arrow--left" aria-label="Previous screenshot" id="gallery-prev">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <button class="gallery-arrow gallery-arrow--right" aria-label="Next screenshot" id="gallery-next">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg>
      </button>

      <div class="gallery-track" id="gallery-track">
        <figure class="gallery-slide">
          <img src="/clide/screenshots/whats-new-dialog.webp" alt="Clide What's New dialog showing latest features on launch" width="1280" height="800" loading="eager" decoding="async" />
          <figcaption class="gallery-caption">Welcome — the What's New dialog greets you with every release</figcaption>
        </figure>
        <figure class="gallery-slide">
          <img src="/clide/screenshots/hero-full-workspace-1.webp" alt="Clide workspace with multiple AI sessions and sidekick processes" width="1920" height="1080" loading="lazy" decoding="async" />
          <figcaption class="gallery-caption">Full workspace — sessions, sidekicks, and notes in one cockpit</figcaption>
        </figure>
        <figure class="gallery-slide">
          <img src="/clide/screenshots/hero-full-workspace-2.webp" alt="Clide workspace showing terminal output and structured notes" width="1920" height="1080" loading="lazy" decoding="async" />
          <figcaption class="gallery-caption">Multi-session workflow with structured notes and live terminals</figcaption>
        </figure>
        <figure class="gallery-slide">
          <img src="/clide/screenshots/terminal-session.webp" alt="Clide terminal session with AI CLI output" width="1920" height="1080" loading="lazy" decoding="async" />
          <figcaption class="gallery-caption">Terminal session — rich output from Claude, Copilot, or any CLI</figcaption>
        </figure>
        <figure class="gallery-slide">
          <img src="/clide/screenshots/explorer-tree.webp" alt="Clide session explorer tree with color-coded sessions" width="1920" height="1080" loading="lazy" decoding="async" />
          <figcaption class="gallery-caption">Session explorer — color-coded, NATO-named, instantly recognizable</figcaption>
        </figure>
        <figure class="gallery-slide">
          <img src="/clide/screenshots/power-launch.webp" alt="Clide Power Launch dialog for batch session creation" width="1920" height="1080" loading="lazy" decoding="async" />
          <figcaption class="gallery-caption">Power Launch — spin up a full project stack in one shot</figcaption>
        </figure>
        <figure class="gallery-slide">
          <img src="/clide/screenshots/settings.webp" alt="Clide settings panel with appearance and terminal options" width="1920" height="1080" loading="lazy" decoding="async" />
          <figcaption class="gallery-caption">Settings — CRT effects, themes, fonts, and deep terminal config</figcaption>
        </figure>
      </div>
    </div>

    <!-- Dot navigation -->
    <div class="gallery-dots" role="tablist" aria-label="Gallery navigation">
      <button class="gallery-dot active" role="tab" aria-selected="true" aria-label="Screenshot 1" data-slide="0"></button>
      <button class="gallery-dot" role="tab" aria-selected="false" aria-label="Screenshot 2" data-slide="1"></button>
      <button class="gallery-dot" role="tab" aria-selected="false" aria-label="Screenshot 3" data-slide="2"></button>
      <button class="gallery-dot" role="tab" aria-selected="false" aria-label="Screenshot 4" data-slide="3"></button>
      <button class="gallery-dot" role="tab" aria-selected="false" aria-label="Screenshot 5" data-slide="4"></button>
      <button class="gallery-dot" role="tab" aria-selected="false" aria-label="Screenshot 6" data-slide="5"></button>
      <button class="gallery-dot" role="tab" aria-selected="false" aria-label="Screenshot 7" data-slide="6"></button>
    </div>
  </section>

