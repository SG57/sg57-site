---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Clide — AI Terminal Command Center | SG57"
  description="Mission Control for your AI terminal sessions. Manage dozens of CLI AI agents from one cockpit."
  ogImage="/brand/clide-icon.svg"
  accentColor="#5BC0BE"
  accentHover="#6DD4D2"
  accentMuted="#4A9E9C"
  accentGlow="rgba(91, 192, 190, 0.15)"
>
  <!-- Hero — cinematic banner -->
  <section class="hero">
    <div class="hero-bg"><div class="hero-bg-image"></div></div>
    <div class="hero-atmosphere" aria-hidden="true">
      <svg class="hero-stars" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <circle cx="145" cy="180" r="2.2" fill="#e4e0f5" opacity="0.45" class="star star-a" style="--td:-0.0s;--dur:9s"/>
        <circle cx="420" cy="320" r="1.8" fill="#c4bce8" opacity="0.35" class="star star-b" style="--td:-3.1s;--dur:11s"/>
        <circle cx="680" cy="85"  r="2.5" fill="#e4e0f5" opacity="0.45" class="star star-a" style="--td:-1.7s;--dur:8.5s"/>
        <circle cx="950" cy="440" r="2.0" fill="#b8b0e0" opacity="0.35" class="star star-b" style="--td:-5.2s;--dur:10.5s"/>
        <circle cx="1230" cy="210" r="1.8" fill="#e4e0f5" opacity="0.4" class="star star-a" style="--td:-2.4s;--dur:9.5s"/>
        <circle cx="260" cy="620" r="2.2" fill="#c4bce8" opacity="0.35" class="star star-b" style="--td:-7.8s;--dur:12s"/>
        <circle cx="830" cy="730" r="1.8" fill="#e4e0f5" opacity="0.4" class="star star-a" style="--td:-0.9s;--dur:8s"/>
        <circle cx="1100" cy="560" r="2.2" fill="#b8b0e0" opacity="0.35" class="star star-b" style="--td:-4.5s;--dur:11.5s"/>
        <circle cx="70" cy="450" r="1.3" fill="#9098b8" opacity="0.22" class="star star-c" style="--td:-8.1s;--dur:15s"/>
        <circle cx="490" cy="530" r="1.3" fill="#9098b8" opacity="0.22" class="star star-c" style="--td:-11.4s;--dur:14.5s"/>
        <circle cx="730" cy="200" r="1.4" fill="#8090b0" opacity="0.2" class="star star-d" style="--td:-4.2s;--dur:16s"/>
        <circle cx="1020" cy="120" r="1.3" fill="#9098b8" opacity="0.22" class="star star-c" style="--td:-9.8s;--dur:18s"/>
        <circle cx="1280" cy="400" r="1.5" fill="#8090b0" opacity="0.2" class="star star-d" style="--td:-1.5s;--dur:15.5s"/>
      </svg>
    </div>
    <div class="hero-blur-edge" aria-hidden="true"></div>
    <div class="hero-content container bloom">
      <!-- h1 for SEO/a11y — visually minimal since "CLIDE_" is in the banner image -->
      <h1 class="hero-title sr-only">Clide — AI Terminal Command Center</h1>
      <span class="hero-label">AI TERMINAL COMMAND CENTER</span>
      <p class="hero-tagline">Mission Control for your AI terminal sessions.</p>
      <p class="hero-subtitle">Manage dozens of CLI AI agents from one cockpit.</p>
      <div class="hero-actions">
        <a
          href="https://sg57.lemonsqueezy.com"
          class="cta-button"
          target="_blank"
          rel="noopener noreferrer"
        >
          Download &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Problem Statement -->
  <section class="problem container bloom">
    <p class="problem-text">
      You're running Claude Code, Cursor, Aider, and Copilot CLI &mdash; all at once.
      Tab switching between 12 terminal windows. Missing prompts. Losing context.
    </p>
    <p class="problem-text problem-punchline">
      <strong>Clide gives you one cockpit for all of them.</strong>
    </p>
  </section>

  <!-- Feature Cards -->
  <section class="features container">
    <h2 class="section-heading">Capabilities</h2>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">&#9638;</div>
        <h3 class="feature-heading">Mission Control</h3>
        <p class="feature-desc">
          Grid dashboard showing all your AI sessions at a glance.
          Status, duration, last output &mdash; everything visible without switching tabs.
        </p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">&#9881;</div>
        <h3 class="feature-heading">Concierge AI</h3>
        <p class="feature-desc">
          Auto-respond to terminal prompts with intelligent context.
          Set grace timers, configure response patterns, let Concierge handle the routine
          while you focus on the complex.
        </p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">&#9883;</div>
        <h3 class="feature-heading">Steward Mode</h3>
        <p class="feature-desc">
          Autonomous agent orchestration. Define missions, set objectives, and let Steward
          coordinate multiple AI agents to achieve your goals.
        </p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">&#9776;</div>
        <h3 class="feature-heading">Fleet Panel</h3>
        <p class="feature-desc">
          Tab tree with grouping, emoji tags, and session management.
          Organize dozens of sessions into logical groups. Drag, reorder, archive.
        </p>
      </div>
    </div>
  </section>

  <!-- Store Gallery -->
  <section class="media container">
    <h2 class="section-heading">Store Preview</h2>
    <div class="store-placeholder">
      <span class="placeholder-glyph">[ ]</span>
      <p class="placeholder-label">Store screenshots coming soon</p>
    </div>
  </section>

  <!-- Pricing Table -->
  <section class="pricing container">
    <h2 class="section-heading">Plans</h2>
    <div class="pricing-grid">
      <!-- Free -->
      <div class="pricing-card">
        <div class="pricing-header">
          <h3 class="pricing-tier">Free</h3>
          <p class="pricing-price">$0</p>
        </div>
        <ul class="pricing-features">
          <li>3 sessions</li>
          <li>Basic grid view</li>
          <li class="disabled">Multi-window</li>
          <li class="disabled">Intel Panel</li>
          <li class="disabled">Custom themes</li>
          <li class="disabled">Terminal search</li>
          <li class="disabled">Emoji tags</li>
          <li class="disabled">Concierge AI</li>
          <li class="disabled">Steward Mode</li>
        </ul>
      </div>

      <!-- Pro -->
      <div class="pricing-card highlighted">
        <div class="pricing-badge">Most Popular</div>
        <div class="pricing-header">
          <h3 class="pricing-tier">Pro</h3>
          <p class="pricing-price">$39 <span class="price-note">one-time</span></p>
        </div>
        <ul class="pricing-features">
          <li>Unlimited sessions</li>
          <li>Full dashboard</li>
          <li class="included">Multi-window</li>
          <li class="included">Intel Panel</li>
          <li class="included">Custom themes</li>
          <li class="included">Terminal search</li>
          <li class="included">Emoji tags</li>
          <li class="disabled">Concierge AI</li>
          <li class="disabled">Steward Mode</li>
        </ul>
      </div>

      <!-- AI Tier -->
      <div class="pricing-card">
        <div class="pricing-header">
          <h3 class="pricing-tier">AI Tier</h3>
          <p class="pricing-price">$5 <span class="price-note">/month</span></p>
        </div>
        <ul class="pricing-features">
          <li>Unlimited sessions</li>
          <li>Full dashboard</li>
          <li class="included">Multi-window</li>
          <li class="included">Intel Panel</li>
          <li class="included">Custom themes</li>
          <li class="included">Terminal search</li>
          <li class="included">Emoji tags</li>
          <li class="included">Concierge AI</li>
          <li class="included">Steward Mode</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Download CTA -->
  <section class="download container">
    <h2 class="download-heading">Ready to take control?</h2>
    <a
      href="https://sg57.lemonsqueezy.com"
      class="cta-button"
      target="_blank"
      rel="noopener noreferrer"
    >
      Download &rarr;
    </a>
  </section>
</Base>

<style>
  /* --- Hero --- */
  .hero {
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    min-height: 100vh;
    min-height: 100svh; /* safe viewport height — correct on mobile browsers */
    overflow: visible;
  }

  /* Banner image — cinematic handheld sway
     Sway intensity: --sway: 6px  = small (subtle)
                     --sway: 12px = medium (default)
                     --sway: 20px = large (dramatic)  */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .hero-bg-image {
    position: absolute;
    inset: -3%;
    background-image: url('/clide/clide-hero.webp');
    background-size: cover;
    background-position: center;
    opacity: 0.35;
    --sway: 12px;
    animation: hero-sway 28s cubic-bezier(0.45, 0.05, 0.55, 0.95) infinite;
    will-change: transform;
  }

  @keyframes hero-sway {
    0%   { transform: translate(0, 0)                         scale(1.002); }
    12%  { transform: translate(var(--sway), calc(var(--sway) * 0.6))   scale(1.005); }
    27%  { transform: translate(calc(var(--sway) * -0.7), var(--sway))  scale(1.001); }
    41%  { transform: translate(calc(var(--sway) * -1), calc(var(--sway) * -0.4)) scale(1.004); }
    58%  { transform: translate(calc(var(--sway) * 0.5), calc(var(--sway) * -0.9)) scale(1.002); }
    73%  { transform: translate(calc(var(--sway) * 0.8), calc(var(--sway) * 0.3))  scale(1.005); }
    87%  { transform: translate(calc(var(--sway) * -0.4), calc(var(--sway) * 0.7)) scale(1.001); }
    100% { transform: translate(0, 0)                         scale(1.002); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-bg-image { animation: none; inset: 0; }
  }

  /* Dark scrim — heavy at bottom where text lives */
  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(6, 10, 14, 0.7) 0%,
      rgba(6, 10, 14, 0.15) 35%,
      transparent 60%
    );
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 0 1.5rem 4rem;
    width: 100%;
  }

  .hero-label {
    display: block;
    font-family: var(--sg57-font-mono);
    font-size: 1.125rem;
    letter-spacing: 0.22em;
    color: var(--sg57-accent);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  /* Product accent override — scoped to all page sections */
  .hero,
  .problem,
  .features,
  .media,
  .pricing,
  .download {
    --sg57-accent: var(--sg57-clide-accent);
    --sg57-accent-hover: var(--sg57-clide-accent-hover);
    --sg57-accent-muted: #4A9E9C;
    --sg57-accent-glow: rgba(91, 192, 190, 0.15);
  }

  .hero-tagline {
    font-family: var(--sg57-font-display);
    font-weight: 500;
    font-size: clamp(1.125rem, 2vw, 1.25rem);
    color: var(--sg57-text);
    margin-bottom: 0.35rem;
  }

  .hero-subtitle {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: clamp(1.125rem, 1.5vw, 1.25rem);
    color: var(--sg57-text);
    margin-bottom: 2rem;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.8);
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 1.125rem;
    letter-spacing: 0.05em;
    color: var(--sg57-accent);
    background: var(--sg57-glass-bg);
    backdrop-filter: blur(var(--sg57-glass-blur));
    -webkit-backdrop-filter: blur(var(--sg57-glass-blur));
    border: 1px solid var(--sg57-accent-muted);
    padding: 0.75rem 2rem;
    border-radius: var(--sg57-radius-md);
    text-decoration: none;
    transition: color 0.25s ease, background 0.25s ease, border-color 0.25s ease,
                box-shadow 0.3s ease, transform 0.2s var(--sg57-ease-out);
  }

  .cta-button:hover {
    color: var(--sg57-text-on-accent);
    background: var(--sg57-accent);
    border-color: var(--sg57-accent);
    box-shadow: 0 0 28px var(--sg57-accent-glow);
    transform: translateY(-1px);
  }

  .cta-button:active {
    transform: scale(0.97) translateY(0);
  }

  .cta-button:focus-visible {
    box-shadow: var(--sg57-focus-ring), 0 0 28px var(--sg57-accent-glow);
    outline: none;
  }

  /* --- Hero atmosphere: ambient glow + starfield above wallpaper --- */
  /* Hero atmosphere — starfield container only.
     Ambient glow handled globally by .ambient-drift in Base.astro (screen blend). */
  .hero-atmosphere {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .hero-stars {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .star {
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
    animation-fill-mode: both;
  }

  .star-a {
    animation-name: star-drift-a, star-twinkle;
    animation-duration: var(--dur, 10s), 4.5s;
    animation-delay: var(--td, 0s), var(--td, 0s);
  }
  .star-b {
    animation-name: star-drift-b, star-twinkle;
    animation-duration: var(--dur, 10s), 5.8s;
    animation-delay: var(--td, 0s), var(--td, 0s);
  }
  .star-c {
    animation-name: star-drift-c;
    animation-duration: var(--dur, 16s);
    animation-delay: var(--td, 0s);
  }
  .star-d {
    animation-name: star-drift-d;
    animation-duration: var(--dur, 16s);
    animation-delay: var(--td, 0s);
  }

  @keyframes star-drift-a {
    0%   { transform: translate(0, 0); }
    25%  { transform: translate(13px, -9px); }
    55%  { transform: translate(7px, 14px); }
    80%  { transform: translate(-11px, 4px); }
    100% { transform: translate(0, 0); }
  }
  @keyframes star-drift-b {
    0%   { transform: translate(0, 0); }
    30%  { transform: translate(-14px, 8px); }
    65%  { transform: translate(10px, -12px); }
    100% { transform: translate(0, 0); }
  }
  @keyframes star-drift-c {
    0%   { transform: translate(0, 0); }
    35%  { transform: translate(9px, -6px); }
    60%  { transform: translate(4px, 10px); }
    85%  { transform: translate(-8px, 3px); }
    100% { transform: translate(0, 0); }
  }
  @keyframes star-drift-d {
    0%   { transform: translate(0, 0); }
    40%  { transform: translate(-7px, 10px); }
    70%  { transform: translate(8px, -5px); }
    100% { transform: translate(0, 0); }
  }
  @keyframes star-twinkle {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.3; }
  }

  /* --- Blur edge: feather hero wallpaper into site background --- */
  .hero-blur-edge {
    position: absolute;
    bottom: -200px;
    left: 0;
    right: 0;
    height: 200px;
    z-index: 0;
    background: linear-gradient(
      to bottom,
      rgba(6, 10, 14, 0.3) 0%,
      rgba(6, 10, 14, 0.15) 30%,
      rgba(6, 10, 14, 0.05) 60%,
      transparent 100%
    );
    pointer-events: none;
  }

  /* --- Problem Statement --- */
  .problem {
    position: relative;
    z-index: 1;
    padding: 3rem 1.5rem 4rem;
    max-width: 780px;
  }

  .problem-text {
    font-family: var(--sg57-font-display);
    font-weight: 500;
    font-size: clamp(1.125rem, 1.8vw, 1.25rem);
    color: var(--sg57-text);
    line-height: 1.8;
    text-align: center;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.8), 0 0 4px rgba(0, 0, 0, 0.9);
  }

  .problem-text strong {
    color: var(--sg57-text-bright);
    font-weight: 700;
  }

  /* --- Features --- */
  .features {
    padding: 2rem 1.5rem 5rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .feature-card {
    background: var(--sg57-surface);
    border: 1px solid var(--sg57-border);
    border-radius: var(--sg57-radius-md);
    padding: 2rem;
    transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.2s var(--sg57-ease-out);
  }

  .feature-card:hover {
    border-color: var(--sg57-accent-muted);
    box-shadow: 0 0 20px var(--sg57-accent-glow);
    transform: translateY(-2px);
  }

  .feature-card:focus-visible {
    box-shadow: var(--sg57-focus-ring);
    outline: none;
  }

  .feature-icon {
    font-size: 1.75rem;
    color: var(--sg57-accent);
    margin-bottom: 1rem;
    line-height: 1;
  }

  .feature-heading {
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 1.125rem;
    letter-spacing: 0.08em;
    color: var(--sg57-text);
    margin-bottom: 0.75rem;
  }

  .feature-desc {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: 1.125rem;
    color: var(--sg57-text-dim);
    line-height: 1.6;
  }

  /* --- Store Media --- */
  .media {
    padding: 0 1.5rem 5rem;
  }

  .store-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 3rem 2rem;
    border: 1px dashed var(--sg57-border);
    border-radius: var(--sg57-radius-md);
    background: var(--sg57-surface);
  }

  .placeholder-glyph {
    font-family: var(--sg57-font-display);
    font-size: 2rem;
    color: var(--sg57-accent-muted);
    letter-spacing: 0.3em;
    opacity: 0.4;
  }

  .placeholder-label {
    font-family: var(--sg57-font-display);
    font-size: 1.125rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sg57-text-muted);
    opacity: 0.5;
  }

  /* --- Pricing --- */
  .pricing {
    padding: 2rem 1.5rem 5rem;
  }

  .section-heading {
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 1.125rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sg57-accent);
    text-align: center;
    margin-bottom: 2rem;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    align-items: start;
  }

  .pricing-card {
    position: relative;
    background: var(--sg57-surface);
    border: 1px solid var(--sg57-border);
    border-radius: var(--sg57-radius-md);
    padding: 2rem 1.5rem;
    transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.2s var(--sg57-ease-out);
  }

  .pricing-card:hover {
    border-color: var(--sg57-accent-muted);
    box-shadow: 0 0 20px var(--sg57-accent-glow);
    transform: translateY(-2px);
  }

  .pricing-card:focus-visible {
    box-shadow: var(--sg57-focus-ring);
    outline: none;
  }

  .pricing-card.highlighted {
    border-color: var(--sg57-accent);
    box-shadow: 0 0 20px var(--sg57-accent-glow);
  }

  .pricing-badge {
    position: absolute;
    top: -0.75rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 1.125rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sg57-text-on-accent);
    background: var(--sg57-accent);
    padding: 0.25rem 0.75rem;
    border-radius: var(--sg57-radius-sm);
    white-space: nowrap;
  }

  .pricing-header {
    text-align: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--sg57-border);
  }

  .pricing-tier {
    font-family: var(--sg57-font-display);
    font-weight: 700;
    font-size: 1.15rem;
    letter-spacing: 0.1em;
    color: var(--sg57-text);
    margin-bottom: 0.35rem;
  }

  .pricing-price {
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: 1.75rem;
    color: var(--sg57-accent);
  }

  .price-note {
    font-weight: 400;
    font-size: 1.125rem;
    color: var(--sg57-text-dim);
  }

  .pricing-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .pricing-features li {
    font-family: var(--sg57-font-display);
    font-weight: 400;
    font-size: 1.125rem;
    color: var(--sg57-text);
    padding-left: 1.5rem;
    position: relative;
  }

  .pricing-features li::before {
    content: '\2713';
    position: absolute;
    left: 0;
    color: var(--sg57-success);
    font-weight: 700;
    font-size: 1.125rem;
  }

  .pricing-features li.included::before {
    content: '\2713';
    color: var(--sg57-success);
  }

  .pricing-features li.disabled {
    color: var(--sg57-text-muted);
  }

  .pricing-features li.disabled::before {
    content: '\2014';
    color: var(--sg57-text-muted);
  }

  /* --- Download CTA --- */
  .download {
    text-align: center;
    padding: 3rem 1.5rem 5rem;
  }

  .download-heading {
    font-family: var(--sg57-font-display);
    font-weight: 600;
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    color: var(--sg57-text);
    margin-bottom: 1.5rem;
    letter-spacing: 0.05em;
  }

  /* --- Responsive --- */
  @media (max-width: 900px) {
    .pricing-grid {
      grid-template-columns: 1fr;
      max-width: 400px;
      margin: 0 auto;
    }
  }

